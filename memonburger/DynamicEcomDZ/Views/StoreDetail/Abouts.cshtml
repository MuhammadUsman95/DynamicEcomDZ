@model DynamicEcomDZ.Models.RestaurantDetailViewModel
<!-- ══════════════ ABOUT SECTION ══════════════ -->
<section id="about" class="about-section">
    <div class="about-wrap">
        <div class="about-img-col">
            <img src="/images/SliderRegistration/@(Model.Sliders.Count > 0 ? Model.Sliders[0].SliderName : "placeholder.jpg")" class="about-img-main" alt="About Us" />
            <div class="about-badge-float">
                <div class="about-badge-num">9PM</div>
                <div class="about-badge-txt">Last Order<br>Time</div>
            </div>
        </div>
        <div class="about-text-col">
            <div class="about-tagline">Our Story</div>
            <h2 class="about-heading">Karachi's Favourite<br><em>Burger Joint</em></h2>
            <p class="about-body">Memon Burger has been serving the streets of Karachi with bold flavours and fresh ingredients. From crispy <strong>Chicken Wontons</strong> to our legendary <strong>Memon's Special Burger</strong> — every item is made fresh to order. Affordable prices, generous portions, and speedy delivery all over Karachi.</p>
            <!-- Menu Highlights Grid -->
            <div class="about-menu-grid">
                <div class="menu-highlight-card">
                    <div class="mhc-name">Memon's Special Burger</div>
                    <div class="mhc-price">Rs. 250</div>
                </div>
                <div class="menu-highlight-card">
                    <div class="mhc-name">Triple Kabab Burger</div>
                    <div class="mhc-price">Rs. 280</div>
                </div>
                <div class="menu-highlight-card">
                    <div class="mhc-name">Crispy Chicken Fry</div>
                    <div class="mhc-price">Rs. 100</div>
                </div>
                <div class="menu-highlight-card">
                    <div class="mhc-name">Chicken Wonton</div>
                    <div class="mhc-price">Rs. 30</div>
                </div>
            </div>
            <div class="info-badges">
                <div class="info-badge"><i class="bi bi-clock-fill"></i>11AM – 9PM</div>
                <div class="info-badge"><i class="bi bi-geo-alt-fill"></i>All Karachi</div>
                <div class="info-badge"><i class="bi bi-whatsapp"></i>0309-1211282</div>
            </div>
            <div class="about-btns">
                <a href="#shop" class="btn-primary-fill"><i class="bi bi-bag-heart"></i>Order Now</a>
                <button class="btn-outline-dark" data-bs-toggle="modal" data-bs-target="#aboutModal"><i class="bi bi-info-circle"></i>More Info</button>
            </div>
        </div>
    </div>
</section>
