@model DynamicEcomDZ.Models.RestaurantDetailViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Memon Burger</title>
    <link rel="icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <style>
        :root {
            --accent: #f5c518;
            --accent-dark: #d4a800;
            --bg: #fffcfc;
            --white: #fffcfc;
            --dark: #0d0d0d;
            --dark2: #1a1a1a;
            --muted: #555555;
            --border: rgba(13,13,13,.1);
            --radius: 10px;
            --tr: all .3s cubic-bezier(.4,0,.2,1);
            --shadow: 0 8px 40px rgba(0,0,0,.12);
            --display: 'Playfair Display', Georgia, serif;
            --body: 'DM Sans', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        ::-webkit-scrollbar {
            width: 5px
        }

        ::-webkit-scrollbar-track {
            background: #fffcfc
        }

        ::-webkit-scrollbar-thumb {
            background: var(--accent);
            border-radius: 10px
        }

        body {
            background: var(--bg);
            font-family: var(--body);
            color: var(--dark);
            overflow-x: hidden;
        }

        /* ── PROMO BAR ── */
        .promo-bar {
            background: var(--dark);
            color: var(--accent);
            font-size: .74rem;
            font-weight: 600;
            letter-spacing: .1em;
            text-align: center;
            padding: 9px 12px;
            position: sticky;
            top: 0;
            z-index: 1070;
        }

            .promo-bar span {
                margin: 0 16px;
                color: #fffcfc;
            }

                .promo-bar span i {
                    color: var(--accent);
                    margin-right: 5px
                }

        /* ── NAVBAR ── */
        .main-nav {
            background: #fffcfc;
            border-bottom: 2px solid var(--dark);
            position: sticky;
            top: 36px;
            z-index: 1060;
            box-shadow: 0 4px 20px rgba(0,0,0,.07);
        }

        .nav-inner {
            max-width: 1280px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            height: 68px;
        }

        .nav-logo img {
            height: 46px;
            width: auto;
            object-fit: contain;
            transition: var(--tr)
        }

            .nav-logo img:hover {
                transform: scale(1.04)
            }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 4px
        }

        .nav-link-item {
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--dark);
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 6px;
            transition: var(--tr);
            position: relative;
            cursor: pointer;
        }

            .nav-link-item::after {
                content: '';
                position: absolute;
                bottom: 4px;
                left: 50%;
                right: 50%;
                height: 2px;
                background: var(--accent);
                border-radius: 2px;
                transition: var(--tr);
            }

            .nav-link-item:hover::after, .nav-link-item.active::after {
                left: 16px;
                right: 16px
            }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 12px
        }

        .cart-pill {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--dark);
            border-radius: 6px;
            padding: 8px 16px;
            cursor: pointer;
            transition: var(--tr);
        }

            .cart-pill:hover {
                background: var(--accent)
            }

                .cart-pill:hover .cp-icon, .cart-pill:hover .cp-txt {
                    color: var(--dark)
                }

        .cp-icon {
            font-size: 1rem;
            color: var(--accent);
            transition: var(--tr)
        }

        .cp-txt {
            font-size: .78rem;
            font-weight: 700;
            color: #fffcfc;
            transition: var(--tr)
        }

        .cp-badge {
            background: var(--accent);
            color: var(--dark);
            font-size: .62rem;
            font-weight: 800;
            padding: 2px 7px;
            border-radius: 20px;
            transition: var(--tr);
        }

        .cart-pill:hover .cp-badge {
            background: var(--dark);
            color: var(--accent)
        }

        .nav-hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 6px
        }

            .nav-hamburger span {
                display: block;
                width: 22px;
                height: 2px;
                background: var(--dark);
                border-radius: 2px;
                transition: var(--tr)
            }

        .mobile-menu {
            display: none;
            position: fixed;
            inset: 0;
            background: var(--dark);
            z-index: 9000;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 28px;
        }

            .mobile-menu.open {
                display: flex
            }

            .mobile-menu .m-link {
                font-family: var(--display);
                font-size: 2rem;
                font-weight: 700;
                color: #fffcfc;
                text-decoration: none;
                transition: var(--tr);
                cursor: pointer;
            }

                .mobile-menu .m-link:hover {
                    color: var(--accent)
                }

        .mobile-menu-close {
            position: absolute;
            top: 24px;
            right: 24px;
            font-size: 1.4rem;
            cursor: pointer;
            color: #fffcfc;
            background: rgba(255,252,252,.1);
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--tr);
            border: none;
        }

            .mobile-menu-close:hover {
                background: var(--accent);
                color: var(--dark)
            }

        @@media(max-width:900px) {
            .nav-links {
                display: none
            }

            .nav-hamburger {
                display: flex
            }
        }

        @@media(max-width:576px) {
            .nav-inner {
                padding: 0 16px
            }
        }

        /* ══════════════════════════════
                   HERO SLIDER — BLACK & WHITE PROFESSIONAL
                   ══════════════════════════════ */
        .hero-slider {
            position: relative;
            overflow: hidden;
        }

        .hero-slide {
            position: relative;
            height: 520px;
            overflow: hidden;
            display: flex;
            align-items: center;
        }

        .hero-slide-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center 30%;
            transform-origin: center center;
            transition: none;
            filter: grayscale(15%) brightness(.9);
        }

        .carousel-item.active .hero-slide-img {
            animation: kenBurns 9s ease-in-out forwards;
        }

        @@keyframes kenBurns {
            from {
                transform: scale(1.07) translate(1%, .3%);
            }

            to {
                transform: scale(1) translate(0,0);
            }
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(100deg, rgba(0,0,0,.93) 0%, rgba(0,0,0,.62) 48%, rgba(0,0,0,.12) 100%), linear-gradient(0deg, rgba(0,0,0,.55) 0%, transparent 50%);
            z-index: 1;
        }

        /* Left white accent bar */
        .hero-slide::after {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            width: 4px;
            height: 100%;
            background: #fff;
            z-index: 4;
        }

        /* Top-right geometric corner */
        .hero-slide::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 180px;
            height: 180px;
            border-top: 1.5px solid rgba(255,255,255,.13);
            border-right: 1.5px solid rgba(255,255,255,.13);
            z-index: 4;
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 3;
            padding: 0 72px 0 68px;
            max-width: 660px;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        /* Tag */
        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: transparent;
            border: 1.5px solid rgba(255,255,255,.5);
            color: #fff;
            font-size: .6rem;
            font-weight: 800;
            letter-spacing: .26em;
            text-transform: uppercase;
            padding: 6px 16px;
            border-radius: 2px;
            margin-bottom: 18px;
            width: fit-content;
            opacity: 0;
            clip-path: inset(0 100% 0 0);
        }

        .carousel-item.active .hero-tag {
            animation: slideReveal .55s cubic-bezier(.16,1,.3,1) .1s forwards;
        }

        @@keyframes slideReveal {
            to {
                opacity: 1;
                clip-path: inset(0 0% 0 0);
            }
        }

        /* Heading */
        .hero-title {
            font-family: var(--display);
            font-size: 3.8rem;
            font-weight: 900;
            line-height: .97;
            color: #fff;
            margin-bottom: 16px;
            opacity: 0;
            transform: translateY(32px);
            letter-spacing: -.025em;
        }

            .hero-title em {
                color: #fff;
                font-style: italic;
                opacity: .5;
            }

        .carousel-item.active .hero-title {
            animation: riseUp .7s cubic-bezier(.16,1,.3,1) .3s forwards;
        }

        /* Divider */
        .hero-divider {
            width: 44px;
            height: 2px;
            background: rgba(255,255,255,.35);
            margin-bottom: 14px;
            opacity: 0;
            transform: translateY(12px);
        }

        .carousel-item.active .hero-divider {
            animation: riseUp .6s cubic-bezier(.16,1,.3,1) .46s forwards;
        }

        /* Subtitle */
        .hero-sub {
            font-size: .85rem;
            color: rgba(255,255,255,.48);
            line-height: 1.78;
            margin-bottom: 32px;
            max-width: 390px;
            opacity: 0;
            transform: translateY(20px);
            font-weight: 400;
            letter-spacing: .01em;
        }

        .carousel-item.active .hero-sub {
            animation: riseUp .62s cubic-bezier(.16,1,.3,1) .5s forwards;
        }

        @@keyframes riseUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Buttons */
        .hero-btns {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            opacity: 0;
            transform: translateY(16px);
        }

        .carousel-item.active .hero-btns {
            animation: riseUp .58s cubic-bezier(.16,1,.3,1) .66s forwards;
        }

        .hero-btn-primary {
            background: #fff;
            color: #0d0d0d;
            border: none;
            font-size: .72rem;
            font-weight: 900;
            letter-spacing: .13em;
            text-transform: uppercase;
            padding: 14px 32px;
            border-radius: 2px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 9px;
            transition: var(--tr);
            position: relative;
            overflow: hidden;
        }

            .hero-btn-primary::before {
                content: '';
                position: absolute;
                inset: 0;
                background: #0d0d0d;
                transform: translateX(-101%);
                transition: transform .32s ease;
            }

            .hero-btn-primary:hover {
                color: #fff;
            }

                .hero-btn-primary:hover::before {
                    transform: translateX(0);
                }

            .hero-btn-primary span, .hero-btn-primary i {
                position: relative;
                z-index: 1;
            }

        .hero-btn-outline {
            background: transparent;
            color: rgba(255,255,255,.65);
            border: 1.5px solid rgba(255,255,255,.28);
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            padding: 13px 26px;
            border-radius: 2px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 9px;
            transition: var(--tr);
        }

            .hero-btn-outline:hover {
                background: rgba(255,255,255,.1);
                color: #fff;
                border-color: rgba(255,255,255,.55);
            }

        /* Right stats */
        .hero-stats {
            position: absolute;
            right: 46px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 4;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .hstat {
            background: rgba(0,0,0,.52);
            backdrop-filter: blur(18px);
            border: 1px solid rgba(255,255,255,.1);
            border-left: 3px solid rgba(255,255,255,.65);
            border-radius: 0 5px 5px 0;
            padding: 13px 18px;
            text-align: center;
            min-width: 100px;
            transition: var(--tr);
        }

            .hstat:hover {
                background: rgba(255,255,255,.1);
                border-left-color: #fff;
            }

        .hstat-num {
            font-family: var(--display);
            font-size: 1.55rem;
            font-weight: 900;
            color: #fff;
            line-height: 1;
        }

        .hstat-lbl {
            font-size: .55rem;
            color: rgba(255,255,255,.36);
            letter-spacing: .13em;
            text-transform: uppercase;
            margin-top: 3px;
        }

        /* Slide counter */
        .hero-counter {
            position: absolute;
            bottom: 36px;
            right: 50px;
            z-index: 5;
            display: flex;
            align-items: baseline;
            gap: 3px;
            color: rgba(255,255,255,.25);
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .05em;
        }

        .hero-counter-cur {
            color: #fff;
            font-size: 1.25rem;
            font-weight: 900;
            line-height: 1;
        }

        /* Controls */
        .hero-slider .carousel-control-prev,
        .hero-slider .carousel-control-next {
            width: 46px;
            height: 46px;
            background: rgba(255,255,255,.06);
            backdrop-filter: blur(8px);
            border-radius: 2px;
            top: 50%;
            bottom: auto;
            transform: translateY(-50%);
            margin: 0 22px;
            opacity: 0;
            border: 1px solid rgba(255,255,255,.14);
            transition: var(--tr);
        }

        .hero-slider:hover .carousel-control-prev,
        .hero-slider:hover .carousel-control-next {
            opacity: 1;
        }

        .hero-slider .carousel-control-prev:hover,
        .hero-slider .carousel-control-next:hover {
            background: rgba(255,255,255,.16);
            border-color: rgba(255,255,255,.4);
        }

        /* Indicators */
        .hero-slider .carousel-indicators {
            margin-bottom: 26px;
            gap: 6px;
            justify-content: flex-start;
            padding-left: 72px;
        }

            .hero-slider .carousel-indicators button {
                width: 20px;
                height: 2px;
                border-radius: 0;
                background: rgba(255,255,255,.18);
                border: none;
                padding: 0;
                transition: var(--tr);
            }

            .hero-slider .carousel-indicators .active {
                width: 46px;
                background: #fff;
            }

        @@media(max-width:900px) {
            .hero-slide {
                height: 400px;
            }

            .hero-content {
                padding: 0 28px;
                max-width: 100%;
            }

            .hero-title {
                font-size: 2.6rem;
            }

            .hero-stats, .hero-counter {
                display: none;
            }

            .hero-slider .carousel-indicators {
                padding-left: 28px;
            }
        }

        @@media(max-width:576px) {
            .hero-slide {
                height: 320px;
            }

            .hero-content {
                padding: 0 18px;
            }

            .hero-title {
                font-size: 1.9rem;
            }

            .hero-sub, .hero-divider {
                display: none;
            }

            .hero-btns {
                gap: 8px;
            }

            .hero-btn-primary {
                padding: 11px 22px;
                font-size: .68rem;
            }

            .hero-btn-outline {
                display: none;
            }

            .hero-slider .carousel-indicators {
                padding-left: 18px;
            }
        }

        /* ── FEATURES STRIP ── */
        .features-strip {
            background: var(--dark);
            padding: 20px 0;
            border-bottom: 3px solid var(--accent);
        }

        .features-inner {
            max-width: 1280px;
            margin: auto;
            padding: 0 28px;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 14px;
        }

        .feat-item {
            display: flex;
            align-items: center;
            gap: 12px
        }

        .feat-icon {
            width: 42px;
            height: 42px;
            border-radius: 6px;
            background: rgba(245,197,24,.12);
            border: 1px solid rgba(245,197,24,.22);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--accent);
            flex-shrink: 0;
        }

        .feat-title {
            font-size: .78rem;
            font-weight: 700;
            color: #fffcfc
        }

        .feat-sub {
            font-size: .68rem;
            color: rgba(255,252,252,.38)
        }

        /* ── SECTION HEADER ── */
        .sec-hd {
            text-align: center;
            margin-bottom: 44px
        }

        .sec-hd-tag {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: .68rem;
            font-weight: 800;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: var(--dark);
            margin-bottom: 10px;
        }

            .sec-hd-tag::before, .sec-hd-tag::after {
                content: '';
                display: inline-block;
                width: 28px;
                height: 2px;
                background: var(--accent)
            }

        .sec-title {
            font-family: var(--display);
            font-size: 2.6rem;
            font-weight: 900;
            color: var(--dark);
            line-height: 1.15;
            margin-bottom: 8px
        }

        .sec-sub {
            font-size: .86rem;
            color: var(--muted);
            max-width: 480px;
            margin: 0 auto;
            line-height: 1.7
        }

        /* ── SHOP SECTION ── */
        .shop-section {
            padding: 1vh 0;
            background: #fffcfc
        }

        .shop-wrap {
            max-width: 1280px;
            margin: auto;
            padding: 0 28px
        }

        .shop-bar {
            background: var(--dark);
            border-radius: 8px;
            padding: 16px 22px;
            margin-bottom: 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            border-bottom: 3px solid var(--accent);
        }

        .shop-bar-name {
            font-weight: 800;
            color: var(--accent);
            font-size: 1rem;
            font-family: var(--display)
        }

        .shop-bar-addr {
            font-size: .72rem;
            color: rgba(255,252,252,.38);
            display: flex;
            align-items: center;
            gap: 4px
        }

            .shop-bar-addr i {
                color: var(--accent);
                font-size: .73rem
            }

        .filter-row {
            display: flex;
            gap: 10px
        }

            .filter-row .form-control, .filter-row .form-select {
                border: 2px solid rgba(13,13,13,.12);
                border-radius: 6px;
                font-size: .82rem;
                font-family: var(--body);
                background: #fffcfc;
                color: var(--dark);
                transition: var(--tr);
            }

                .filter-row .form-control:focus, .filter-row .form-select:focus {
                    border-color: var(--accent);
                    box-shadow: 0 0 0 3px rgba(245,197,24,.18)
                }

        @@media(max-width:700px) {
            .shop-bar {
                flex-direction: column;
                align-items: flex-start
            }

            .filter-row {
                width: 100%
            }

                .filter-row .form-control, .filter-row .form-select {
                    flex: 1
                }
        }

        .cat-title-row {
            margin: 40px 0 20px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .cat-title-row::before, .cat-title-row::after {
                content: '';
                flex: 1;
                height: 1px;
                background: linear-gradient(90deg,transparent,rgba(13,13,13,.12),transparent);
            }

        .cat-title-badge {
            background: var(--dark);
            color: var(--accent);
            padding: 7px 20px;
            border-radius: 4px;
            font-size: .76rem;
            font-weight: 800;
            letter-spacing: .05em;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 7px;
            border-bottom: 2px solid var(--accent);
        }

        /* ── PRODUCT CARD ── */
        .pcard {
            background: #fffcfc;
            border-radius: 12px;
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
            border: 1.5px solid rgba(13,13,13,.08);
            box-shadow: 0 4px 20px rgba(13,13,13,.06),0 1px 4px rgba(13,13,13,.04);
            transition: transform .4s cubic-bezier(.34,1.36,.64,1),box-shadow .35s ease,border-color .3s ease;
            cursor: pointer;
            position: relative;
        }

            .pcard::before {
                content: '';
                position: absolute;
                inset: 0;
                border-radius: 12px;
                background: linear-gradient(135deg,rgba(245,197,24,.04) 0%,transparent 60%);
                opacity: 0;
                transition: opacity .3s ease;
                pointer-events: none;
                z-index: 0;
            }

            .pcard:hover {
                transform: translateY(-10px) scale(1.01);
                box-shadow: 0 24px 60px rgba(13,13,13,.15),0 8px 20px rgba(13,13,13,.08);
                border-color: var(--accent)
            }

                .pcard:hover::before {
                    opacity: 1
                }

        .pcard-img {
            height: 190px;
            overflow: hidden;
            position: relative;
            background: linear-gradient(135deg,#1a1a1a 0%,#0d0d0d 100%);
            flex-shrink: 0;
        }

            .pcard-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform .55s cubic-bezier(.4,0,.2,1),filter .4s ease;
                display: block;
