@model DynamicEcomDZ.Models.RestaurantDetailViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Memon Burger</title>
    <link rel="icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&display=swap" rel="stylesheet">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <style>
        :root {
            --accent: #c8a96e;
            --accent-light: #dfc9a0;
            --accent-dark: #a8884e;
            --primary: #231f20;
            --primary-light: #3a3536;
            --bg: #ffffff;
            --bg-warm: #f9f7f7;
            --bg-card: #ffffff;
            --white: #ffffff;
            --dark: #231f20;
            --dark2: #1a1718;
            --muted: #6b5f62;
            --muted-light: #9a8d90;
            --border: rgba(35,31,32,.08);
            --border-accent: rgba(200,169,110,.25);
            --radius: 12px;
            --radius-sm: 6px;
            --tr: all .35s cubic-bezier(.4,0,.2,1);
            --shadow-sm: 0 2px 8px rgba(35,31,32,.06);
            --shadow: 0 8px 32px rgba(35,31,32,.1);
            --shadow-lg: 0 20px 60px rgba(35,31,32,.14);
            --display: 'Playfair Display', Georgia, serif;
            --body: 'DM Sans', sans-serif;
            --gold-gradient: linear-gradient(135deg, #c8a96e 0%, #e0c48a 50%, #c8a96e 100%);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        html, body {
            overflow-x: hidden;
            max-width: 100%;
        }

        ::-webkit-scrollbar {
            width: 6px
        }

        ::-webkit-scrollbar-track {
            background: #f5f5f5
        }

        ::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 10px
        }

        body {
            background: var(--bg);
            font-family: var(--body);
            color: var(--dark);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ── NAVBAR ── */
        .main-nav {
            background: #ffffff;
            border-bottom: 1px solid rgba(35,31,32,.06);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            width: 100%;
            z-index: 1060;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            background: rgba(255,255,255,.95);
            box-shadow: 0 2px 16px rgba(35,31,32,.06);
        }

        .nav-inner {
            max-width: 1320px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 36px;
            height: 72px;
        }

        .nav-logo img {
            height: 5em;
            width: auto;
            object-fit: contain;
            transition: var(--tr);
        }

            .nav-logo img:hover {
                transform: scale(1.03)
            }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 6px
        }

        .nav-link-item {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            text-decoration: none;
            padding: 8px 18px;
            border-radius: 6px;
            transition: var(--tr);
            position: relative;
            cursor: pointer;
        }

            .nav-link-item::after {
                content: '';
                position: absolute;
                bottom: 2px;
                left: 50%;
                right: 50%;
                height: 2px;
                background: var(--accent);
                border-radius: 2px;
                transition: var(--tr);
            }

            .nav-link-item:hover, .nav-link-item.active {
                color: var(--dark)
            }

                .nav-link-item:hover::after, .nav-link-item.active::after {
                    left: 18px;
                    right: 18px
                }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 14px
        }

        .cart-pill {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--dark);
            border-radius: 50px;
            padding: 9px 20px;
            cursor: pointer;
            transition: var(--tr);
            border: 1px solid transparent;
        }

            .cart-pill:hover {
                background: var(--primary-light);
                border-color: var(--accent)
            }

                .cart-pill:hover .cp-icon, .cart-pill:hover .cp-txt {
                    color: var(--accent-light)
                }

        .cp-icon {
            font-size: 1rem;
            color: var(--bg);
            transition: var(--tr)
        }

        .cp-txt {
            font-size: .72rem;
            font-weight: 700;
            color: var(--bg);
            transition: var(--tr);
            letter-spacing: .06em
        }

        .cp-badge {
            background: var(--accent);
            color: var(--dark);
            font-size: .6rem;
            font-weight: 800;
            padding: 2px 8px;
            border-radius: 20px;
            transition: var(--tr);
        }

        .cart-pill:hover .cp-badge {
            background: var(--accent-light)
        }

        .nav-hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 6px;
        }

            .nav-hamburger span {
                display: block;
                width: 22px;
                height: 2px;
                background: var(--dark);
                border-radius: 2px;
                transition: var(--tr);
            }

        .mobile-menu {
            display: none;
            position: fixed;
            inset: 0;
            background: var(--dark);
            z-index: 9000;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 32px;
        }

            .mobile-menu.open {
                display: flex
            }

            .mobile-menu .m-link {
                font-family: var(--display);
                font-size: 2.2rem;
                font-weight: 700;
                color: var(--bg);
                text-decoration: none;
                transition: var(--tr);
                cursor: pointer;
                letter-spacing: .02em;
            }

                .mobile-menu .m-link:hover {
                    color: var(--accent)
                }

        .mobile-menu-close {
            position: absolute;
            top: 24px;
            right: 24px;
            font-size: 1.4rem;
            cursor: pointer;
            color: var(--bg);
            background: rgba(250,242,244,.08);
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--tr);
            border: 1px solid rgba(250,242,244,.12);
        }

            .mobile-menu-close:hover {
                background: rgba(250,242,244,.18);
                color: var(--accent)
            }

        @@media(max-width:900px) {
            .nav-links {
                display: none
            }

            .nav-hamburger {
                display: flex
            }
        }

        @@media(max-width:576px) {
            .nav-inner {
                padding: 0 16px
            }
        }

        /* ── HERO SLIDER ── */
        /* ── HERO SLIDER — BANNER SHOWCASE ── */
        .hero-section {
            background: var(--bg);
            position: relative;
            overflow: hidden;
            padding: 8px 36px 0;
        }

        .hero-slider {
            position: relative;
            overflow: hidden;
            width: 100%;
            max-width: 1320px;
            margin: 0 auto;
            border-radius: var(--radius);
            box-shadow: 0 4px 24px rgba(35,31,32,.1);
        }

        .hero-slide {
            position: relative;
            height: 400px;
            overflow: hidden;
        }

        .hero-slide-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center center;
            transform-origin: center center;
            transition: none;
        }

        /* ── Subtle zoom animation ── */
        .carousel-item.active .hero-slide-img {
            animation: heroZoom 8s ease-out forwards;
        }

        @@keyframes heroZoom {
            from {
                transform: scale(1.04);
            }

            to {
                transform: scale(1);
            }
        }

        /* ── Soft vignette at bottom only ── */
        .hero-slide::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(0deg, rgba(35,31,32,.35) 0%, transparent 15%);
            z-index: 1;
            pointer-events: none;
        }

        /* ── Gold accent line at bottom ── */
        .hero-slide::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--gold-gradient);
            z-index: 5;
            pointer-events: none;
        }

        /* ── Hide text overlay — banners already have their own design ── */
        .hero-overlay {
            display: none;
        }

        .hero-content {
            display: none;
        }

        /* ── Slide counter — elegant corner badge ── */
        .hero-counter {
            position: absolute;
            bottom: 18px;
            right: 24px;
            z-index: 6;
            display: flex;
            align-items: center;
            gap: 5px;
            background: rgba(35,31,32,.5);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            padding: 6px 14px;
            border-radius: 50px;
            border: 1px solid rgba(200,169,110,.2);
        }

        .hero-counter-cur {
            color: var(--accent);
            font-size: .9rem;
            font-weight: 900;
            line-height: 1;
            font-variant-numeric: tabular-nums;
        }

        .hero-counter span:last-child {
            color: rgba(250,242,244,.3);
            font-size: .68rem;
            font-weight: 600;
        }

        /* ── Navigation Arrows ── */
        .hero-slider .carousel-control-prev,
        .hero-slider .carousel-control-next {
            width: 46px;
            height: 46px;
            background: rgba(255,255,255,.75);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 50%;
            top: 50%;
            bottom: auto;
            transform: translateY(-50%);
            margin: 0 16px;
            opacity: 0;
            border: 1px solid rgba(35,31,32,.08);
            transition: var(--tr);
            box-shadow: 0 2px 12px rgba(35,31,32,.12);
        }

        .hero-slider:hover .carousel-control-prev,
        .hero-slider:hover .carousel-control-next {
            opacity: 1;
        }

        .hero-slider .carousel-control-prev:hover,
        .hero-slider .carousel-control-next:hover {
            background: var(--accent);
            border-color: var(--accent);
            transform: translateY(-50%) scale(1.06);
        }

        .hero-slider .carousel-control-prev-icon,
        .hero-slider .carousel-control-next-icon {
            width: 14px;
            height: 14px;
            filter: brightness(0);
            opacity: .7;
        }

        .hero-slider .carousel-control-prev:hover .carousel-control-prev-icon,
        .hero-slider .carousel-control-next:hover .carousel-control-next-icon {
            filter: brightness(0);
            opacity: 1;
        }

        /* ── Indicators — centered dots ── */
        .hero-slider .carousel-indicators {
            margin-bottom: 0;
            bottom: 14px;
            left: 50%;
            transform: translateX(-50%);
            justify-content: center;
            gap: 6px;
            padding: 6px 16px;
            background: rgba(255,255,255,.7);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border-radius: 50px;
            border: 1px solid rgba(35,31,32,.06);
            width: fit-content;
            margin-left: 0;
            margin-right: 0;
            position: absolute;
            box-shadow: 0 2px 10px rgba(35,31,32,.08);
        }

            .hero-slider .carousel-indicators button {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: rgba(35,31,32,.18);
                border: none;
                padding: 0;
                transition: all .4s cubic-bezier(.4,0,.2,1);
                opacity: 1;
            }

            .hero-slider .carousel-indicators .active {
                width: 26px;
                border-radius: 10px;
                background: var(--accent);
                box-shadow: 0 0 8px rgba(200,169,110,.35);
            }

        @@media(max-width:900px) {
            .hero-section {
                padding: 8px 20px 0;
            }

            .hero-slide {
                height: 340px;
            }

            .hero-slider .carousel-control-prev,
            .hero-slider .carousel-control-next {
                width: 40px;
                height: 40px;
                margin: 0 10px;
            }
        }

        @@media(max-width:576px) {
            .hero-section {
                padding: 6px 12px 0;
            }

            .hero-slide {
                height: 200px;
            }

            .hero-slider .carousel-control-prev,
            .hero-slider .carousel-control-next {
                width: 34px;
                height: 34px;
                margin: 0 6px;
                opacity: 1;
            }

            .hero-counter {
                display: none;
            }

            .hero-slider .carousel-indicators {
                bottom: 8px;
                padding: 4px 10px;
                gap: 4px;
            }

                .hero-slider .carousel-indicators button {
                    width: 6px;
                    height: 6px;
                }

                .hero-slider .carousel-indicators .active {
                    width: 20px;
                }
        }

        /* ── FEATURES STRIP ── */
        .features-strip {
            background: var(--bg);
            padding: 16px 36px 0;
            position: relative;
        }

        .features-inner {
            max-width: 1320px;
            margin: auto;
            padding: 18px 28px;
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            background: var(--bg-card);
            border-radius: var(--radius);
            border: 1px solid rgba(35,31,32,.06);
            box-shadow: 0 4px 20px rgba(35,31,32,.08);
        }

        .feat-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 0;
        }

        .feat-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--dark);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            color: var(--accent);
            flex-shrink: 0;
        }

        .feat-title {
            font-size: .76rem;
            font-weight: 700;
            color: var(--dark);
            letter-spacing: .01em
        }

        .feat-sub {
            font-size: .64rem;
            color: var(--muted-light)
        }

        @@media(max-width:576px) {
            .features-strip {
                padding: 10px 12px 0;
            }

            .features-inner {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 8px;
                padding: 14px;
            }

            .feat-item {
                background: var(--bg);
                border: 1px solid rgba(35,31,32,.05);
                border-radius: 10px;
                padding: 10px 12px;
            }

            .feat-icon {
                width: 34px;
                height: 34px;
                font-size: .9rem;
                border-radius: 8px;
            }

            .feat-title {
                font-size: .68rem;
            }

            .feat-sub {
                font-size: .58rem;
            }
        }

        /* ── SHOP SECTION ── */
        .shop-section {
            padding: 0 0 4vh;
            background: var(--bg)
        }

        .shop-wrap {
            max-width: 1320px;
            margin: auto;
            padding: 0 36px
        }

        .shop-bar {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 18px 24px;
            margin-bottom: 32px;
            margin-top: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            border: 1px solid rgba(35,31,32,.06);
            box-shadow: 0 4px 20px rgba(35,31,32,.08);
        }

        .shop-bar-name {
            font-weight: 800;
            color: var(--dark);
            font-size: 1.05rem;
            font-family: var(--display);
            letter-spacing: .01em;
        }

        .shop-bar-addr {
            font-size: .72rem;
            color: var(--muted-light);
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .shop-bar-addr i {
                color: var(--accent);
                font-size: .73rem
            }

        .filter-row {
            display: flex;
            gap: 10px
        }

            .filter-row .form-control, .filter-row .form-select {
                border: 1.5px solid rgba(35,31,32,.08);
                border-radius: 8px;
                font-size: .82rem;
                font-family: var(--body);
                background: var(--bg);
                color: var(--dark);
                transition: var(--tr);
            }

                .filter-row .form-control:focus, .filter-row .form-select:focus {
                    border-color: var(--accent);
                    box-shadow: 0 0 0 3px rgba(200,169,110,.12);
                }

        @@media(max-width:700px) {
            .shop-bar {
                flex-direction: column;
                align-items: flex-start
            }

            .filter-row {
                width: 100%
            }

                .filter-row .form-control, .filter-row .form-select {
                    flex: 1
                }
        }

        .cat-title-row {
            margin: 48px 0 22px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

            .cat-title-row::before, .cat-title-row::after {
                content: '';
                flex: 1;
                height: 1px;
                background: linear-gradient(90deg, transparent, rgba(200,169,110,.2), transparent);
            }

        .cat-title-badge {
            background: var(--dark);
            color: var(--accent);
            padding: 8px 22px;
            border-radius: 50px;
            font-size: .72rem;
            font-weight: 800;
            letter-spacing: .08em;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 8px;
            border: 1px solid rgba(200,169,110,.15);
        }

        /* ── PRODUCT CARD ── */
        .pcard {
            background: var(--bg-card);
            border-radius: var(--radius);
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(35,31,32,.05);
            box-shadow: 0 4px 20px rgba(35,31,32,.08);
            transition: transform .45s cubic-bezier(.34,1.36,.64,1), box-shadow .4s ease, border-color .3s ease;
            cursor: pointer;
            position: relative;
        }

            .pcard::before {
                content: '';
                position: absolute;
                inset: 0;
                border-radius: var(--radius);
                background: linear-gradient(135deg, rgba(200,169,110,.05) 0%, transparent 60%);
                opacity: 0;
                transition: opacity .3s ease;
                pointer-events: none;
                z-index: 0;
            }

            .pcard:hover {
                transform: translateY(-8px) scale(1.01);
                box-shadow: var(--shadow-lg);
                border-color: rgba(200,169,110,.3);
            }

                .pcard:hover::before {
                    opacity: 1
                }

        .pcard-img {
            height: 155px;
            overflow: hidden;
            position: relative;
            background: linear-gradient(135deg, var(--dark) 0%, #2a2526 100%);
            flex-shrink: 0;
        }

            .pcard-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform .6s cubic-bezier(.4,0,.2,1), filter .4s ease;
                display: block;
                filter: brightness(.95) saturate(1.05);
            }

        .pcard:hover .pcard-img img {
            transform: scale(1.08);
            filter: brightness(1.02) saturate(1.1);
        }

        .pcard-img::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 50%;
            background: linear-gradient(to top, rgba(35,31,32,.45) 0%, transparent 100%);
            z-index: 1;
            pointer-events: none;
        }

        .pcard-discount {
            position: absolute;
            top: 10px;
            left: 10px;
            background: #c0392b;
            color: var(--bg);
            font-size: .56rem;
            font-weight: 900;
            padding: 4px 10px;
            border-radius: 3px;
            z-index: 3;
            letter-spacing: .06em;
            text-transform: uppercase;
            box-shadow: 0 3px 10px rgba(192,57,43,.35);
        }

        .pcard-view-overlay {
            position: absolute;
            inset: 0;
            background: rgba(35,31,32,0);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 4;
            transition: background .3s ease;
            pointer-events: none;
        }

        .pcard-view-btn {
            background: var(--accent);
            color: var(--dark);
            font-size: .68rem;
            font-weight: 800;
            letter-spacing: .1em;
            text-transform: uppercase;
            padding: 10px 22px;
            border-radius: 3px;
            display: flex;
            align-items: center;
            gap: 6px;
            opacity: 0;
            transform: translateY(12px) scale(.88);
            transition: all .35s cubic-bezier(.34,1.56,.64,1);
            border: none;
            cursor: pointer;
            pointer-events: none;
            box-shadow: 0 4px 16px rgba(200,169,110,.35);
        }

        .pcard:hover .pcard-view-overlay {
            background: rgba(35,31,32,.5)
        }

        .pcard:hover .pcard-view-btn {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        .pcard-body {
            padding: 16px 16px 14px;
            display: flex;
            flex-direction: column;
            gap: 5px;
            flex-grow: 1;
            position: relative;
            z-index: 1;
        }

        .pcard-name {
            font-size: .86rem;
            font-weight: 800;
            color: var(--dark);
            line-height: 1.3;
            margin: 0;
            letter-spacing: -.01em;
        }

        .pcard-desc {
            font-size: .7rem;
            color: var(--muted-light);
            line-height: 1.55;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .pcard-price {
            margin-top: auto;
            padding-top: 10px;
            display: flex;
            align-items: baseline;
            gap: 8px;
        }

        .pcard-cur {
            font-weight: 900;
            font-size: 1rem;
            color: var(--dark);
            letter-spacing: -.01em;
        }

        .pcard-old {
            font-size: .72rem;
            color: var(--muted-light);
            text-decoration: line-through;
        }

        /* ── QTY STRIP ── */
        .qty-strip {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 10px;
            background: var(--dark);
            border-radius: 8px;
            padding: 5px 6px;
            border: 1.5px solid transparent;
            transition: border-color .3s ease;
            position: relative;
            z-index: 10;
        }

        .pcard:hover .qty-strip {
            border-color: rgba(200,169,110,.25)
        }

        .qty-b {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            font-size: 18px;
            font-weight: 700;
            line-height: 1;
            background-color: rgba(200,169,110,.15);
            color: var(--accent);
            border: none;
            cursor: pointer;
            transition: background .2s, transform .15s;
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
            user-select: none;
            position: relative;
            z-index: 11;
        }

            .qty-b:hover {
                background-color: rgba(200,169,110,.3);
            }

            .qty-b:active {
                transform: scale(.88);
                background-color: rgba(200,169,110,.45);
            }

        .qty-n {
            font-size: .9rem;
            font-weight: 800;
            min-width: 28px;
            text-align: center;
            color: var(--bg);
            font-variant-numeric: tabular-nums;
            user-select: none;
        }

        @@media(max-width:576px) {
            .qty-b {
                width: 36px;
                height: 36px;
                font-size: 20px;
            }

            .qty-strip {
                padding: 6px 8px;
            }
        }

        /* ── Disable hover effects on touch devices ── */
        @@media (hover: none) {
            .pcard:hover {
                transform: none !important;
                box-shadow: var(--shadow-sm) !important;
                border-color: rgba(35,31,32,.05) !important;
            }

                .pcard:hover::before {
                    opacity: 0 !important;
                }

                .pcard:hover .pcard-img img {
                    transform: none !important;
                    filter: brightness(.95) saturate(1.05) !important;
                }

                .pcard:hover .pcard-view-overlay {
                    background: rgba(35,31,32,0) !important;
                }

                .pcard:hover .pcard-view-btn {
                    opacity: 0 !important;
                    transform: translateY(12px) scale(.88) !important;
                }

                .pcard:hover .qty-strip {
                    border-color: transparent !important;
                }
        }

        /* ── PRODUCT MODAL ── */
        #productModal .modal-dialog {
            max-width: 720px
        }

        #productModal .modal-content {
            border-radius: var(--radius);
            border: none;
            overflow: hidden;
            background: transparent;
            box-shadow: 0 32px 80px rgba(35,31,32,.3);
        }

        #productModal .modal-body {
            padding: 0;
