                bottom: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--gold-gradient);
            }

            .pmodal-add-btn:hover {
                background: var(--primary-light);
                color: var(--accent-light);
                transform: translateY(-2px);
            }

        /* ── TESTIMONIALS ── */
        .testimonial-section {
            padding: 40px 0 44px;
            background: var(--bg)
        }

        .test-wrap {
            max-width: 1320px;
            margin: auto;
            padding: 0 36px
        }

        .sec-hd {
            text-align: center;
            margin-bottom: 28px
        }

        .sec-hd-tag {
            display: inline-flex;
            align-items: center;
