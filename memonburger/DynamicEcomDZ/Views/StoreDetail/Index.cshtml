            align-items: center;
            justify-content: center;
            font-size: 1.7rem;
            color: var(--accent);
            margin: 0 auto 20px;
            border: 1px solid rgba(200,169,110,.2);
        }

        .nl-title {
            font-family: var(--display);
            font-size: 2.3rem;
            font-weight: 900;
            color: var(--bg);
            margin-bottom: 10px;
        }

        .nl-sub {
            font-size: .86rem;
            color: rgba(250,242,244,.35);
            margin-bottom: 24px;
        }

        /* ── CART DRAWER ── */
        .cart-drawer {
            position: fixed;
            top: 0;
            right: -420px;
            width: 385px;
            height: 100vh;
            background: var(--bg);
            z-index: 1300;
            display: flex;
            flex-direction: column;
            transition: right .4s cubic-bezier(.4,0,.2,1);
            box-shadow: -12px 0 50px rgba(35,31,32,.16);
            border-left: 1px solid var(--border);
        }

            .cart-drawer.open {
                right: 0
            }

        .cart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 22px;
            flex-shrink: 0;
            background: var(--dark);
            position: relative;
        }

            .cart-header::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--gold-gradient);
            }

            .cart-header h4 {
                font-weight: 800;
                color: var(--bg);
                font-size: 1rem;
                display: flex;
                align-items: center;
                gap: 8px;
                margin: 0;
            }

        .cart-close-btn {
            border: none;
            background: rgba(200,169,110,.1);
            width: 34px;
            height: 34px;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--tr);
            color: var(--accent);
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
        }

            .cart-close-btn:hover {
                background: rgba(200,169,110,.25);
                color: var(--accent-light)
            }

        .cart-items-scroll {
            flex-grow: 1;
            overflow-y: auto;
            padding: 14px 16px 8px;
            background: var(--bg-warm);
        }

            .cart-items-scroll::-webkit-scrollbar {
                width: 4px
            }

            .cart-items-scroll::-webkit-scrollbar-thumb {
                background: rgba(35,31,32,.15);
                border-radius: 10px
            }

        .cart-empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px 20px;
            text-align: center;
        }

        .cart-empty-icon {
            width: 72px;
            height: 72px;
            border-radius: 10px;
            background: var(--dark);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: var(--accent);
            margin-bottom: 14px;
        }

        .cart-empty-text {
            font-size: .84rem;
            font-weight: 700;
            color: var(--muted)
        }

        .cart-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 10px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            margin-bottom: 10px;
            transition: box-shadow .25s, border-color .25s;
        }

            .cart-item:hover {
                box-shadow: 0 4px 16px rgba(35,31,32,.07);
                border-color: rgba(200,169,110,.2);
            }

        .cart-item-img {
            width: 52px;
            height: 52px;
            object-fit: cover;
            border-radius: 8px;
            flex-shrink: 0;
            border: 1px solid var(--border);
        }

        .cart-item-info {
            flex: 1;
            min-width: 0
        }

            .cart-item-info strong {
                font-size: .78rem;
                display: block;
                color: var(--dark);
                font-weight: 700;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

        .cart-item-price-unit {
            font-size: .68rem;
            color: var(--muted-light);
            margin-top: 2px;
        }

        .cart-qty-box {
            display: flex;
            align-items: center;
            gap: 5px;
            background: var(--dark);
            border-radius: 6px;
            padding: 5px 10px;
            flex-shrink: 0;
        }

        .cart-qty-btn {
            width: 30px;
            height: 30px;
            border-radius: 4px;
            border: none;
            background: var(--accent);
            color: var(--dark);
            font-size: .88rem;
            font-weight: 900;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .2s, transform .15s;
            line-height: 1;
            flex-shrink: 0;
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
        }

            .cart-qty-btn:hover {
                background: var(--accent-light);
                transform: scale(1.08)
            }

            .cart-qty-btn.minus {
                background: rgba(250,242,244,.08);
                color: var(--bg)
            }

                .cart-qty-btn.minus:hover {
                    background: #c0392b;
                    color: var(--bg)
                }

        .cart-qty-num {
            font-size: .8rem;
            font-weight: 800;
            min-width: 18px;
            text-align: center;
            color: var(--bg);
        }

        .cart-item-right {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 5px;
            flex-shrink: 0;
        }

        .cart-item-total {
            font-weight: 800;
            font-size: .84rem;
            color: var(--dark);
            white-space: nowrap
        }

        .cart-total {
            padding: 14px 18px;
            border-top: 1px solid var(--border);
            flex-shrink: 0;
            background: var(--bg);
        }

        .cart-total-inner {
            background: var(--dark);
            border-radius: 10px;
            padding: 14px 16px;
            position: relative;
            overflow: hidden;
        }

            .cart-total-inner::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--gold-gradient);
            }

        .total-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 7px;
            font-size: .78rem;
            color: rgba(250,242,244,.35);
        }

            .total-row:last-child {
                margin-bottom: 0
            }

            .total-row .lbl {
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 5px;
            }

                .total-row .lbl i {
                    font-size: .73rem;
                    opacity: .5
                }

            .total-row .val {
                font-weight: 700;
                color: rgba(250,242,244,.6)
            }

            .total-row.discount .val {
                color: #c0392b
            }

            .total-row.net {
                margin-top: 10px;
                padding-top: 10px;
                border-top: 1px dashed rgba(200,169,110,.25);
            }

                .total-row.net .lbl {
                    font-size: .92rem;
                    font-weight: 800;
                    color: var(--bg)
                }

                .total-row.net .val {
                    font-size: 1.1rem;
                    font-weight: 900;
                    color: var(--accent)
                }

        .free-delivery {
            background: var(--accent);
            color: var(--dark);
            padding: 1px 10px;
            border-radius: 4px;
            font-size: .68rem;
            font-weight: 800;
        }

        .delivery-fee {
            color: var(--accent);
            font-weight: 700
        }

        .checkout-wrapper {
            padding: 12px 18px 16px;
            flex-shrink: 0;
            background: var(--bg);
        }

            .checkout-wrapper .btn {
                border-radius: 8px;
                font-weight: 800;
                font-size: .88rem;
                padding: 14px;
                background: var(--dark);
                border: none;
                color: var(--accent);
                transition: var(--tr);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                position: relative;
                overflow: hidden;
                touch-action: manipulation;
                -webkit-tap-highlight-color: transparent;
            }

                .checkout-wrapper .btn::before {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    right: 0;
                    height: 2px;
                    background: var(--gold-gradient);
                }

                .checkout-wrapper .btn:hover {
                    background: var(--primary-light);
                    color: var(--accent-light);
                }

        @@media(max-width:576px) {
            .cart-drawer {
                width: 100%;
                right: -100%
            }
        }

        .cart-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(35,31,32,.6);
            backdrop-filter: blur(6px);
            z-index: 900;
            opacity: 0;
            visibility: hidden;
            transition: .3s ease;
        }

            .cart-backdrop.show {
                opacity: 1;
                visibility: visible
            }

        /* ── MODALS ── */
        .modal-content {
            border-radius: var(--radius);
            border: 1px solid var(--border);
            box-shadow: 0 24px 70px rgba(35,31,32,.22);
        }

        .modal-header {
            background: var(--dark);
            border-radius: var(--radius) var(--radius) 0 0;
            position: relative;
        }

            .modal-header::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--gold-gradient);
            }

            .modal-header .modal-title {
                color: var(--accent);
                font-weight: 800;
                font-family: var(--display);
                font-size: 1.12rem;
            }

            .modal-header .btn-close {
                filter: brightness(0) invert(1)
            }

        .input-group-text {
            background: var(--bg-warm);
            border-color: var(--border);
            color: var(--dark);
        }

        .form-control, .form-select {
            border-color: var(--border);
            border-radius: 8px;
            font-family: var(--body);
            font-size: .84rem;
            transition: var(--tr);
            background: var(--bg-card);
            color: var(--dark);
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(200,169,110,.12);
            }

        #orderSuccessModal .modal-dialog {
            transform: scale(.7);
            transition: transform .35s cubic-bezier(.34,1.56,.64,1);
        }

        #orderSuccessModal.show .modal-dialog {
            transform: scale(1)
        }

        .success-gif {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
        }

        .loading-swal-container, .loading-swal-popup {
            z-index: 99999 !important
        }

        .modal-backdrop {
            z-index: 1040 !important
        }

        .modal {
            z-index: 1050 !important
        }

        /* ── WHATSAPP WIDGET ── */
        .wa-widget {
            position: fixed;
            bottom: 28px;
            right: 28px;
            z-index: 1200;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 14px;
            pointer-events: none;
            width: auto;
            height: auto;
        }

        .wa-popup, .wa-fab-wrap {
            pointer-events: auto;
        }

        .wa-popup {
            width: 325px;
            background: var(--bg-card);
            border-radius: 18px;
            box-shadow: 0 20px 60px rgba(35,31,32,.2), 0 4px 16px rgba(35,31,32,.08);
            overflow: hidden;
            display: none;
            border: 1px solid rgba(35,31,32,.05);
        }

            .wa-popup.open {
                display: block;
            }

        .wa-popup-header {
            background: linear-gradient(135deg,#128c7e 0%,#25d366 100%);
            padding: 18px 16px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .wa-avatar-wrap {
            position: relative;
            flex-shrink: 0
        }

        .wa-popup-avatar {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            background: rgba(255,255,255,.18);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: #fff;
            border: 2px solid rgba(255,255,255,.4);
        }

        .wa-online-dot {
            position: absolute;
            bottom: 1px;
            right: 1px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #a8ffb0;
            border: 2px solid #25d366;
        }

        .wa-popup-info {
            flex: 1
        }

        .wa-popup-name {
            font-size: .92rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.2
        }

        .wa-popup-status {
            font-size: .7rem;
            color: rgba(255,255,255,.82);
            margin-top: 2px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .wa-popup-status span {
                width: 7px;
                height: 7px;
                border-radius: 50%;
                background: #a8ffb0;
                display: inline-block;
                animation: waPulse 2s infinite;
                flex-shrink: 0;
            }

        .wa-popup-close {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255,255,255,.18);
            border: none;
            color: #fff;
            font-size: .78rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background .2s;
            flex-shrink: 0;
        }

            .wa-popup-close:hover {
                background: rgba(255,255,255,.35)
            }

        .wa-popup-body {
            padding: 14px 12px;
            background: #e5ddd5;
            min-height: 90px;
        }

        .wa-bubble {
            background: #fff;
            border-radius: 0 12px 12px 12px;
            padding: 12px 14px 9px;
            font-size: .8rem;
            color: #303030;
            line-height: 1.65;
            max-width: 92%;
            box-shadow: 0 1px 5px rgba(0,0,0,.08);
            position: relative;
        }

            .wa-bubble::before {
                content: '';
                position: absolute;
                top: 0;
                left: -7px;
                border-width: 0 7px 8px 0;
                border-style: solid;
                border-color: transparent #fff transparent transparent;
            }

        .wa-bubble-time {
            font-size: .6rem;
            color: #aaa;
            text-align: right;
            margin-top: 4px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 3px;
        }

            .wa-bubble-time i {
                font-size: .68rem;
                color: #4fc3f7
            }

        .wa-quick-replies {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            padding: 8px 12px 12px;
            background: #e5ddd5;
        }

        .wa-chip {
            background: #fff;
            border: 1.5px solid #25d366;
            color: #128c7e;
            font-size: .7rem;
            font-weight: 700;
            padding: 5px 13px;
            border-radius: 20px;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

            .wa-chip:hover {
                background: #25d366;
                color: #fff;
                border-color: #25d366;
                transform: translateY(-2px);
            }

        .wa-popup-footer {
            padding: 10px 12px 14px;
            background: var(--bg-warm);
            border-top: 1px solid rgba(35,31,32,.05);
        }

        .wa-send-btn {
            width: 100%;
            padding: 12px;
            background: #25d366;
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: .82rem;
            font-weight: 800;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none;
            transition: background .2s, transform .2s;
            box-shadow: 0 4px 14px rgba(37,211,102,.3);
            letter-spacing: .02em;
        }

            .wa-send-btn:hover {
                background: #1ebe5d;
                color: #fff;
                transform: translateY(-2px)
            }

        .wa-fab-wrap {
            position: relative
        }

        .wa-fab {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg,#128c7e,#25d366);
            color: #fff;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            cursor: pointer;
            box-shadow: 0 6px 28px rgba(37,211,102,.45);
            transition: transform .3s cubic-bezier(.34,1.56,.64,1), box-shadow .3s;
            position: relative;
            z-index: 2;
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
        }

            .wa-fab:hover {
                transform: scale(1.1) rotate(-8deg);
                box-shadow: 0 10px 36px rgba(37,211,102,.55);
            }

        .wa-fab-ring {
            position: absolute;
            inset: -5px;
            border-radius: 50%;
            border: 2px solid rgba(37,211,102,.35);
            animation: waRing 2.2s ease-in-out infinite;
        }

        .wa-fab-ring2 {
            position: absolute;
            inset: -10px;
            border-radius: 50%;
            border: 2px solid rgba(37,211,102,.15);
            animation: waRing 2.2s ease-in-out infinite .6s;
        }

        .wa-fab-badge {
            position: absolute;
            top: -3px;
            right: -3px;
            width: 19px;
            height: 19px;
            background: #c0392b;
            color: #fff;
            font-size: .52rem;
            font-weight: 900;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--bg);
            z-index: 3;
            animation: waBadgePop .45s cubic-bezier(.34,1.56,.64,1) .8s both;
        }

        .wa-tooltip {
            position: absolute;
            right: 72px;
            bottom: 16px;
            background: var(--dark);
            color: var(--accent);
            font-size: .72rem;
            font-weight: 700;
            padding: 7px 15px;
            border-radius: 8px;
            white-space: nowrap;
            pointer-events: none;
            opacity: 0;
            transform: translateX(8px);
            transition: all .25s ease;
            box-shadow: 0 4px 16px rgba(35,31,32,.2);
        }

            .wa-tooltip::after {
                content: '';
                position: absolute;
                right: -7px;
                top: 50%;
                transform: translateY(-50%);
                border-width: 5px 0 5px 7px;
                border-style: solid;
                border-color: transparent transparent transparent var(--dark);
            }

        .wa-fab-wrap:hover .wa-tooltip {
            opacity: 1;
            transform: translateX(0)
        }

        @@keyframes waRing {
            0%, 100% {
                transform: scale(1);
                opacity: .6
            }

            50% {
                transform: scale(1.15);
                opacity: 0
            }
        }

        @@keyframes waBadgePop {
            from {
                transform: scale(0)
            }

            to {
                transform: scale(1)
            }
        }

        @@keyframes waPulse {
            0%, 100% {
                opacity: 1
            }

            50% {
                opacity: .4
            }
        }

        /* ── BACK TO TOP ── */
        .back-top {
            position: fixed;
            bottom: 100px;
            right: 28px;
            z-index: 800;
            width: 44px;
            height: 44px;
            border-radius: 8px;
            background: var(--dark);
            color: var(--accent);
            border: 1px solid rgba(200,169,110,.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.05rem;
            cursor: pointer;
            box-shadow: 0 5px 20px rgba(35,31,32,.18);
            opacity: 0;
            visibility: hidden;
            transform: translateY(14px);
            transition: all .3s ease;
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
        }

            .back-top.show {
                opacity: 1;
                visibility: visible;
                transform: translateY(0)
            }

            .back-top:hover {
                background: var(--primary-light);
                color: var(--accent-light)
            }

        /* ── FOOTER ── */
        .site-footer {
            background: var(--dark)
        }

        .footer-top {
            max-width: 1320px;
            margin: auto;
            padding: 64px 44px 50px;
            display: grid;
            grid-template-columns: 1.8fr 1fr 1fr 1fr;
            gap: 48px;
            border-bottom: 1px solid rgba(200,169,110,.08);
        }

        @@media(max-width:1100px) {
            .footer-top {
                grid-template-columns: 1fr 1fr;
                gap: 34px;
                padding: 48px 28px;
            }
        }

        @@media(max-width:600px) {
            .footer-top {
                grid-template-columns: 1fr 1fr;
                padding: 30px 18px;
                gap: 24px;
            }

            .footer-brand {
                grid-column: span 2;
            }

            .footer-contact-item {
                margin-bottom: 10px;
            }

            .footer-bottom {
                flex-direction: column;
                gap: 8px;
                font-size: .68rem;
                padding: 14px 16px;
            }
        }

        .footer-brand p {
            font-size: .8rem;
            color: rgba(250,242,244,.28);
            line-height: 1.9;
            margin: 14px 0 22px;
            max-width: 280px;
        }

        .footer-socials {
            display: flex;
            gap: 8px
        }

        .fsoc {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            background: rgba(200,169,110,.06);
            border: 1px solid rgba(200,169,110,.12);
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(200,169,110,.4);
            font-size: .88rem;
            text-decoration: none;
            transition: var(--tr);
        }

            .fsoc:hover {
                background: rgba(200,169,110,.15);
                border-color: rgba(200,169,110,.35);
                color: var(--accent);
                transform: translateY(-2px);
            }

        .footer-col h5 {
            font-size: .64rem;
            font-weight: 800;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--accent);
            margin-bottom: 18px;
        }

        .footer-col ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

            .footer-col ul li a {
                font-size: .78rem;
                color: rgba(250,242,244,.28);
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 6px;
                transition: color .2s;
            }

                .footer-col ul li a:hover {
                    color: var(--accent)
                }

                .footer-col ul li a i {
                    font-size: .68rem;
                    opacity: .5
                }

        .footer-contact-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 14px;
        }

        .fc-icon {
            width: 34px;
            height: 34px;
            border-radius: 6px;
            flex-shrink: 0;
            background: rgba(200,169,110,.06);
            border: 1px solid rgba(200,169,110,.12);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .8rem;
            color: var(--accent);
            margin-top: 1px;
        }

        .fc-label {
            font-size: .62rem;
            color: rgba(200,169,110,.35);
            margin-bottom: 2px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .1em;
        }

        .fc-val {
            font-size: .78rem;
            color: rgba(250,242,244,.4);
            text-decoration: none;
            transition: var(--tr);
        }

            .fc-val:hover {
                color: var(--accent)
            }

        .footer-bottom {
            text-align: center;
            padding: 18px 24px;
            font-size: .72rem;
            color: rgba(250,242,244,.12);
            background: rgba(0,0,0,.15);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 22px;
            flex-wrap: wrap;
        }

            .footer-bottom a {
                color: rgba(200,169,110,.25);
                text-decoration: none;
                transition: var(--tr);
            }

                .footer-bottom a:hover {
                    color: var(--accent)
                }

        .flying-img {
            position: fixed;
            z-index: 9999;
            pointer-events: none;
            transition: all .75s cubic-bezier(.4,0,.2,1);
            border-radius: 6px;
            box-shadow: 0 8px 24px rgba(35,31,32,.25);
        }
    </style>
</head>

<!-- ══ PRODUCT MODAL ══ -->
<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body p-0" style="position:relative;">
                <button class="pmodal-close-btn" type="button"
                        onclick="bootstrap.Modal.getInstance(document.getElementById('productModal')).hide()">
                    <i class="bi bi-x-lg"></i>
                </button>
                <div class="pmodal-layout">
                    <div class="pmodal-img-wrap">
                        <span class="pmodal-discount-tag" id="pmodal-discount" style="display:none;"></span>
                        <img id="pmodal-img" src="" alt="" />
                    </div>
                    <div class="pmodal-info">
                        <span class="pmodal-cat-tag"><i class="bi bi-tag-fill"></i><span id="pmodal-category"></span></span>
                        <h4 class="pmodal-name" id="pmodal-name"></h4>
                        <p class="pmodal-desc" id="pmodal-desc"></p>
                        <div class="pmodal-price-row">
                            <span class="pmodal-price" id="pmodal-price"></span>
                            <span class="pmodal-old-price" id="pmodal-old-price" style="display:none;"></span>
                        </div>
                        <div class="pmodal-qty-row">
                            <span class="pmodal-qty-label"><i class="bi bi-basket2"></i> Quantity</span>
                            <div class="pmodal-qty-controls">
                                <button class="pmodal-qty-btn minus" type="button" onclick="pmodalQty(-1)">−</button>
                                <span class="pmodal-qty-num" id="pmodal-qty">1</span>
                                <button class="pmodal-qty-btn" type="button" onclick="pmodalQty(1)">+</button>
                            </div>
                        </div>
                        <button class="pmodal-add-btn" type="button" onclick="pmodalAddToCart()">
                            <i class="bi bi-bag-plus-fill me-2"></i>Add to Cart
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══ CLOSED MODAL ══ -->
<div class="modal fade" id="closedModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center">
            <div class="modal-header justify-content-center"><h5 class="modal-title">Store Notice</h5></div>
            <div class="modal-body py-4"></div>
            <div class="modal-footer justify-content-center border-0">
                <button class="btn px-4" style="background:var(--dark);color:var(--accent);font-weight:700;border-radius:8px;" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<!-- ══ CHECKOUT MODAL ══ -->
<div class="modal fade" id="checkoutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-bag-heart-fill me-2"></i>Complete Your Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-6"><label class="form-label fw-bold small">Contact # *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-telephone"></i></span><input type="text" id="ContactNo" class="form-control next-input" maxlength="15" placeholder="03XXXXXXXXX"></div></div>
                    <div class="col-6"><label class="form-label fw-bold small">Name *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-person"></i></span><input type="text" id="CustomerName" class="form-control next-input" placeholder="Your full name"></div></div>
                    <div class="col-6"><label class="form-label fw-bold small">Street *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-signpost"></i></span><input type="text" id="Street" class="form-control next-input" placeholder="Street no."></div></div>
                    <div class="col-6"><label class="form-label fw-bold small">Block / Floor *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-layers"></i></span><input type="text" id="Floor" class="form-control next-input" placeholder="Block / Floor / House"></div></div>
                    <div class="col-12"><label class="form-label fw-bold small">Full Address *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-house"></i></span><input type="text" id="CustomerAddress" class="form-control next-input" placeholder="Complete delivery address"></div></div>
                    <div class="col-12"><label class="form-label fw-bold small">Special Instructions</label><textarea id="Description" class="form-control next-input" rows="2" placeholder="Any special requests or notes..."></textarea></div>
                </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4">
                <button class="btn btn-secondary px-4" style="border-radius:8px;" data-bs-dismiss="modal"><i class="bi bi-x-circle me-1"></i>Cancel</button>
                <button class="btn px-5" style="background:var(--dark);color:var(--accent);font-weight:700;border-radius:8px;border:none;" onclick="placeOrder()"><i class="bi bi-check2-circle me-1"></i>Place Order</button>
            </div>
        </div>
    </div>
</div>

<!-- ══ SUCCESS MODAL ══ -->
<div class="modal fade" id="orderSuccessModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">
            <div class="modal-body">
                <img id="orderStatusGif" src="/Images/GIF/OrderSuccess.gif" class="success-gif mb-3" alt="Order Status" />
                <div id="orderSuccessMessage" class="mt-2 fw-bold"></div>
            </div>
            <div class="modal-footer justify-content-center border-0 pt-0">
                <button type="button" class="btn px-5" style="background:var(--dark);color:var(--accent);font-weight:700;border-radius:8px;border:none;" data-bs-dismiss="modal">OK, Thank You!</button>
            </div>
        </div>
    </div>
</div>

<body>
    <!-- NAVBAR -->
    <nav class="main-nav" id="mainNav">
        <div class="nav-inner">
            <a href="/" class="nav-logo"><img src="/images/@Model.HeaderLogo" alt="@Model.CompanyName" /></a>
            <div class="nav-links">
                <a href="#hero" class="nav-link-item active">Home</a>
                <a href="#shop" class="nav-link-item">Shop</a>
                <a href="/StoreDetail/Abouts" class="nav-link-item">About</a>
            </div>
            <div class="nav-right">
                <div class="cart-pill" id="cartIcon" onclick="toggleCart()">
                    <i class="bi bi-cart3 cp-icon"></i>
                    <span class="cp-txt">Cart</span>
                    <span class="cp-badge" id="cartCount">0</span>
                </div>
                <div class="nav-hamburger" id="hamburger" onclick="openMenu()">
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
    </nav>

    <!-- MOBILE MENU -->
    <div class="mobile-menu" id="mobileMenu">
        <button class="mobile-menu-close" onclick="closeMenu()"><i class="bi bi-x-lg"></i></button>
        <a href="#hero" class="m-link" onclick="closeMenu()">Home</a>
        <a href="#shop" class="m-link" onclick="closeMenu()">Shop</a>
        <a href="/StoreDetail/Abouts" class="m-link" onclick="closeMenu()">About</a>
        <div class="cart-pill" onclick="toggleCart();closeMenu()" style="margin-top:8px">
            <i class="bi bi-cart3 cp-icon"></i>
            <span class="cp-txt">Cart</span>
            <span class="cp-badge" id="cartCountMobile">0</span>
        </div>
    </div>

    <!-- HERO SLIDER -->
    <section id="hero" class="hero-section">
        <div id="heroCarousel" class="hero-slider carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                @for (int i = 0; i < Model.Sliders.Count; i++)
                {
                    <button type="button" data-bs-target="#heroCarousel"
                            data-bs-slide-to="@i"
                            class="@(i == 0 ? "active" : "")"
                            aria-label="Slide @(i + 1)"></button>
                }
            </div>
            <div class="carousel-inner">
                @for (int i = 0; i < Model.Sliders.Count; i++)
                {
                    var s = Model.Sliders[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")" data-bs-interval="@(s.SliderMovingTimer * 1000)">
                        <div class="hero-slide">
                            <img src="@("/images/SliderRegistration/" + s.SliderName)" class="hero-slide-img" alt="@s.HeadingSlider" />
                            <div class="hero-overlay"></div>
                            <div class="hero-content"></div>
                            <div class="hero-counter">
                                <span class="hero-counter-cur">0@(i + 1)</span>
                                <span>/ 0@(Model.Sliders.Count)</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
        </div>
    </section>

    <!-- FEATURES STRIP -->
    <div class="features-strip">
        <div class="features-inner">
            <div class="feat-item"><div class="feat-icon"><i class="bi bi-truck"></i></div><div><div class="feat-title">All Karachi Delivery</div><div class="feat-sub">Home delivery available</div></div></div>
            <div class="feat-item"><div class="feat-icon"><i class="bi bi-fire"></i></div><div><div class="feat-title">Fresh &amp; Hot</div><div class="feat-sub">Made to order always</div></div></div>
            <div class="feat-item"><div class="feat-icon"><i class="bi bi-currency-rupee"></i></div><div><div class="feat-title">Delivery Rs.@Model.DeliveryCharges</div></div></div>
            <div class="feat-item"><div class="feat-icon"><i class="bi bi-clock"></i></div><div><div class="feat-title">@Model.ClosingTimeIn – @Model.ClosingTimeOut</div><div class="feat-sub">Open every day</div></div></div>
            <div class="feat-item" style="grid-column: span 2;"><div class="feat-icon"><i class="bi bi-whatsapp"></i></div><div><div class="feat-title">WhatsApp Order</div><div class="feat-sub">@Model.WhatsappNo</div></div></div>
