            gap: 5px;
            background: var(--dark);
            color: var(--accent);
            font-size: .62rem;
            font-weight: 800;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 5px 12px;
            border-radius: 3px;
