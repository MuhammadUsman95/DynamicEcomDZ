            }

            .pmodal-qty-btn.minus {
                background: rgba(250,242,244,.1);
                color: var(--bg);
            }

                .pmodal-qty-btn.minus:hover {
                    background: #c0392b;
                    color: var(--bg)
                }

        .pmodal-qty-num {
            font-size: 1.05rem;
            font-weight: 900;
            min-width: 22px;
            text-align: center;
            color: var(--bg);
        }

        .pmodal-add-btn {
            width: 100%;
            padding: 14px;
            border-radius: 8px;
            border: none;
            background: var(--dark);
            color: var(--accent);
            font-weight: 800;
            font-size: .88rem;
