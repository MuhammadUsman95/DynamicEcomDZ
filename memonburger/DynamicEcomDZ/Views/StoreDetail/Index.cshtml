            @foreach (var category in Model.Products)
            {
                <div class="cat-title-row">
                    <span class="cat-title-badge"><i class="bi bi-grid-fill"></i>@category.Key</span>
                </div>
                <div class="row g-3">
                    @foreach (var product in category.Value)
                    {
                        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 col-6 product-card-item"
                             data-product-name="@product.ProductName.ToLower()">
                            <div class="pcard">
                                <div class="pcard-img" onclick="openProductModal('@product.ProductCode')" style="cursor:pointer;">
                                    @if (product.DiscountAmount > 0)
                                    {
                                        <span class="pcard-discount">−@product.DiscountAmount</span>
                                    }
                                    <img src="@("/images/ProductRegistration/" + product.ProductImage)"
                                         alt="@product.ProductName"
                                         id="img-@product.ProductCode" />
                                    <div class="pcard-view-overlay">
                                        <span class="pcard-view-btn"><i class="bi bi-eye-fill"></i> View</span>
                                    </div>
                                </div>
                                <div class="pcard-body">
                                    <h6 class="pcard-name">@product.ProductName</h6>
                                    <span class="pcard-desc">@product.ProductDescription</span>
                                    <div class="pcard-price">
                                        <span class="pcard-cur">Rs. @(product.Prices - product.DiscountAmount)</span>
                                        @if (product.DiscountAmount > 0)
                                        {
                                            <span class="pcard-old">@product.Prices</span>
                                        }
                                    </div>
                                    <div class="qty-strip">
                                        <button class="qty-b" type="button"
                                                onclick="event.stopPropagation();changeQuantity('@product.ProductCode','@product.ProductName',-1)">
                                            −
                                        </button>
                                        <span class="qty-n" id="qty-@product.ProductCode">0</span>
                                        <button class="qty-b" type="button"
                                                onclick="event.stopPropagation();changeQuantity('@product.ProductCode','@product.ProductName',1)">
                                            +
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
