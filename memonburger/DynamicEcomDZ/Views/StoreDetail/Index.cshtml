        <div class="shop-wrap">
            <div class="shop-bar">
                <div>
                    <div class="shop-bar-name">@Model.CompanyName</div>
                    <div class="shop-bar-addr"><i class="bi bi-geo-alt-fill"></i>@Model.Address</div>
                </div>
                <div class="filter-row">
                    <input type="text" id="productSearch" class="form-control form-control-sm" placeholder="Search menu..." style="min-width:170px">
                    <select id="categoryFilter" class="form-select form-select-sm">
                        <option value="all">All Categories</option>
                        @foreach (var category in Model.Products.Keys)
                        {
                            <option value="@category">@category</option>
                        }
