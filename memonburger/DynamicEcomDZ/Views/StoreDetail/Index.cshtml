            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .7rem;
            font-weight: 800;
            color: var(--accent);
            flex-shrink: 0;
        }

        .tcard-name {
            font-size: .76rem;
            font-weight: 700;
            color: var(--dark)
        }

        .tcard-loc {
            font-size: .64rem;
            color: var(--muted-light)
        }

        /* ── NEWSLETTER ── */
        .newsletter-section {
            background: var(--dark);
            padding: 72px 0;
            position: relative;
        }

            .newsletter-section::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--gold-gradient);
            }

        .nl-inner {
            max-width: 660px;
            margin: auto;
            text-align: center;
            padding: 0 28px;
        }

        .nl-icon {
            width: 64px;
            height: 64px;
            border-radius: 10px;
            background: rgba(200,169,110,.1);
