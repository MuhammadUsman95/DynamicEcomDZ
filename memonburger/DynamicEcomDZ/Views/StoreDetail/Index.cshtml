@model DynamicEcomDZ.Models.RestaurantDetailViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    @* <title>@Model.RestaurantName</title> *@
    <title>Memon Burger</title>
    <link rel="icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <style>
        :root {
            --accent: #f5c518;
            --accent-dark: #d4a800;
            --accent-soft: rgba(245,197,24,.1);
            --bg: #f9f9f9;
            --white: #ffffff;
            --dark: #0d0d0d;
            --dark2: #1a1a1a;
            --muted: #666666;
            --border: rgba(0,0,0,.1);
            --footer: #0d0d0d;
            --radius: 14px;
            --tr: all .3s cubic-bezier(.4,0,.2,1);
            --shadow: 0 8px 40px rgba(0,0,0,.12);
            --display: 'Playfair Display', Georgia, serif;
            --body: 'DM Sans', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        ::-webkit-scrollbar {
            width: 5px
        }

        ::-webkit-scrollbar-track {
            background: #f0f0f0
        }

        ::-webkit-scrollbar-thumb {
            background: var(--accent);
            border-radius: 10px
        }

        body {
            background: var(--bg);
            font-family: var(--body);
            color: var(--dark);
            overflow-x: hidden
        }

        /* ── PROMO BAR ── */
        .promo-bar {
            background: var(--dark);
            color: var(--accent);
            font-size: .74rem;
            font-weight: 600;
            letter-spacing: .1em;
            text-align: center;
            padding: 9px 12px;
            position: sticky;
            top: 0;
            z-index: 1070;
        }

            .promo-bar span {
                margin: 0 16px;
                color: #fff
            }

                .promo-bar span i {
                    color: var(--accent);
                    margin-right: 5px
                }

        /* ── NAVBAR ── */
        .main-nav {
            background: #fff;
            border-bottom: 2px solid var(--dark);
            position: sticky;
            top: 36px;
            z-index: 1060;
            box-shadow: 0 4px 20px rgba(0,0,0,.08);
        }

        .nav-inner {
            max-width: 1280px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            height: 70px;
        }

        .nav-logo img {
            height: 48px;
            width: auto;
            object-fit: contain;
            transition: var(--tr)
        }

            .nav-logo img:hover {
                transform: scale(1.04)
            }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 4px
        }

        .nav-link-item {
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--dark);
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 6px;
            transition: var(--tr);
            position: relative;
            cursor: pointer;
        }

            .nav-link-item::after {
                content: '';
                position: absolute;
                bottom: 4px;
                left: 50%;
                right: 50%;
                height: 2px;
                background: var(--accent);
                border-radius: 2px;
                transition: var(--tr);
            }

            .nav-link-item:hover {
                color: var(--dark)
            }

                .nav-link-item:hover::after, .nav-link-item.active::after {
                    left: 16px;
                    right: 16px
                }

            .nav-link-item.active {
                color: var(--dark)
            }

        .nav-shop-btn {
            background: var(--dark);
            color: var(--accent);
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            padding: 10px 22px;
            border-radius: 6px;
            text-decoration: none;
            border: 2px solid var(--dark);
            cursor: pointer;
            transition: var(--tr);
        }

            .nav-shop-btn:hover {
                background: var(--accent);
                color: var(--dark);
                border-color: var(--accent)
            }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 12px
        }

        .cart-pill {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--dark);
            border-radius: 6px;
            padding: 8px 16px;
            cursor: pointer;
            transition: var(--tr);
        }

            .cart-pill:hover {
                background: var(--accent)
            }

                .cart-pill:hover .cp-icon, .cart-pill:hover .cp-txt {
                    color: var(--dark)
                }

        .cp-icon {
            font-size: 1rem;
            color: var(--accent);
            transition: var(--tr)
        }

        .cp-txt {
            font-size: .78rem;
            font-weight: 700;
            color: #fff;
            transition: var(--tr)
        }

        .cp-badge {
            background: var(--accent);
            color: var(--dark);
            font-size: .62rem;
            font-weight: 800;
            padding: 2px 7px;
            border-radius: 20px;
            transition: var(--tr);
        }

        .cart-pill:hover .cp-badge {
            background: var(--dark);
            color: var(--accent)
        }

        .nav-hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 6px
        }

            .nav-hamburger span {
                display: block;
                width: 22px;
                height: 2px;
                background: var(--dark);
                border-radius: 2px;
                transition: var(--tr)
            }

        .mobile-menu {
            display: none;
            position: fixed;
            inset: 0;
            background: var(--dark);
            z-index: 9000;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 28px;
        }

            .mobile-menu.open {
                display: flex
            }

            .mobile-menu .m-link {
                font-family: var(--display);
                font-size: 2rem;
                font-weight: 700;
                color: #fff;
                text-decoration: none;
                transition: var(--tr);
                cursor: pointer;
            }

                .mobile-menu .m-link:hover {
                    color: var(--accent)
                }

        .mobile-menu-close {
            position: absolute;
            top: 24px;
            right: 24px;
            font-size: 1.4rem;
            cursor: pointer;
            color: #fff;
            background: rgba(255,255,255,.1);
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--tr);
            border: none;
        }

            .mobile-menu-close:hover {
                background: var(--accent);
                color: var(--dark)
            }

        @@media(max-width:900px) {
            .nav-links, .nav-shop-btn {
                display: none
            }

            .nav-hamburger {
                display: flex
            }
        }

        @@media(max-width:576px) {
            .nav-inner {
                padding: 0 16px
            }
        }

        /* ── HERO SLIDER ── */
        .hero-slider {
            position: relative;
            overflow: hidden
        }

        .hero-slide {
            position: relative;
            height: 620px;
            overflow: hidden;
            display: flex;
            align-items: flex-end;
        }

        .hero-slide-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(30%);
            transition: transform 8s ease;
        }

        .carousel-item.active .hero-slide-img {
            transform: scale(1.06)
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(105deg,rgba(0,0,0,.88) 0%,rgba(0,0,0,.4) 60%,rgba(0,0,0,.1) 100%);
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            padding: 0 60px 70px;
            max-width: 640px;
        }

        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent);
            color: var(--dark);
            font-size: .68rem;
            font-weight: 800;
            letter-spacing: .18em;
            text-transform: uppercase;
            padding: 5px 18px;
            border-radius: 4px;
            margin-bottom: 20px;
            opacity: 0;
        }

        .carousel-item.active .hero-tag {
            animation: fadeUp .5s ease .2s forwards
        }

        .hero-title {
            font-family: var(--display);
            font-size: 4rem;
            font-weight: 900;
            line-height: 1.05;
            color: #fff;
            margin-bottom: 18px;
            opacity: 0;
        }

        .carousel-item.active .hero-title {
            animation: fadeUp .6s ease .4s forwards
        }

        .hero-sub {
            font-size: .9rem;
            color: rgba(255,255,255,.7);
            line-height: 1.7;
            margin-bottom: 32px;
            opacity: 0;
        }

        .carousel-item.active .hero-sub {
            animation: fadeUp .6s ease .55s forwards
        }

        .hero-btns {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            opacity: 0
        }

        .carousel-item.active .hero-btns {
            animation: fadeUp .6s ease .7s forwards
        }

        .hero-btn-primary {
            background: var(--accent);
            color: var(--dark);
            border: none;
            font-size: .82rem;
            font-weight: 800;
            letter-spacing: .07em;
            text-transform: uppercase;
            padding: 14px 32px;
            border-radius: 4px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: var(--tr);
        }

            .hero-btn-primary:hover {
                background: #fff;
                color: var(--dark);
                transform: translateY(-3px)
            }

        .hero-stats {
            position: absolute;
            right: 48px;
            bottom: 70px;
            z-index: 3;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .hstat {
            background: rgba(255,255,255,.08);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,.15);
            border-radius: 8px;
            padding: 14px 20px;
            text-align: center;
        }

        .hstat-num {
            font-family: var(--display);
            font-size: 1.6rem;
            font-weight: 900;
            color: var(--accent);
            line-height: 1
        }

        .hstat-lbl {
            font-size: .62rem;
            color: rgba(255,255,255,.5);
            letter-spacing: .1em;
            text-transform: uppercase;
            margin-top: 2px
        }

        .hero-slider .carousel-control-prev, .hero-slider .carousel-control-next {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,.1);
            backdrop-filter: blur(10px);
            border-radius: 4px;
            top: 50%;
            bottom: auto;
            transform: translateY(-50%);
            margin: 0 20px;
            opacity: 0;
            border: 1px solid rgba(255,255,255,.2);
            transition: var(--tr);
        }

        .hero-slider:hover .carousel-control-prev, .hero-slider:hover .carousel-control-next {
            opacity: 1
        }

        .hero-slider .carousel-control-prev:hover, .hero-slider .carousel-control-next:hover {
            background: var(--accent);
            border-color: var(--accent)
        }

        .hero-slider .carousel-indicators {
            margin-bottom: 28px;
            gap: 8px
        }

            .hero-slider .carousel-indicators button {
                width: 32px;
                height: 3px;
                border-radius: 0;
                background: rgba(255,255,255,.25);
                border: none;
                padding: 0;
                transition: var(--tr);
            }

            .hero-slider .carousel-indicators .active {
                width: 52px;
                background: var(--accent)
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(28px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        @@media(max-width:900px) {
            .hero-slide {
                height: 480px
            }

            .hero-content {
                padding: 0 32px 56px;
                max-width: 100%
            }

            .hero-title {
                font-size: 2.8rem
            }

            .hero-stats {
                display: none
            }
        }

        @@media(max-width:576px) {
            .hero-slide {
                height: 360px
            }

            .hero-content {
                padding: 0 20px 48px
            }

            .hero-title {
                font-size: 2rem
            }

            .hero-sub {
                display: none
            }
        }

        /* ── FEATURES STRIP ── */
        .features-strip {
            background: var(--dark);
            padding: 22px 0;
            border-bottom: 4px solid var(--accent);
        }

        .features-inner {
            max-width: 1280px;
            margin: auto;
            padding: 0 28px;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 16px;
        }

        .feat-item {
            display: flex;
            align-items: center;
            gap: 12px
        }

        .feat-icon {
            width: 44px;
            height: 44px;
            border-radius: 6px;
            background: rgba(245,197,24,.15);
            border: 1px solid rgba(245,197,24,.25);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--accent);
            flex-shrink: 0;
        }

        .feat-title {
            font-size: .8rem;
            font-weight: 700;
            color: #fff
        }

        .feat-sub {
            font-size: .7rem;
            color: rgba(255,255,255,.4)
        }

        /* ── SECTION HEADER ── */
        .sec-hd {
            text-align: center;
            margin-bottom: 48px
        }

        .sec-hd-tag {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: .68rem;
            font-weight: 800;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: var(--dark);
            margin-bottom: 12px;
        }

            .sec-hd-tag::before, .sec-hd-tag::after {
                content: '';
                display: inline-block;
                width: 30px;
                height: 2px;
                background: var(--accent);
            }

        .sec-title {
            font-family: var(--display);
            font-size: 2.8rem;
            font-weight: 900;
            color: var(--dark);
            line-height: 1.15;
            margin-bottom: 10px;
        }

        .sec-sub {
            font-size: .88rem;
            color: var(--muted);
            max-width: 500px;
            margin: 0 auto;
            line-height: 1.7
        }

        /* ── MENU STATS ── */
        .menu-stats-strip {
            background: var(--accent);
            padding: 36px 0;
            border-top: 3px solid var(--dark);
            border-bottom: 3px solid var(--dark);
        }

        .mst-inner {
            max-width: 1280px;
            margin: auto;
            padding: 0 28px;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 24px;
        }

        .mst-item {
            text-align: center
        }

        .mst-num {
            font-family: var(--display);
            font-size: 2.6rem;
            font-weight: 900;
            color: var(--dark);
            line-height: 1
        }

        .mst-lbl {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: rgba(0,0,0,.55);
            margin-top: 4px
        }

        /* ── DARK CONTENT STRIP ── */
        .dark-strip {
            background: var(--dark);
            padding: 80px 0;
        }

        .dark-strip-inner {
            max-width: 1280px;
            margin: auto;
            padding: 0 40px
        }

        .dark-grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 60px;
            align-items: center;
        }

        @@media(max-width:900px) {
            .dark-grid {
                grid-template-columns: 1fr;
                gap: 36px
            }
        }

        .dark-text .dt-tag {
            font-size: .68rem;
            font-weight: 800;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: var(--accent);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .dark-text .dt-tag::before {
                content: '';
                width: 28px;
                height: 2px;
                background: var(--accent)
            }

        .dark-heading {
            font-family: var(--display);
            font-size: 3rem;
            font-weight: 900;
            color: #fff;
            line-height: 1.1;
            margin-bottom: 18px;
        }

            .dark-heading em {
                color: var(--accent);
                font-style: italic
            }

        .dark-body {
            font-size: .88rem;
            color: rgba(255,255,255,.5);
            line-height: 1.85;
            margin-bottom: 32px
        }

        .menu-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 32px
        }

        .mpill {
            background: rgba(255,255,255,.06);
            border: 1.5px solid rgba(255,255,255,.12);
            color: rgba(255,255,255,.7);
            font-size: .75rem;
            font-weight: 700;
            padding: 7px 16px;
            border-radius: 4px;
            cursor: pointer;
            transition: var(--tr);
        }

            .mpill:hover, .mpill.active {
                background: var(--accent);
                border-color: var(--accent);
                color: var(--dark)
            }

        .dark-cta-btn {
            background: var(--accent);
            color: var(--dark);
            border: none;
            padding: 14px 32px;
            border-radius: 4px;
            font-size: .82rem;
            font-weight: 800;
            letter-spacing: .07em;
            text-transform: uppercase;
            cursor: pointer;
            transition: var(--tr);
            display: inline-flex;
            align-items: center;
            gap: 9px;
        }

            .dark-cta-btn:hover {
                background: #fff;
                transform: translateY(-3px)
            }

        .dark-cards {
            display: flex;
            flex-direction: column;
            gap: 14px
        }

        .dcard {
            background: rgba(255,255,255,.04);
            border: 1.5px solid rgba(255,255,255,.08);
            border-radius: 8px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: var(--tr);
        }

            .dcard:hover {
                background: rgba(245,197,24,.08);
                border-color: rgba(245,197,24,.3)
            }

        .dcard-icon {
            width: 50px;
            height: 50px;
            border-radius: 8px;
            background: rgba(245,197,24,.1);
            border: 1px solid rgba(245,197,24,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: var(--accent);
            flex-shrink: 0;
        }

        .dcard-title {
            font-size: .88rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 3px
        }

        .dcard-sub {
            font-size: .74rem;
            color: rgba(255,255,255,.4)
        }

        /* ── SHOP SECTION ── */
        .shop-section {
            padding: 90px 0;
            background: #fff
        }

        .shop-wrap {
            max-width: 1280px;
            margin: auto;
            padding: 0 28px
        }

        .shop-bar {
            background: var(--dark);
            border-radius: 8px;
            padding: 18px 24px;
            margin-bottom: 36px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            border-bottom: 3px solid var(--accent);
        }

        .shop-bar-name {
            font-weight: 800;
            color: var(--accent);
            font-size: 1rem;
            font-family: var(--display)
        }

        .shop-bar-addr {
            font-size: .74rem;
            color: rgba(255,255,255,.4);
            display: flex;
            align-items: center;
            gap: 4px
        }

            .shop-bar-addr i {
                color: var(--accent);
                font-size: .75rem
            }

        .filter-row {
            display: flex;
            gap: 10px
        }

            .filter-row .form-control, .filter-row .form-select {
                border: 2px solid rgba(0,0,0,.12);
                border-radius: 6px;
                font-size: .84rem;
                font-family: var(--body);
                background: #fff;
                color: var(--dark);
                transition: var(--tr);
            }

                .filter-row .form-control:focus, .filter-row .form-select:focus {
                    border-color: var(--accent);
                    box-shadow: 0 0 0 3px rgba(245,197,24,.18);
                }

        @@media(max-width:700px) {
            .shop-bar {
                flex-direction: column;
                align-items: flex-start
            }

            .filter-row {
                width: 100%
            }

                .filter-row .form-control, .filter-row .form-select {
                    flex: 1
                }
        }

        .cat-title-row {
            margin: 44px 0 22px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .cat-title-row::before, .cat-title-row::after {
                content: '';
                flex: 1;
                height: 1px;
                background: linear-gradient(90deg,transparent,rgba(0,0,0,.15),transparent);
            }

        .cat-title-badge {
            background: var(--dark);
            color: var(--accent);
            padding: 8px 22px;
            border-radius: 4px;
            font-size: .78rem;
            font-weight: 800;
            letter-spacing: .05em;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 7px;
            border-bottom: 2px solid var(--accent);
        }

        /* ── PRODUCT CARD (Improved) ── */
        .product-card-wrap {
            height: 100%
        }

        .pcard {
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
            border: 1.5px solid var(--border);
            box-shadow: 0 2px 16px rgba(0,0,0,.07);
            transition: transform .35s cubic-bezier(.34,1.36,.64,1), box-shadow .3s ease, border-color .3s ease;
            cursor: pointer;
            position: relative;
        }

            .pcard:hover {
                transform: translateY(-8px);
