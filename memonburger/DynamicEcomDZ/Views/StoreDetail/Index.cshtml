                pointer-events: none;
            }

            .tcard:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 28px rgba(35,31,32,.08);
                border-color: rgba(200,169,110,.2);
            }

        .tcard-stars {
            display: flex;
            gap: 2px;
            margin-bottom: 12px
        }

            .tcard-stars i {
                font-size: .72rem;
