            gap: 14px
        }

        .pmodal-qty-btn {
            width: 38px;
            height: 38px;
            border-radius: 6px;
            border: none;
            background: var(--accent);
            color: var(--dark);
            font-size: 1rem;
            font-weight: 900;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .2s, transform .15s;
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
        }

            .pmodal-qty-btn:hover {
                background: var(--accent-light);
