            padding: 16px 16px 14px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .wa-avatar-wrap {
            position: relative;
            flex-shrink: 0
        }

        .wa-popup-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: rgba(255,252,252,.22);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: #fffcfc;
            border: 2px solid rgba(255,252,252,.45);
        }

        .wa-online-dot {
            position: absolute;
            bottom: 1px;
            right: 1px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #a8ffb0;
            border: 2px solid #25d366
        }

        .wa-popup-info {
            flex: 1
        }

        .wa-popup-name {
            font-size: .92rem;
            font-weight: 800;
            color: #fffcfc;
            line-height: 1.2
        }

        .wa-popup-status {
            font-size: .7rem;
            color: rgba(255,252,252,.82);
            margin-top: 2px;
            display: flex;
            align-items: center;
            gap: 5px
        }

            .wa-popup-status span {
                width: 7px;
                height: 7px;
                border-radius: 50%;
                background: #a8ffb0;
                display: inline-block;
                animation: waPulse 2s infinite;
                flex-shrink: 0
            }

        .wa-popup-close {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255,252,252,.18);
            border: none;
            color: #fffcfc;
            font-size: .78rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background .2s;
            flex-shrink: 0
        }

            .wa-popup-close:hover {
                background: rgba(255,252,252,.35)
            }

        .wa-popup-body {
            padding: 14px 12px;
            background: #e5ddd5;
            min-height: 90px
        }

        .wa-bubble {
            background: #fffcfc;
            border-radius: 0 12px 12px 12px;
            padding: 11px 13px 8px;
            font-size: .8rem;
            color: #303030;
            line-height: 1.6;
            max-width: 92%;
            box-shadow: 0 1px 5px rgba(13,13,13,.1);
            position: relative;
        }

            .wa-bubble::before {
                content: '';
                position: absolute;
                top: 0;
                left: -7px;
                border-width: 0 7px 8px 0;
                border-style: solid;
                border-color: transparent #fffcfc transparent transparent
            }

        .wa-bubble-time {
            font-size: .6rem;
            color: #aaa;
            text-align: right;
            margin-top: 4px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 3px
        }

            .wa-bubble-time i {
                font-size: .68rem;
                color: #4fc3f7
            }

        .wa-quick-replies {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            padding: 8px 12px 12px;
            background: #e5ddd5
        }

        .wa-chip {
            background: #fffcfc;
            border: 1.5px solid #25d366;
            color: #128c7e;
            font-size: .7rem;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 18px;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

            .wa-chip:hover {
                background: #25d366;
                color: #fffcfc;
                border-color: #25d366;
                transform: translateY(-2px)
            }

        .wa-popup-footer {
            padding: 10px 12px 13px;
            background: #f0eded;
            border-top: 1px solid rgba(13,13,13,.07)
        }

        .wa-send-btn {
            width: 100%;
            padding: 11px;
            background: #25d366;
            color: #fffcfc;
            border: none;
            border-radius: 8px;
            font-size: .82rem;
            font-weight: 800;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none;
            transition: background .2s,transform .2s;
            box-shadow: 0 4px 12px rgba(37,211,102,.32);
            letter-spacing: .02em;
        }

            .wa-send-btn:hover {
                background: #1ebe5d;
                color: #fffcfc;
                transform: translateY(-2px)
            }

        .wa-fab-wrap {
            position: relative
        }

        .wa-fab {
            width: 58px;
            height: 58px;
            border-radius: 50%;
            background: linear-gradient(135deg,#128c7e,#25d366);
            color: #fffcfc;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            cursor: pointer;
            box-shadow: 0 6px 26px rgba(37,211,102,.5);
            transition: transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s;
            position: relative;
            z-index: 2;
        }

            .wa-fab:hover {
                transform: scale(1.12) rotate(-8deg);
                box-shadow: 0 10px 34px rgba(37,211,102,.6)
            }

        .wa-fab-ring {
            position: absolute;
            inset: -5px;
            border-radius: 50%;
            border: 2px solid rgba(37,211,102,.38);
            animation: waRing 2.2s ease-in-out infinite
        }

        .wa-fab-ring2 {
            position: absolute;
            inset: -10px;
            border-radius: 50%;
            border: 2px solid rgba(37,211,102,.18);
            animation: waRing 2.2s ease-in-out infinite .6s
        }

        .wa-fab-badge {
            position: absolute;
            top: -3px;
            right: -3px;
            width: 19px;
            height: 19px;
            background: #dc3545;
            color: #fffcfc;
            font-size: .52rem;
            font-weight: 900;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #fffcfc;
            z-index: 3;
            animation: waBadgePop .45s cubic-bezier(.34,1.56,.64,1) .8s both;
        }

        .wa-tooltip {
            position: absolute;
            right: 70px;
            bottom: 14px;
            background: var(--dark);
            color: #fffcfc;
            font-size: .73rem;
            font-weight: 700;
            padding: 6px 13px;
            border-radius: 7px;
            white-space: nowrap;
            pointer-events: none;
            opacity: 0;
            transform: translateX(8px);
            transition: all .25s ease;
            border-bottom: 2px solid var(--accent);
            box-shadow: 0 4px 14px rgba(13,13,13,.18);
        }

            .wa-tooltip::after {
                content: '';
                position: absolute;
                right: -7px;
                top: 50%;
                transform: translateY(-50%);
                border-width: 5px 0 5px 7px;
                border-style: solid;
                border-color: transparent transparent transparent var(--dark);
            }

        .wa-fab-wrap:hover .wa-tooltip {
            opacity: 1;
            transform: translateX(0)
        }

        @@keyframes waRing {
            0%, 100% {
                transform: scale(1);
                opacity: .6
            }

            50% {
                transform: scale(1.15);
                opacity: 0
            }
        }

        @@keyframes waBadgePop {
            from {
                transform: scale(0)
            }

            to {
                transform: scale(1)
            }
        }

        @@keyframes waPulse {
            0%, 100% {
                opacity: 1
            }

            50% {
                opacity: .4
            }
        }

        /* ── BACK TO TOP ── */
        .back-top {
            position: fixed;
            bottom: 96px;
            right: 26px;
            z-index: 800;
            width: 42px;
            height: 42px;
            border-radius: 6px;
            background: var(--dark);
            color: var(--accent);
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.05rem;
            cursor: pointer;
            box-shadow: 0 5px 18px rgba(13,13,13,.2);
            opacity: 0;
            visibility: hidden;
            transform: translateY(14px);
            transition: all .3s ease;
            border-bottom: 2px solid var(--accent);
        }

            .back-top.show {
                opacity: 1;
                visibility: visible;
                transform: translateY(0)
            }

            .back-top:hover {
                background: var(--accent);
                color: var(--dark)
            }

        /* ── FOOTER ── */
        .site-footer {
            background: var(--dark)
        }

        .footer-top {
            max-width: 1280px;
            margin: auto;
            padding: 60px 40px 46px;
            display: grid;
            grid-template-columns: 1.8fr 1fr 1fr 1fr;
            gap: 44px;
            border-bottom: 1px solid rgba(255,252,252,.06);
        }

        @@media(max-width:1100px) {
            .footer-top {
                grid-template-columns: 1fr 1fr;
                gap: 32px;
                padding: 44px 26px
            }
        }

        @@media(max-width:600px) {
            .footer-top {
                grid-template-columns: 1fr;
                padding: 32px 18px
            }
        }

        .footer-brand p {
            font-size: .8rem;
            color: rgba(255,252,252,.33);
            line-height: 1.85;
            margin: 12px 0 20px;
            max-width: 270px
        }

        .footer-socials {
            display: flex;
            gap: 8px
        }

        .fsoc {
            width: 36px;
            height: 36px;
            border-radius: 6px;
            background: rgba(255,252,252,.05);
            border: 1px solid rgba(255,252,252,.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255,252,252,.38);
            font-size: .88rem;
            text-decoration: none;
            transition: var(--tr);
        }

            .fsoc:hover {
                background: var(--accent);
                border-color: var(--accent);
                color: var(--dark);
                transform: translateY(-2px)
            }

        .footer-col h5 {
            font-size: .66rem;
            font-weight: 800;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: var(--accent);
            margin-bottom: 16px
        }

        .footer-col ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 9px
        }

            .footer-col ul li a {
                font-size: .78rem;
                color: rgba(255,252,252,.33);
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 6px;
                transition: color .2s
            }

                .footer-col ul li a:hover {
                    color: var(--accent)
                }

                .footer-col ul li a i {
                    font-size: .68rem;
                    opacity: .5
                }

        .footer-contact-item {
            display: flex;
            align-items: flex-start;
            gap: 11px;
            margin-bottom: 13px
        }

        .fc-icon {
            width: 32px;
            height: 32px;
            border-radius: 5px;
            flex-shrink: 0;
            background: rgba(245,197,24,.08);
            border: 1px solid rgba(245,197,24,.14);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .8rem;
            color: var(--accent);
            margin-top: 1px
        }

        .fc-label {
            font-size: .64rem;
            color: rgba(255,252,252,.28);
            margin-bottom: 2px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .08em
        }

        .fc-val {
            font-size: .78rem;
            color: rgba(255,252,252,.48);
            text-decoration: none;
            transition: var(--tr)
        }

            .fc-val:hover {
                color: var(--accent)
            }

        .footer-bottom {
            text-align: center;
            padding: 16px 22px;
            font-size: .72rem;
            color: rgba(255,252,252,.16);
            background: rgba(13,13,13,.4);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 22px;
            flex-wrap: wrap;
        }

            .footer-bottom a {
                color: rgba(255,252,252,.22);
                text-decoration: none;
                transition: var(--tr)
            }

                .footer-bottom a:hover {
                    color: var(--accent)
                }

        .flying-img {
            position: fixed;
            z-index: 9999;
            pointer-events: none;
            transition: all .75s cubic-bezier(.4,0,.2,1);
            border-radius: 4px;
            box-shadow: 0 8px 22px rgba(13,13,13,.28)
        }
    </style>
</head>

<!-- ══════════════ PRODUCT MODAL ══════════════ -->
<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body p-0" style="position:relative;">
                <button class="pmodal-close-btn" onclick="bootstrap.Modal.getInstance(document.getElementById('productModal')).hide()"><i class="bi bi-x-lg"></i></button>
                <div class="pmodal-layout">
                    <div class="pmodal-img-wrap">
                        <span class="pmodal-discount-tag" id="pmodal-discount" style="display:none;"></span>
                        <img id="pmodal-img" src="" alt="" />
                    </div>
                    <div class="pmodal-info">
                        <span class="pmodal-cat-tag"><i class="bi bi-tag-fill"></i><span id="pmodal-category"></span></span>
                        <h4 class="pmodal-name" id="pmodal-name"></h4>
                        <p class="pmodal-desc" id="pmodal-desc"></p>
                        <div class="pmodal-price-row">
                            <span class="pmodal-price" id="pmodal-price"></span>
                            <span class="pmodal-old-price" id="pmodal-old-price" style="display:none;"></span>
                        </div>
                        <div class="pmodal-qty-row">
                            <span class="pmodal-qty-label"><i class="bi bi-basket2"></i> Quantity</span>
                            <div class="pmodal-qty-controls">
                                <button class="pmodal-qty-btn minus" onclick="pmodalQty(-1)">−</button>
                                <span class="pmodal-qty-num" id="pmodal-qty">1</span>
                                <button class="pmodal-qty-btn" onclick="pmodalQty(1)">+</button>
                            </div>
                        </div>
                        <button class="pmodal-add-btn" onclick="pmodalAddToCart()"><i class="bi bi-bag-plus-fill me-2"></i>Add to Cart</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ CLOSED MODAL ══════════════ -->
<div class="modal fade" id="closedModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center">
            <div class="modal-header justify-content-center"><h5 class="modal-title">Store Notice</h5></div>
            <div class="modal-body py-4"></div>
            <div class="modal-footer justify-content-center border-0">
                <button class="btn px-4" style="background:var(--dark);color:var(--accent);font-weight:700;border-radius:6px;border-bottom:2px solid var(--accent);" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ CHECKOUT MODAL ══════════════ -->
<div class="modal fade" id="checkoutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-bag-heart-fill me-2"></i>Complete Your Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-6"><label class="form-label fw-bold small">Contact # *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-telephone"></i></span><input type="text" id="ContactNo" class="form-control next-input" maxlength="15" placeholder="03XXXXXXXXX"></div></div>
                    <div class="col-6"><label class="form-label fw-bold small">Name *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-person"></i></span><input type="text" id="CustomerName" class="form-control next-input" placeholder="Your full name"></div></div>
                    <div class="col-6"><label class="form-label fw-bold small">Street *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-signpost"></i></span><input type="text" id="Street" class="form-control next-input" placeholder="Street no."></div></div>
                    <div class="col-6"><label class="form-label fw-bold small">Block / Floor *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-layers"></i></span><input type="text" id="Floor" class="form-control next-input" placeholder="Block / Floor / House"></div></div>
                    <div class="col-12"><label class="form-label fw-bold small">Full Address *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-house"></i></span><input type="text" id="CustomerAddress" class="form-control next-input" placeholder="Complete delivery address"></div></div>
                    <div class="col-12"><label class="form-label fw-bold small">Special Instructions</label><textarea id="Description" class="form-control next-input" rows="2" placeholder="Any special requests or notes..."></textarea></div>
                </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4">
                <button class="btn btn-secondary px-4" style="border-radius:6px;" data-bs-dismiss="modal"><i class="bi bi-x-circle me-1"></i>Cancel</button>
                <button class="btn px-5" style="background:var(--dark);color:var(--accent);font-weight:700;border-radius:6px;border:none;border-bottom:2px solid var(--accent);" onclick="placeOrder()"><i class="bi bi-check2-circle me-1"></i>Place Order</button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ SUCCESS MODAL ══════════════ -->
<div class="modal fade" id="orderSuccessModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">
            <div class="modal-body">
                <img id="orderStatusGif" src="/Images/GIF/OrderSuccess.gif" class="success-gif mb-3" alt="Order Status" />
                <div id="orderSuccessMessage" class="mt-2 fw-bold"></div>
            </div>
            <div class="modal-footer justify-content-center border-0 pt-0">
                <button type="button" class="btn px-5" style="background:var(--dark);color:var(--accent);font-weight:700;border-radius:6px;border:none;border-bottom:2px solid var(--accent);" data-bs-dismiss="modal">OK, Thank You!</button>
            </div>
        </div>
    </div>
</div>

<body>
    <!-- ══════════════ PROMO BAR ══════════════ -->
    @if (!string.IsNullOrEmpty(Model.SubHeaderTitle))
    {
        <div class="promo-bar" id="promoBar">
            <span><i class="bi bi-clock"></i>Order Timing: @Model.ClosingTimeIn – @Model.ClosingTimeOut</span>
            <span><i class="bi bi-whatsapp"></i>@Model.WhatsappNo</span>
        </div>
    }

    <!-- ══════════════ NAVBAR ══════════════ -->
    <nav class="main-nav" id="mainNav">
        <div class="nav-inner">
            <a href="/" class="nav-logo"><img src="/images/@Model.HeaderLogo" alt="@Model.CompanyName" /></a>
            <div class="nav-links">
                <a href="#hero" class="nav-link-item active">Home</a>
                <a href="#shop" class="nav-link-item">Shop</a>
                @* <a href="/About" class="nav-link-item">About</a> *@
                <a asp-controller="StoreDetail" asp-action="Abouts" class="btn-about">
                    <i class="bi bi-info-circle"></i> Abouts
                </a>
            </div>
            <div class="nav-right">
                <div class="cart-pill" id="cartIcon" onclick="toggleCart()">
                    <i class="bi bi-cart3 cp-icon"></i>
                    <span class="cp-txt">Cart</span>
                    <span class="cp-badge" id="cartCount">0</span>
                </div>
                <div class="nav-hamburger" id="hamburger" onclick="openMenu()">
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
    </nav>

    <!-- Mobile menu -->
    <div class="mobile-menu" id="mobileMenu">
        <button class="mobile-menu-close" onclick="closeMenu()"><i class="bi bi-x-lg"></i></button>
        <a href="#hero" class="m-link" onclick="closeMenu()">Home</a>
        <a href="#shop" class="m-link" onclick="closeMenu()">Shop</a>
        <a href="/About" class="m-link" onclick="closeMenu()">About</a>
        <div class="cart-pill" onclick="toggleCart();closeMenu()" style="margin-top:8px">
            <i class="bi bi-cart3 cp-icon"></i>
            <span class="cp-txt">Cart</span>
            <span class="cp-badge" id="cartCountMobile">0</span>
        </div>
    </div>

    <!-- ══════════════ HERO SLIDER ══════════════ -->
    <section id="hero">
        <div id="heroCarousel" class="hero-slider carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                @for (int i = 0; i < Model.Sliders.Count; i++)
                {
                    <button type="button" data-bs-target="#heroCarousel"
                            data-bs-slide-to="@i"
                            class="@(i == 0 ? "active" : "")"
                            aria-label="Slide @(i + 1)"></button>
                }
            </div>
            <div class="carousel-inner">
                @for (int i = 0; i < Model.Sliders.Count; i++)
                {
                    var s = Model.Sliders[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")"
                         data-bs-interval="@(s.SliderMovingTimer * 1000)">
                        <div class="hero-slide">
                            <img src="@("/images/SliderRegistration/" + s.SliderName)"
                                 class="hero-slide-img" alt="@s.HeadingSlider" />
                            <div class="hero-overlay"></div>
                            <div class="hero-content">
                                <div class="hero-tag">
                                    <i class="bi bi-fire"></i>
                                    <span>@s.HeadingSlider</span>
                                </div>
                                <h1 class="hero-title">@s.DescriptionSlider</h1>
                                <div class="hero-divider"></div>
                                <p class="hero-sub">
                                    Fresh burgers &amp; crispy fry items — made to order,
                                    delivered hot across all Karachi.
                                </p>
                                <div class="hero-btns">
                                    <a href="#shop" class="hero-btn-primary">
                                        <i class="bi bi-bag-heart-fill"></i>
                                        <span>Order Now</span>
                                    </a>
                                    <a href="#shop" class="hero-btn-outline">
                                        <i class="bi bi-grid-fill"></i>
                                        <span>View Menu</span>
                                    </a>
                                </div>
                            </div>
                            <div class="hero-stats">
                                <div class="hstat">
                                    <div class="hstat-num">30+</div>
                                    <div class="hstat-lbl">Menu Items</div>
                                </div>
                                <div class="hstat">
                                    <div class="hstat-num">Rs.30</div>
                                    <div class="hstat-lbl">Starting From</div>
                                </div>
                                <div class="hstat">
                                    <div class="hstat-num">11AM</div>
                                    <div class="hstat-lbl">Opens Daily</div>
                                </div>
                            </div>
                            <div class="hero-counter">
                                <span class="hero-counter-cur">0@(i + 1)</span>
                                <span>/ 0@Model.Sliders.Count</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button"
                    data-bs-target="#heroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button"
                    data-bs-target="#heroCarousel" data-bs-slide="next">
