@{
    ViewData["Title"] = "Whatsapp Numbers";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <div class="card shadow">

        <div class="card-header bg-success text-white">
            <h4 class="mb-0">Whatsapp Number Management</h4>
        </div>

        <div class="card-body">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <div class="row">
                <div class="col-md-6">
                    <a asp-controller="Whatsapp"
                       asp-action="DownloadNumberFormat"
                       class="btn btn-primary">
                        📥 Download Excel Format
                    </a>
                </div>

                <div class="col-md-6">
                    <form asp-controller="Whatsapp"
                          asp-action="ImportNumber"
                          method="post"
                          enctype="multipart/form-data">

                        <div class="input-group">
                            <input class="form-control"
                                   type="file"
                                   name="file"
                                   accept=".xlsx,.xls"
                                   required />

                            <button class="btn btn-success" type="submit">
                                ⬆ Import Excel
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <hr />

            <div class="alert alert-info mb-0">
                Excel columns should be:
                <b>DeliveryName</b> and <b>DeliveryPhone</b>
            </div>

        </div>
    </div>
</div>