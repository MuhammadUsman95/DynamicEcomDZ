@model LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Campaign Management - Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <style>
        * {
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a, #2563eb);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 380px;
            background: #fff;
            padding: 35px;
            border-radius: 18px;
            box-shadow: 0 20px 45px rgba(0,0,0,.25);
        }

        .login-title {
            text-align: center;
            margin-bottom: 5px;
            color: #0f172a;
            font-size: 28px;
            font-weight: 800;
        }

        .login-subtitle {
            text-align: center;
            color: #64748b;
            margin-bottom: 28px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        label {
            font-weight: 700;
            color: #334155;
            display: block;
            margin-bottom: 7px;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            height: 46px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            padding: 0 14px;
            font-size: 15px;
            outline: none;
        }

        input:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(37,99,235,.12);
        }

        .remember {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 22px;
            color: #475569;
            font-weight: 600;
        }

            .remember label {
                margin: 0;
                font-weight: 600;
            }

        .login-btn {
            width: 100%;
            height: 46px;
            border: none;
            border-radius: 10px;
            background: #2563eb;
            color: white;
            font-size: 16px;
            font-weight: 800;
            cursor: pointer;
        }

            .login-btn:hover {
                background: #1d4ed8;
            }

        .error {
            background: #fee2e2;
            color: #991b1b;
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 18px;
            text-align: center;
            font-weight: 700;
        }
    </style>
</head>

<body>

    <div class="login-card">
        <h1 class="login-title">Campaign Management</h1>
        <p class="login-subtitle">Login to your account</p>

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

        <form asp-controller="Account" asp-action="Login" method="post">

            <div class="form-group">
                <label>User ID</label>
                <input asp-for="UserId" type="text" placeholder="Enter User ID" autocomplete="username" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input asp-for="Password" type="password" placeholder="Enter Password" autocomplete="current-password" />
            </div>

            <div class="remember">
                <input asp-for="RememberMe" type="checkbox" />
                <label>Remember me</label>
            </div>

            <button type="submit" class="login-btn">Login</button>

        </form>
    </div>

</body>
</html>