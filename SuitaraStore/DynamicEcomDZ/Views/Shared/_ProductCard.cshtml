@* ═══════════════════════════════════════════════════════════════════════════
   _ProductCard.cshtml — Premium Dedo Luxury Product Card Partial
   Usage: @await Html.PartialAsync("_ProductCard", product)
   Place in: Views/Shared/_ProductCard.cshtml
   Theme: Dedo Gold (Luxury Minimalist)
   ═══════════════════════════════════════════════════════════════════════════ *@

@model DynamicEcomDZ.Models.DetailModel

<style>
    /* Dedo Product Card Theme */
    .product-card-wrap {
        height: 100%;
    }

    .pcard {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
        border: 1px solid #e8e4df;
        box-shadow: 0 2px 12px rgba(26,26,26,0.05);
        transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease, border-color 0.35s ease;
        cursor: pointer;
    }

        .pcard:hover {
            transform: translateY(-8px);
            box-shadow: 0 16px 40px rgba(201,169,97,0.15);
            border-color: #c9a961;
        }

    /* Image Section */
    .pcard-img {
        height: 220px;
        overflow: hidden;
        position: relative;
        background: #f5f1ed;
    }

        .pcard-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
        }

    .pcard:hover .pcard-img img {
        transform: scale(1.08);
    }

    /* Discount Badge */
    .pcard-discount {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #c9a961;
        color: #1a1a1a;
        font-size: 0.65rem;
        font-weight: 800;
        padding: 5px 12px;
        border-radius: 6px;
        z-index: 2;
        box-shadow: 0 4px 12px rgba(201,169,97,0.3);
        letter-spacing: 0.5px;
    }

    /* Zoom Icon */
    .pcard-zoom {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 3;
        pointer-events: none;
        transition: background 0.3s;
    }

        .pcard-zoom i {
            font-size: 2rem;
            color: rgba(255, 255, 255, 0);
            transition: color 0.3s;
            font-weight: 600;
        }

    .pcard:hover .pcard-zoom {
        background: rgba(201, 169, 97, 0.2);
    }

        .pcard:hover .pcard-zoom i {
            color: rgba(255, 255, 255, 0.9);
        }

    /* Wishlist Button */
    .pcard-wishlist {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: rgba(201, 169, 97, 0.6);
        z-index: 4;
        transition: all 0.3s ease;
        cursor: pointer;
        pointer-events: auto;
        border: 1px solid rgba(201, 169, 97, 0.2);
    }

        .pcard-wishlist:hover {
            background: #c9a961;
            color: white;
            border-color: #c9a961;
            transform: scale(1.1);
        }

    /* Card Body */
    .pcard-body {
        padding: 16px 14px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex-grow: 1;
    }

    /* Product Name */
    .pcard-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: #1a1a1a;
        line-height: 1.3;
        margin: 0;
        font-family: 'Playfair Display', serif;
        letter-spacing: 0.3px;
    }

    /* Product Description */
    .pcard-desc {
        font-size: 0.78rem;
        color: #666666;
        line-height: 1.4;
        margin-bottom: 2px;
    }

    /* Price Section */
    .pcard-price {
        margin-top: auto;
        padding-top: 10px;
        display: flex;
        align-items: baseline;
        gap: 8px;
        border-top: 1px solid #e8e4df;
    }

    .pcard-cur {
        font-weight: 800;
        font-size: 1.1rem;
        color: #c9a961;
        font-family: 'Playfair Display', serif;
    }

    .pcard-old {
        font-size: 0.8rem;
        color: #999;
        text-decoration: line-through;
        opacity: 0.8;
    }

    /* Color Swatches */
    .pcard-colors {
        display: flex;
        gap: 8px;
        margin-top: 8px;
        flex-wrap: wrap;
    }

    .color-dot {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 2px solid transparent;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
    }

        .color-dot:hover {
            border-color: #1a1a1a;
            transform: scale(1.15);
        }

    /* Quantity Strip */
    .qty-strip {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 10px;
        background: #f5f1ed;
        border-radius: 8px;
        padding: 8px 10px;
    }

    .qty-b {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        border: 1px solid #e8e4df;
        background: white;
        color: #1a1a1a;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        line-height: 1;
    }

        .qty-b:hover {
            background: #c9a961;
            color: white;
            border-color: #c9a961;
            transform: scale(1.08);
        }

        .qty-b:active {
            transform: scale(0.95);
        }

    .qty-n {
        font-size: 1rem;
        font-weight: 800;
        min-width: 24px;
        text-align: center;
        color: #1a1a1a;
    }

    /* Responsive */
    @@media (max-width: 576px) {
        .pcard-img

    {
        height: 180px;
    }

    .pcard-name {
        font-size: 0.9rem;
    }

    }
</style>

<div class="product-card-wrap">
    <div class="pcard" onclick="openProductModal('@Model.ProductCode')">

        <!-- ═══════════════════ IMAGE AREA ═══════════════════ -->
        <div class="pcard-img">

            @* Discount Badge *@
            @if (Model.DiscountAmount > 0)
            {
                <span class="pcard-discount">
                    −Rs.@Model.DiscountAmount
                </span>
            }

            @* Product Image *@
            <img src="@("/images/ProductRegistration/" + Model.ProductImage)"
                 alt="@Model.ProductName"
                 id="img-@Model.ProductCode" />

            @* Zoom Icon *@
            <div class="pcard-zoom">
                <i class="bi bi-zoom-in"></i>
            </div>

            @* Wishlist Button *@
            <button class="pcard-wishlist"
                    onclick="event.stopPropagation();
                    Swal.fire({toast:true, position:'top-end', icon:'success', title:'Added to wishlist!', showConfirmButton:false, timer:1500})">
                <i class="bi bi-heart"></i>
            </button>
        </div>

        <!-- ═══════════════════ CARD BODY ═══════════════════ -->
        <div class="pcard-body">

            @* Product Name *@
            <h6 class="pcard-name">@Model.ProductName</h6>

            @* Product Description *@
            <span class="pcard-desc">@Model.ProductDescription</span>

            @* Color Swatches *@
            <div class="pcard-colors">
                <span class="color-dot" style="background: #1a1a1a;" title="Black"></span>
                <span class="color-dot" style="background: #666666;" title="Grey"></span>
                <span class="color-dot" style="background: #c9a961;" title="Gold"></span>
                <span class="color-dot" style="background: #f5f1ed;" border-color: #e8e4df;" title="Cream"></span>
            </div>

            @* Price Section *@
            <div class="pcard-price">
                <span class="pcard-cur">Rs. @(Model.Prices - Model.DiscountAmount)</span>
                @if (Model.DiscountAmount > 0)
                {
                    <span class="pcard-old">Rs.@Model.Prices</span>
                }
            </div>

            <!-- ═══════════════════ QUANTITY STRIP ═══════════════════ -->
            <div class="qty-strip" onclick="event.stopPropagation()">
                <button class="qty-b"
                        onclick="changeQuantity('@Model.ProductCode','@Model.ProductName',-1)"
                        type="button">
                    −
                </button>
                <span class="qty-n" id="qty-@Model.ProductCode">0</span>
                <button class="qty-b"
                        onclick="changeQuantity('@Model.ProductCode','@Model.ProductName',1)"
                        type="button">
                    +
                </button>
            </div>
        </div>
    </div>
</div>
