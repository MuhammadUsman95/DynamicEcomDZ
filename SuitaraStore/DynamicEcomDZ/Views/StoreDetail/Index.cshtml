    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>

        // ── FIXED TOP HEADER SPACE ──
        function setFixedHeaderSpace() {
            const promoBar = document.getElementById("promoBar");
            const mainNav = document.getElementById("mainNav");

            const promoHeight = promoBar ? promoBar.offsetHeight : 0;
            const navHeight = mainNav ? mainNav.offsetHeight : 0;

            document.documentElement.style.setProperty("--promo-height", promoHeight + "px");
            document.documentElement.style.setProperty("--header-total-height", (promoHeight + navHeight) + "px");
        }

        document.addEventListener("DOMContentLoaded", setFixedHeaderSpace);
        window.addEventListener("resize", setFixedHeaderSpace);
        window.addEventListener("load", setFixedHeaderSpace);

        // ── WHATSAPP CHAT WIDGET ──
        function toggleWhatsAppChat() {
            const widget = document.getElementById("waChatWidget");
            if (widget) widget.classList.toggle("show");
        }


        // ── PROMOTION POPUP ON WEBSITE LOAD ──
        document.addEventListener("DOMContentLoaded", function () {
            const promoModalEl = document.getElementById("promotionModal");

            if (!promoModalEl) return;

            setTimeout(function () {
                const promotionModal = new bootstrap.Modal(promoModalEl, {
                    backdrop: true,
                    keyboard: true
                });

                promotionModal.show();
            }, 800);
        });

        // ── BACK TO TOP ──
        window.addEventListener("scroll",function(){
          const bt = document.getElementById("backTop");
          bt.style.display = window.scrollY > 400 ? "flex" : "none";
        });

        // ── SMOOTH SCROLL ──
        document.querySelectorAll('a[href^="#"]').forEach(a=>{
          a.addEventListener("click",function(e){
            const t = document.querySelector(this.getAttribute("href"));
            if(t){ e.preventDefault(); t.scrollIntoView({behavior:"smooth"}); }
          });
        });

        // ── CATEGORY FILTER ──
        document.addEventListener("DOMContentLoaded", function () {

            function normalizeCategory(value) {
                return (value || "")
                    .toString()
                    .trim()
                    .toLowerCase()
                    .replace(/\s+/g, " ");
            }

            document.querySelectorAll(".category-filter").forEach(btn => {

                btn.addEventListener("click", function () {

                    const category = normalizeCategory(this.dataset.category);

                    document.querySelectorAll(".category-filter")
                        .forEach(x => x.classList.remove("active"));

                    this.classList.add("active");

                    document.querySelectorAll(".category-section")
                        .forEach(section => {

                            const sectionCategory = normalizeCategory(section.dataset.category);

                            if (category === "all" || sectionCategory === category) {
                                section.style.display = "block";
                            }
                            else {
                                section.style.display = "none";
                            }
                        });

                    const shop = document.getElementById("shop");
                    if (shop) {
                        shop.scrollIntoView({ behavior: "smooth", block: "start" });
                    }
                });

            });

        });

        // ── DIRECT ADD TO CART FROM CARD ──
        function addToCartDirect(productCode) {

            const product = getProductByCode(productCode);
            if (!product) return;

            if (cart[productCode]) {
                cart[productCode].Quantity += 1;
            }
            else {
                cart[productCode] = {
                    ProductCode: productCode,
                    ProductName: product.ProductName,
                    Quantity: 1,
                    Rate: product.Prices,
                    DiscountAmount: product.DiscountAmount || 0,
                    DeliveryCharges: product.DeliveryCharges || 0,
                    image: firstProductImage(product.ProductImage)
                };
            }

            renderCart();

            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: 'Added to cart',
                showConfirmButton: false,
                timer: 1500,
                timerProgressBar: true
            });
        }

        // ── PRODUCT DATA ──
        const productMaster = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Products.SelectMany(x => x.Value)));
        function getProductByCode(code){ return productMaster.find(p=>p.ProductCode===code); }
        let cart={};

        // ── PRODUCT IMAGE / DISCOUNT HELPERS ──
        function splitProductImages(productImage) {
          return (productImage || '')
            .toString()
            .split(',')
            .map(x => x.trim())
            .filter(x => x.length > 0);
        }

        function firstProductImage(productImage) {
          const imgs = splitProductImages(productImage);
          return imgs.length ? imgs[0] : '';
        }

        function productImageUrl(imageName) {
          imageName = (imageName || '').toString().trim();
          return imageName ? '/images/ProductRegistration/' + imageName : '/images/no-image.png';
        }

        function calcDiscountPercent(product) {
          const price = Number(product?.Prices || 0);
          const discountAmount = Number(product?.DiscountAmount || 0);
          if (price <= 0 || discountAmount <= 0) return 0;
          return Math.round((discountAmount / price) * 100);
        }

        function netProductPrice(product) {
          return Math.max(0, Number(product?.Prices || 0) - Number(product?.DiscountAmount || 0));
        }

        // Agar ProductImage me comma-separated multiple images hon to card/list par first image show karo
        document.addEventListener('DOMContentLoaded', function () {
          document.querySelectorAll('img').forEach(img => {
            const src = img.getAttribute('src') || '';
            if (src.includes(',') && src.includes('/images/ProductRegistration/')) {
              const prefix = '/images/ProductRegistration/';
              const filePart = src.substring(src.indexOf(prefix) + prefix.length);
              img.setAttribute('src', prefix + firstProductImage(filePart));
            }
          });
        });

        // ── PRODUCT MODAL ──
        let pmodalCode=null;
        function openProductModal(productCode){
          const p=getProductByCode(productCode); if(!p) return;
          pmodalCode=productCode;

          const images = splitProductImages(p.ProductImage);
          const mainImage = firstProductImage(p.ProductImage);
          const mainImgEl = document.getElementById('pmodal-img');
          mainImgEl.src = productImageUrl(mainImage);
          mainImgEl.alt = p.ProductName;

          const thumbsEl = document.getElementById('pmodal-thumbs');
          thumbsEl.innerHTML = '';
          images.forEach((imgName, index) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'pmodal-thumb' + (index === 0 ? ' active' : '');
            btn.innerHTML = `<img src="${productImageUrl(imgName)}" alt="${p.ProductName}">`;
            btn.onclick = function () {
              mainImgEl.src = productImageUrl(imgName);
              document.querySelectorAll('.pmodal-thumb').forEach(x => x.classList.remove('active'));
              btn.classList.add('active');
            };
            thumbsEl.appendChild(btn);
          });
          thumbsEl.style.display = images.length > 1 ? 'flex' : 'none';

          const discEl=document.getElementById('pmodal-discount');
          const discountPercent = calcDiscountPercent(p);
          if(discountPercent>0){discEl.textContent=discountPercent+'% OFF';discEl.style.display='inline-block';}
          else{discEl.style.display='none';}

          document.getElementById('pmodal-category').textContent=p.Category||'';
          document.getElementById('pmodal-name').textContent=p.ProductName;
          document.getElementById('pmodal-desc').textContent=p.ProductDescription||'Premium quality product.';

          const net=netProductPrice(p);
          document.getElementById('pmodal-price').textContent='Rs. '+fmt(net);
          const oldEl=document.getElementById('pmodal-old-price');
          if(Number(p.DiscountAmount||0)>0){oldEl.textContent='Rs. '+fmt(p.Prices);oldEl.style.display='inline';}
          else{oldEl.style.display='none';}
          const cardQty=parseInt(document.getElementById('qty-'+productCode)?.textContent)||0;
          document.getElementById('pmodal-qty').textContent=Math.max(cardQty,1);
          new bootstrap.Modal(document.getElementById('productModal')).show();
        }
        function pmodalQty(d){
          const el=document.getElementById('pmodal-qty');
          el.textContent=Math.max(1,parseInt(el.textContent)+d);
        }
        function pmodalAddToCart(){
          if(!pmodalCode) return;
          const qty=parseInt(document.getElementById('pmodal-qty').textContent)||1;
          const p=getProductByCode(pmodalCode); if(!p) return;
          cart[pmodalCode]={ProductCode:pmodalCode,ProductName:p.ProductName,Quantity:qty,Rate:p.Prices,DiscountAmount:p.DiscountAmount,DeliveryCharges:p.DeliveryCharges,image:firstProductImage(p.ProductImage)};
          renderCart();
          bootstrap.Modal.getInstance(document.getElementById('productModal')).hide();
          Swal.fire({toast:true,position:'top-end',icon:'success',title:'Added to cart!',showConfirmButton:false,timer:1800,timerProgressBar:true,customClass:{popup:'swal2-toast'}});
        }

        // ── CART ──
        function changeQuantity(productCode,productName,delta){
          const qtySpan=document.getElementById('qty-'+productCode);
          let newQty=Math.max(0,(parseInt(qtySpan.textContent)||0)+delta);
          qtySpan.textContent=newQty;
          const product=getProductByCode(productCode); if(!product) return;
          if(newQty===0){delete cart[productCode];}
          else{cart[productCode]={ProductCode:productCode,ProductName:product.ProductName,Quantity:newQty,Rate:product.Prices,DiscountAmount:product.DiscountAmount,DeliveryCharges:product.DeliveryCharges,image:firstProductImage(product.ProductImage)};}
          renderCart();
        }
        function renderCart(){
          const container=document.getElementById("cartItemsContainer");
          const totalDiv=document.getElementById("cartTotal");
          container.innerHTML="";
          const items=Object.values(cart);
          if(items.length===0){
            container.innerHTML=`<div class="cart-empty-state" style="text-align: center; padding: 2rem;"><div class="cart-empty-icon" style="font-size: 3rem; color: var(--dedo-border); margin-bottom: 1rem;"><i class="bi bi-cart-x"></i></div><div style="color: var(--dedo-dark); font-weight: 600; margin-bottom: 0.5rem;">Your cart is empty</div><div style="font-size: .8rem; color: var(--dedo-grey);">Add beautiful items to get started</div></div>`;
            totalDiv.style.display="none"; updateCartCount(); return;
          }
          let tg=0,td=0,tq=0,dc=0;
          items.forEach(item=>{
            if(dc===0&&item.DeliveryCharges!==undefined) dc=Number(item.DeliveryCharges);
            const r=item.Quantity*item.Rate,d=item.Quantity*item.DiscountAmount,net=r-d;
            tg+=r;td+=d;tq+=item.Quantity;
            container.innerHTML+=`
              <div style="display: flex; gap: 1rem; padding: 1rem; border-bottom: 1px solid var(--dedo-border); margin-bottom: 1rem;">
                <img src="${productImageUrl(item.image)}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 6px;"/>
                <div style="flex: 1;">
                  <strong style="color: var(--dedo-dark); display: block; margin-bottom: 0.3rem;">${item.ProductName}</strong>
                  <div style="color: var(--dedo-grey); font-size: 0.85rem; margin-bottom: 0.5rem;">Unit: ${item.DiscountAmount>0 ? `<span style="color: var(--dedo-gold); font-weight: 700;">Rs.${fmt(item.Rate-item.DiscountAmount)}</span>` : `Rs.${fmt(item.Rate)}`}</div>
                  <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <button style="width: 24px; height: 24px; border: 1px solid var(--dedo-border); background: white; color: var(--dedo-dark); border-radius: 3px; cursor: pointer; font-weight: 700;" onclick="changeQuantity('${item.ProductCode}','${item.ProductName}',-1)">−</button>
                    <span style="min-width: 20px; text-align: center;">${item.Quantity}</span>
                    <button style="width: 24px; height: 24px; border: 1px solid var(--dedo-border); background: white; color: var(--dedo-dark); border-radius: 3px; cursor: pointer; font-weight: 700;" onclick="changeQuantity('${item.ProductCode}','${item.ProductName}',1)">+</button>
                  </div>
                </div>
                <div style="text-align: right;"><strong style="color: var(--dedo-dark);">Rs.${fmt(net)}</strong></div>
              </div>`;
          });
          const np=(tg-td)+dc;
          totalDiv.style.display="block";
          totalDiv.innerHTML=`<div style="padding: 1rem; border-top: 2px solid var(--dedo-border);">
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.8rem; padding-bottom: 0.8rem; border-bottom: 1px solid var(--dedo-border);">
              <span style="color: var(--dedo-grey);">Subtotal</span>
              <strong style="color: var(--dedo-dark);">Rs.${fmt(tg)}</strong>
            </div>
            ${td>0?`<div style="display: flex; justify-content: space-between; margin-bottom: 0.8rem; padding-bottom: 0.8rem; border-bottom: 1px solid var(--dedo-border); color: var(--dedo-gold);"><span>Discount</span><strong>−Rs.${fmt(td)}</strong></div>`:''}
            <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--dedo-border);">
              <span style="color: var(--dedo-grey);">Delivery</span>
              <strong style="color: ${dc===0 ? 'var(--dedo-gold)' : 'var(--dedo-dark)'};">${dc===0 ? 'Free' : 'Rs.'+fmt(dc)}</strong>
            </div>
            <div style="display: flex; justify-content: space-between; font-size: 1.1rem;">
              <strong style="color: var(--dedo-dark);">Total</strong>
              <strong style="color: var(--dedo-gold);">Rs.${fmt(np)}</strong>
            </div>
          </div>`;
          updateCartCount();
        }
        function fmt(v){return Number(v).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0});}
        function updateCartCount(){
          let c=0; Object.values(cart).forEach(x=>c+=x.Quantity);
          document.getElementById('cartCount').textContent=c;
          const hBadge=document.getElementById('cartHeaderCount');
          if(c>0){hBadge.textContent=c+' items';hBadge.style.display='inline';}
          else{hBadge.style.display='none';}
        }
                function toggleCart(){
          const drawer = document.getElementById('cartDrawer');
          const backdrop = document.getElementById('cartBackdrop');
          const isOpen = drawer.classList.contains('open');
          if (isOpen) {
            drawer.classList.remove('open');
            backdrop.classList.remove('show');
          } else {
            drawer.classList.add('open');
            backdrop.classList.add('show');
          }
        }

        // ── CHECKOUT ──
        function openCheckoutModal(){
          if(Object.values(cart).length===0){Swal.fire({icon:'warning',title:'Cart Empty',text:'Please add items first.',confirmButtonColor:'var(--dedo-gold)'});return;}
        document.getElementById('cartDrawer').classList.remove('open');
        document.getElementById('cartBackdrop').classList.remove('show');
          fetch('/StoreDetail/CheckRestaurantValidation',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({RestaurantId:@Model.RestaurantId})})
            .then(r=>r.json())
            .then(data=>{
              if(data.statusId===0){document.querySelector('#closedModal .modal-title').innerText='Order Not Allowed';document.querySelector('#closedModal .modal-body').innerHTML=data.message;new bootstrap.Modal(document.getElementById('closedModal')).show();return;}
              new bootstrap.Modal(document.getElementById('checkoutModal')).show();
            })
            .catch(()=>Swal.fire('Error','Server validation failed.','error'));
        }
        function placeOrder(){
          const contactNo=document.getElementById("ContactNo").value.trim();
          const customerName=document.getElementById("CustomerName").value.trim();
          const customerAddress=document.getElementById("CustomerAddress").value.trim();
          const street=document.getElementById("Street").value.trim();
          const floor=document.getElementById("Floor").value.trim();
          const description=document.getElementById("Description").value.trim();
          if(!contactNo||contactNo.length<9){Swal.fire("Validation","Contact No must be at least 9 digits.","error");return;}
          if(!customerName||!customerAddress||!street||!floor){Swal.fire("Validation","All fields are mandatory except Description.","error");return;}
          Swal.fire({title:"Confirm Order",text:"Are you sure you want to place this order?",icon:"question",showCancelButton:true,confirmButtonText:"Yes, Place Order",cancelButtonText:"Cancel",confirmButtonColor:"var(--dedo-gold)",cancelButtonColor:"#6c757d",reverseButtons:true,focusCancel:true})
            .then(result=>{
              if(!result.isConfirmed) return;
              bootstrap.Modal.getInstance(document.getElementById('checkoutModal')).hide();
              setTimeout(()=>{
                Swal.fire({title:"Processing...",html:`<div style="text-align:center"><img src="/Images/GIF/OrderPlaced.gif" style="width:120px;height:120px;border-radius:50%;margin-bottom:12px;"/><div style="font-weight:700;color:#333;">Placing your order...</div></div>`,allowOutsideClick:false,allowEscapeKey:false,showConfirmButton:false,backdrop:'rgba(0,0,0,0.7)'});
                $.ajax({
                  url:"/StoreDetail/PlaceOrder",type:"POST",contentType:"application/json",
                  data:JSON.stringify({ContactNo:contactNo,CustomerName:customerName,CustomerAddress:customerAddress,Street:street,Floor:floor,Description:description,Items:Object.values(cart),RestaurantId:@Model.RestaurantId}),
                  success:function(res){
                    Swal.close();
                    document.getElementById("orderSuccessMessage").innerHTML=res.message;
                    if(res.statusId===0){document.getElementById("orderStatusGif").src="/Images/GIF/OrderFailed.gif";}
                    else{document.getElementById("orderStatusGif").src="/Images/GIF/OrderSuccess.gif";cart={};renderCart();document.querySelectorAll('[id^="qty-"]').forEach(s=>s.textContent=0);clearCheckoutModalFields();}
                    new bootstrap.Modal(document.getElementById('orderSuccessModal')).show();
                  },
                  error:function(){Swal.close();Swal.fire("Error","Something went wrong.","error");}
                });
              },300);
            });
        }
        function clearCheckoutModalFields(cc=true){
          if(cc) document.getElementById("ContactNo").value="";
          ["CustomerName","CustomerAddress","Street","Floor","Description"].forEach(id=>document.getElementById(id).value="");
        }
        document.getElementById("ContactNo").addEventListener("input",function(){this.value=this.value.replace(/\D/g,'');});
        document.getElementById("ContactNo").addEventListener("blur",function(){
          if(!this.value.trim()) return;
          fetch('/StoreDetail/CustomerExsistOrNo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ContactNo:this.value.trim()})})
            .then(r=>r.json())
            .then(data=>{
              if(data.statusId===1){
                document.getElementById("CustomerName").value=data.customerName||"";
                document.getElementById("CustomerAddress").value=data.customerAddress||"";
                document.getElementById("Street").value=data.street||"";
                document.getElementById("Floor").value=data.floor||"";
                document.getElementById("Description").value=data.description||"";
              }else{clearCheckoutModalFields(false);}
            }).catch(err=>console.error(err));
        });
        document.addEventListener("DOMContentLoaded",function(){
          const inputs=document.querySelectorAll(".next-input");
          inputs.forEach((input,index)=>{
            input.addEventListener("keydown",function(e){
              if(e.key==="Enter"){e.preventDefault();const next=inputs[index+1];next?next.focus():placeOrder();}
            });
          });
        });


        // ── WHATSAPP CHAT WIDGET ──
        function toggleWhatsAppChat() {
            const widget = document.getElementById("waChatWidget");
            if (widget) {
                widget.classList.toggle("show");
            }
        }


    </script>

</body>
</html>
