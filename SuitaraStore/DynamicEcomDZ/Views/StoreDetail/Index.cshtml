                    <div class="col-6"><label class="form-label fw-600 small">Street *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-signpost"></i></span><input type="text" id="Street" class="form-control next-input" placeholder="Street no."></div></div>
                    <div class="col-6"><label class="form-label fw-600 small">Block *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-layers"></i></span><input type="text" id="Floor" class="form-control next-input" placeholder="Block / Floor"></div></div>
                    <div class="col-12"><label class="form-label fw-600 small">Address *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-house"></i></span><input type="text" id="CustomerAddress" class="form-control next-input" placeholder="Full address"></div></div>
                    <div class="col-12"><label class="form-label fw-600 small">Description</label><textarea id="Description" class="form-control next-input" rows="2" placeholder="Any special instructions..."></textarea></div>
