    <button class="wa-floating-btn" onclick="toggleWhatsAppChat()" aria-label="WhatsApp Chat">
        <svg xmlns="http://www.w3.org/2000/svg"
             width="30"
             height="30"
             fill="currentColor"
             viewBox="0 0 16 16"
             aria-hidden="true">
            <path d="M13.601 2.326A7.854 7.854 0 0 0 8.012 0C3.607 0 .02 3.587.02 7.992c0 1.406.367 2.779 1.065 3.99L0 16l4.13-1.084a7.94 7.94 0 0 0 3.882 1.007h.003c4.404 0 7.991-3.587 7.991-7.992a7.94 7.94 0 0 0-2.405-5.605zM8.015 14.5h-.002a6.51 6.51 0 0 1-3.318-.908l-.238-.141-2.45.642.654-2.388-.155-.245a6.48 6.48 0 0 1-.996-3.468C1.51 4.414 4.428 1.5 8.015 1.5a6.47 6.47 0 0 1 4.61 1.91 6.48 6.48 0 0 1 1.906 4.607c-.002 3.588-2.916 6.483-6.516 6.483z" />
            <path d="M11.55 9.47c-.194-.097-1.148-.566-1.326-.63-.178-.065-.307-.097-.436.097-.13.194-.501.63-.614.76-.113.129-.226.145-.42.048-.194-.097-.82-.302-1.56-.963-.577-.515-.966-1.15-1.08-1.344-.113-.194-.012-.299.085-.396.087-.086.194-.226.291-.339.097-.113.13-.194.194-.323.065-.129.032-.242-.016-.339-.049-.097-.436-1.05-.598-1.438-.157-.378-.317-.326-.436-.332-.113-.006-.242-.007-.371-.007a.71.71 0 0 0-.517.242c-.178.194-.679.663-.679 1.616s.695 1.874.792 2.003c.097.129 1.368 2.088 3.314 2.928.463.2.824.319 1.105.408.464.147.887.126 1.221.077.373-.056 1.148-.469 1.31-.922.162-.453.162-.841.113-.922-.048-.081-.177-.129-.371-.226z" />
        </svg>
