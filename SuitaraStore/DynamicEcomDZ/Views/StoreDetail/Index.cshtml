        #productModal .modal-body {
            padding: 0;
            position: relative
        }

        .pmodal-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 400px
        }

        @@media(max-width:576px) {
            .pmodal-layout {
                grid-template-columns: 1fr
            }
        }

        .pmodal-img-wrap {
            position: relative;
            overflow: hidden;
            background: var(--pk-soft);
            min-height: 340px
        }

            .pmodal-img-wrap img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
                transition: transform .6s ease
            }

            .pmodal-img-wrap:hover img {
                transform: scale(1.06)
            }

        .pmodal-discount-tag {
            position: absolute;
            top: 14px;
            left: 14px;
            background: linear-gradient(135deg,var(--pk),var(--pk-dark));
            color: #fff;
            font-size: 11px;
            font-weight: 800;
            padding: 4px 12px;
            border-radius: 20px;
            z-index: 2
        }

        .pmodal-close-btn {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: rgba(0,0,0,.55);
            border: 1px solid rgba(255,255,255,.2);
            color: #fff;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--tr);
            z-index: 10
        }

            .pmodal-close-btn:hover {
                background: var(--pk);
                border-color: var(--pk)
            }

        .pmodal-info {
            background: #fff;
            padding: 30px 24px;
            display: flex;
            flex-direction: column;
            gap: 16px
        }

        .pmodal-cat-tag {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--pk-soft);
            color: var(--pk);
            border: 1px solid rgba(214,19,109,.2);
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 4px 12px;
            border-radius: 20px;
            width: fit-content
        }

        .pmodal-name {
            font-family: var(--display);
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--dark);
            line-height: 1.3;
            margin: 0
        }

        .pmodal-desc {
            font-size: .8rem;
            color: var(--muted);
            line-height: 1.75;
            flex-grow: 1
        }

        .pmodal-price-row {
            display: flex;
            align-items: baseline;
            gap: 10px
        }

        .pmodal-price {
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--pk)
        }

        .pmodal-old-price {
            font-size: .88rem;
            color: #dc3545;
            text-decoration: line-through;
            opacity: .75
        }

        .pmodal-qty-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--pk-soft);
            border-radius: 30px;
            padding: 9px 18px;
            border: 1px solid rgba(214,19,109,.18)
        }

        .pmodal-qty-label {
            font-size: .76rem;
            color: var(--muted);
            font-weight: 600
        }

        .pmodal-qty-controls {
            display: flex;
            align-items: center;
            gap: 14px
        }

        .pmodal-qty-btn {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: none;
            background: var(--pk);
            color: #fff;
            font-size: 1rem;
            font-weight: 800;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .2s,transform .15s
        }

            .pmodal-qty-btn:hover {
                background: var(--pk-dark);
                transform: scale(1.1)
            }

            .pmodal-qty-btn:active {
                transform: scale(.9)
            }

            .pmodal-qty-btn.minus {
                background: #f0f0f5;
                color: var(--dark)
            }

                .pmodal-qty-btn.minus:hover {
                    background: #dc3545;
                    color: #fff
                }

        .pmodal-qty-num {
            font-size: 1.1rem;
            font-weight: 900;
            min-width: 22px;
            text-align: center;
            color: var(--dark)
        }

        .pmodal-add-btn {
            width: 100%;
            padding: 14px;
            border-radius: 12px;
            border: none;
            background: linear-gradient(135deg,var(--pk),var(--pk-dark));
            color: #fff;
            font-weight: 800;
            font-size: .92rem;
            cursor: pointer;
            transition: var(--tr);
            letter-spacing: .04em
        }

            .pmodal-add-btn:hover {
                background: var(--dark);
                transform: translateY(-2px);
                box-shadow: 0 10px 28px rgba(214,19,109,.25)
            }

        /* ─────────────── CART DRAWER ─────────────── */
        .cart-drawer {
            position: fixed;
            top: 0;
            right: -420px;
            width: 380px;
            height: 100vh;
            background: #fff;
            z-index: 1300;
            display: flex;
            flex-direction: column;
            transition: right .38s cubic-bezier(.4,0,.2,1);
            box-shadow: -12px 0 48px rgba(214,19,109,.15);
            border-left: 2px solid rgba(214,19,109,.15)
        }

            .cart-drawer.open {
                right: 0
            }

        .cart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            border-bottom: 1.5px solid rgba(214,19,109,.12);
            flex-shrink: 0;
            background: linear-gradient(135deg,var(--pk),var(--pk-dark))
        }

            .cart-header h4 {
                font-weight: 800;
                color: #fff;
                font-size: 1.05rem;
                display: flex;
                align-items: center;
                gap: 8px;
                margin: 0
            }

        .cart-close-btn {
            border: none;
            background: rgba(255,255,255,.18);
            width: 34px;
            height: 34px;
            border-radius: 50%;
            font-size: 17px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--tr);
            color: #fff
        }

            .cart-close-btn:hover {
                background: rgba(255,255,255,.32)
            }

        .cart-items-scroll {
            flex-grow: 1;
            overflow-y: auto;
            padding: 12px 14px 6px;
            background: var(--bg)
        }

            .cart-items-scroll::-webkit-scrollbar {
                width: 4px
            }

            .cart-items-scroll::-webkit-scrollbar-thumb {
                background: rgba(214,19,109,.3);
                border-radius: 10px
            }

        .cart-empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px 20px;
            text-align: center
        }

        .cart-empty-icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: var(--pk-soft);
            border: 1px solid rgba(214,19,109,.18);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: rgba(214,19,109,.4);
            margin-bottom: 14px
        }

        .cart-empty-text {
            font-size: .85rem;
            font-weight: 600;
            color: var(--muted)
        }

        .cart-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            background: #fff;
            border: 1px solid rgba(214,19,109,.08);
            margin-bottom: 8px;
            transition: box-shadow .25s
        }

            .cart-item:hover {
                box-shadow: 0 4px 16px rgba(214,19,109,.1);
                border-color: rgba(214,19,109,.22)
            }

        .cart-item-img {
            width: 52px;
            height: 52px;
            object-fit: cover;
            border-radius: 10px;
            flex-shrink: 0;
            border: 1.5px solid rgba(214,19,109,.15)
        }

        .cart-item-info {
            flex: 1;
            min-width: 0
        }

            .cart-item-info strong {
                font-size: .8rem;
                display: block;
                color: var(--dark);
                font-weight: 700;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis
            }

        .cart-item-price-unit {
            font-size: .7rem;
            color: var(--muted);
            margin-top: 2px
        }

        .cart-qty-box {
            display: flex;
            align-items: center;
            gap: 5px;
            background: var(--pk-soft);
            border-radius: 20px;
            padding: 3px 6px;
            flex-shrink: 0
        }

        .cart-qty-btn {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: none;
            background: var(--pk);
            color: #fff;
            font-size: .9rem;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .2s,transform .15s;
            line-height: 1;
            flex-shrink: 0
        }

            .cart-qty-btn:hover {
                background: var(--pk-dark);
                transform: scale(1.1)
            }

            .cart-qty-btn.minus {
                background: #e9e9f0;
                color: var(--dark)
            }

                .cart-qty-btn.minus:hover {
                    background: #dc3545;
                    color: #fff
                }

        .cart-qty-num {
            font-size: .82rem;
            font-weight: 800;
            min-width: 18px;
            text-align: center;
            color: var(--dark)
        }

        .cart-item-right {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 5px;
            flex-shrink: 0
        }

        .cart-item-total {
            font-weight: 800;
            font-size: .86rem;
            color: var(--pk);
            white-space: nowrap
        }

        .cart-total {
            padding: 14px 16px;
            border-top: 1.5px solid rgba(214,19,109,.12);
            flex-shrink: 0;
            background: #fff
        }

        .cart-total-inner {
            background: var(--bg);
            border-radius: 12px;
            padding: 12px 14px;
            border: 1px solid rgba(214,19,109,.12)
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 7px;
            font-size: .8rem;
            color: var(--muted)
        }

            .total-row:last-child {
                margin-bottom: 0
            }

            .total-row .lbl {
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 5px
            }

                .total-row .lbl i {
                    font-size: .75rem;
                    opacity: .6
                }

            .total-row .val {
                font-weight: 700;
                color: var(--dark)
            }

            .total-row.discount .lbl, .total-row.discount .val {
                color: #dc3545
            }

            .total-row.net {
                margin-top: 10px;
                padding-top: 10px;
                border-top: 1.5px dashed rgba(214,19,109,.22)
            }

                .total-row.net .lbl {
                    font-size: .95rem;
                    font-weight: 800;
                    color: var(--dark)
                }

                .total-row.net .val {
                    font-size: 1.1rem;
                    font-weight: 900;
                    color: var(--pk)
                }

        .free-delivery {
            background: #28a745;
            color: #fff;
            padding: 1px 9px;
            border-radius: 30px;
            font-size: .7rem;
            font-weight: 700
        }

        .delivery-fee {
            color: var(--pk);
            font-weight: 700
        }

        .checkout-wrapper {
            padding: 12px 16px 16px;
            flex-shrink: 0;
            background: #fff
        }

            .checkout-wrapper .btn {
                border-radius: 12px;
                font-weight: 700;
                font-size: .9rem;
                padding: 13px;
                background: linear-gradient(135deg,var(--pk),var(--pk-dark));
                border: none;
                color: #fff;
                box-shadow: 0 6px 20px rgba(214,19,109,.3);
                transition: var(--tr);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px
            }

                .checkout-wrapper .btn:hover {
                    background: var(--dark);
                    color: #fff;
                    transform: translateY(-2px)
                }

        @@media(max-width:576px) {
            .cart-drawer {
                width: 100%;
                right: -100%
            }
        }

        .cart-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(15,15,26,.55);
            backdrop-filter: blur(3px);
            z-index: 900;
            opacity: 0;
            visibility: hidden;
            transition: .3s ease
        }

            .cart-backdrop.show {
                opacity: 1;
                visibility: visible
            }

        /* ─────────────── MODALS ─────────────── */
        .modal-content {
            border-radius: 18px;
            border: none;
            box-shadow: 0 24px 72px rgba(214,19,109,.2)
        }

        .modal-header {
            background: linear-gradient(135deg,var(--pk),var(--pk-dark));
            border-bottom: none;
            border-radius: 18px 18px 0 0
        }

            .modal-header .modal-title {
                color: #fff;
                font-weight: 700;
                font-family: var(--display);
                font-size: 1.15rem
            }

            .modal-header .btn-close {
                filter: brightness(0) invert(1)
            }

        .input-group-text {
            background: var(--pk-soft);
            border-color: rgba(214,19,109,.18);
            color: var(--pk)
        }

        .form-control, .form-select {
            border-color: rgba(214,19,109,.18);
            border-radius: 10px;
            font-family: var(--body);
            font-size: .86rem;
            transition: var(--tr)
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--pk);
                box-shadow: 0 0 0 3px rgba(214,19,109,.12)
            }

        #orderSuccessModal .modal-dialog {
            transform: scale(.7);
            transition: transform .35s cubic-bezier(.34,1.56,.64,1)
        }

        #orderSuccessModal.show .modal-dialog {
            transform: scale(1)
        }

        .success-gif {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            object-fit: cover
        }

        .loading-swal-container, .loading-swal-popup {
            z-index: 99999 !important
        }

        .modal-backdrop {
            z-index: 1040 !important
        }

        .modal {
            z-index: 1050 !important
        }

        /* ─────────────── BACK TO TOP ─────────────── */
        .back-top {
            position: fixed;
            bottom: 28px;
            right: 28px;
            z-index: 800;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: var(--pk);
            color: #fff;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            cursor: pointer;
            box-shadow: 0 6px 20px rgba(214,19,109,.4);
            opacity: 0;
            visibility: hidden;
            transform: translateY(16px);
            transition: all .3s ease;
        }

            .back-top.show {
                opacity: 1;
                visibility: visible;
                transform: translateY(0)
            }

            .back-top:hover {
                background: var(--pk-dark);
                transform: translateY(-3px)
            }
    </style>
</head>

<!-- ══════════════ PRODUCT MODAL ══════════════ -->
<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body p-0" style="position:relative;">
                <button class="pmodal-close-btn" onclick="bootstrap.Modal.getInstance(document.getElementById('productModal')).hide()"><i class="bi bi-x-lg"></i></button>
                <div class="pmodal-layout">
                    <div class="pmodal-img-wrap">
                        <span class="pmodal-discount-tag" id="pmodal-discount" style="display:none;"></span>
                        <img id="pmodal-img" src="" alt="" />
                    </div>
                    <div class="pmodal-info">
                        <span class="pmodal-cat-tag"><i class="bi bi-tag-fill"></i><span id="pmodal-category"></span></span>
                        <h4 class="pmodal-name" id="pmodal-name"></h4>
                        <p class="pmodal-desc" id="pmodal-desc"></p>
                        <div class="pmodal-price-row">
                            <span class="pmodal-price" id="pmodal-price"></span>
                            <span class="pmodal-old-price" id="pmodal-old-price" style="display:none;"></span>
                        </div>
                        <div class="pmodal-qty-row">
                            <span class="pmodal-qty-label"><i class="bi bi-basket2"></i> Quantity</span>
                            <div class="pmodal-qty-controls">
                                <button class="pmodal-qty-btn minus" onclick="pmodalQty(-1)">−</button>
                                <span class="pmodal-qty-num" id="pmodal-qty">1</span>
                                <button class="pmodal-qty-btn" onclick="pmodalQty(1)">+</button>
                            </div>
                        </div>
                        <button class="pmodal-add-btn" onclick="pmodalAddToCart()"><i class="bi bi-bag-plus-fill me-2"></i>Add to Cart</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ CLOSED MODAL ══════════════ -->
<div class="modal fade" id="closedModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center">
            <div class="modal-header justify-content-center"><h5 class="modal-title">Store Notice</h5></div>
            <div class="modal-body py-4"></div>
            <div class="modal-footer justify-content-center border-0">
                <button class="btn px-4" style="background:var(--pk);color:#fff;font-weight:700;border-radius:30px;" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ CHECKOUT MODAL ══════════════ -->
<div class="modal fade" id="checkoutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-bag-heart-fill me-2"></i>Complete Your Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-6"><label class="form-label fw-600 small">Contact # *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-telephone"></i></span><input type="text" id="ContactNo" class="form-control next-input" maxlength="15" placeholder="03XXXXXXXXX"></div></div>
                    <div class="col-6"><label class="form-label fw-600 small">Name *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-person"></i></span><input type="text" id="CustomerName" class="form-control next-input" placeholder="Your full name"></div></div>
                    <div class="col-6"><label class="form-label fw-600 small">Street *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-signpost"></i></span><input type="text" id="Street" class="form-control next-input" placeholder="Street no."></div></div>
                    <div class="col-6"><label class="form-label fw-600 small">Block / Floor *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-layers"></i></span><input type="text" id="Floor" class="form-control next-input" placeholder="Block / Floor / House"></div></div>
                    <div class="col-12"><label class="form-label fw-600 small">Full Address *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-house"></i></span><input type="text" id="CustomerAddress" class="form-control next-input" placeholder="Complete delivery address"></div></div>
                    <div class="col-12"><label class="form-label fw-600 small">Special Instructions</label><textarea id="Description" class="form-control next-input" rows="2" placeholder="Any special requests or notes..."></textarea></div>
                </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4">
                <button class="btn btn-secondary px-4" style="border-radius:30px;" data-bs-dismiss="modal"><i class="bi bi-x-circle me-1"></i>Cancel</button>
                <button class="btn px-5" style="background:linear-gradient(135deg,var(--pk),var(--pk-dark));color:#fff;font-weight:700;border-radius:30px;border:none;" onclick="placeOrder()"><i class="bi bi-check2-circle me-1"></i>Place Order</button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ SUCCESS MODAL ══════════════ -->
<div class="modal fade" id="orderSuccessModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">
            <div class="modal-body">
                <img id="orderStatusGif" src="/Images/GIF/OrderSuccess.gif" class="success-gif mb-3" alt="Order Status" />
                <div id="orderSuccessMessage" class="mt-2 fw-600"></div>
            </div>
            <div class="modal-footer justify-content-center border-0 pt-0">
                <button type="button" class="btn px-5" style="background:linear-gradient(135deg,var(--pk),var(--pk-dark));color:#fff;font-weight:700;border-radius:30px;border:none;" data-bs-dismiss="modal">OK, Thank You!</button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ ABOUT MODAL ══════════════ -->
<div class="modal fade" id="aboutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-info-circle-fill me-2"></i>About @Model.RestaurantName</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <p style="font-size:.9rem;color:var(--muted);line-height:1.85;">We are a premier fashion destination offering exquisite <strong>Pakistani Outfits</strong> and <strong>Luxury Bags</strong> collections. With a passion for elegance and craftsmanship, every piece in our collection is curated to bring you the finest in contemporary and traditional fashion.</p>
                <div class="row g-3 mt-2">
                    <div class="col-md-6"><div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:var(--pk-soft);border:1px solid rgba(214,19,109,.15)"><i class="bi bi-patch-check-fill fs-4" style="color:var(--pk)"></i><div><strong class="d-block" style="font-size:.85rem">Premium Quality</strong><span style="font-size:.75rem;color:var(--muted)">Finest fabrics & craftsmanship</span></div></div></div>
                    <div class="col-md-6"><div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:var(--pk-soft);border:1px solid rgba(214,19,109,.15)"><i class="bi bi-truck fs-4" style="color:var(--pk)"></i><div><strong class="d-block" style="font-size:.85rem">Fast Delivery</strong><span style="font-size:.75rem;color:var(--muted)">Swift & safe to your door</span></div></div></div>
                    <div class="col-md-6"><div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:var(--pk-soft);border:1px solid rgba(214,19,109,.15)"><i class="bi bi-arrow-repeat fs-4" style="color:var(--pk)"></i><div><strong class="d-block" style="font-size:.85rem">Easy Returns</strong><span style="font-size:.75rem;color:var(--muted)">Hassle-free return policy</span></div></div></div>
                    <div class="col-md-6"><div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:var(--pk-soft);border:1px solid rgba(214,19,109,.15)"><i class="bi bi-headset fs-4" style="color:var(--pk)"></i><div><strong class="d-block" style="font-size:.85rem">24/7 Support</strong><span style="font-size:.75rem;color:var(--muted)">Always here to help you</span></div></div></div>
                </div>
                <div class="mt-4 p-3 rounded-3 text-center" style="background:linear-gradient(135deg,var(--pk),var(--pk-dark))">
                    <p class="mb-0" style="color:#fff;font-size:.88rem;font-weight:600;">📍 @Model.RestaurantAddress</p>
                </div>
            </div>
        </div>
    </div>
</div>

<body>
    <!-- ══════════════ PROMO BAR ══════════════ -->
    @if (!string.IsNullOrEmpty(Model.SubHeaderTitle))
    {
        <div class="promo-bar" id="promoBar">
            <span><i class="bi bi-truck"></i>@Html.Raw(Model.SubHeaderTitle)</span>
            <span><i class="bi bi-patch-check"></i>Authentic Products</span>
            <span><i class="bi bi-stars"></i>Premium Collections</span>
        </div>
    }

    <!-- ══════════════ NAVBAR ══════════════ -->
    <nav class="main-nav" id="mainNav">
        <div class="nav-inner">
            <a href="/" class="nav-logo"><img src="/images/logo.png" alt="@Model.RestaurantName" /></a>
            <div class="nav-links">
                <a href="#hero" class="nav-link-item active">Home</a>
                <a href="#shop" class="nav-link-item" onclick="scrollTo('shop')">Shop</a>
                <a href="#about" class="nav-link-item" onclick="scrollTo('about')">About</a>
                <a href="#" class="nav-link-item" data-bs-toggle="modal" data-bs-target="#aboutModal">Contact</a>
            </div>
            <div class="nav-right">
                <a href="#shop" class="nav-shop-btn"><i class="bi bi-bag-heart me-1"></i>Shop Now</a>
                <div class="cart-pill" id="cartIcon" onclick="toggleCart()">
                    <i class="bi bi-cart3 cp-icon"></i>
                    <span class="cp-txt">Cart</span>
                    <span class="cp-badge" id="cartCount">0</span>
