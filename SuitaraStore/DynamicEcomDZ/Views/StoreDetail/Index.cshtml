<body>

    @if (!string.IsNullOrEmpty(Model.SubHeaderTitle))
    {
        <div class="mini-sub-header" id="miniSubHeader">
            <div class="container">
                <div class="sub-header-inner">
                    <i class="bi bi-truck"></i>
                    <span class="small">@Html.Raw(Model.SubHeaderTitle)</span>
                </div>
            </div>
        </div>
    }

    <header class="main-header">
        <div class="header-inner">
            <a href="/" class="header-logo"><img src="/images/logo.png" alt="Logo"></a>
            <div class="cart-icon" id="cartIcon" onclick="toggleCart()">
                <span class="cart-count" id="cartCount">0</span>
                <i class="bi bi-cart3"></i>
            </div>
        </div>
    </header>

    <div id="detailSlider" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-indicators">
            @for (int i = 0; i < Model.Sliders.Count; i++)
            {
                <button type="button" data-bs-target="#detailSlider" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-label="Slide @(i + 1)"></button>
            }
        </div>
        <div class="carousel-inner">
            @for (int i = 0; i < Model.Sliders.Count; i++)
            {
                var s = Model.Sliders[i];
                <div class="carousel-item @(i == 0 ? "active" : "")" data-bs-interval="@(s.SliderMovingTimer * 1000)">
                    <img src="@("/images/SliderRegistration/" + s.SliderName)" alt="Slider @i" />
                    <div class="carousel-caption">
                        <div class="caption-badge"><i class="bi bi-stars"></i> @s.HeadingSlider</div>
                        <h2 class="caption-heading">@s.DescriptionSlider</h2>
                    </div>
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#detailSlider" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
        <button class="carousel-control-next" type="button" data-bs-target="#detailSlider" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
    </div>

    <div class="products-section-wrap">
        <div class="container product-section" id="productsContainer">

            <div class="restaurant-bar">
                <div class="restaurant-identity">
                    <div>
                        <p class="restaurant-address-text"><i class="bi bi-geo-alt-fill"></i> @Model.RestaurantAddress</p>
                    </div>
                </div>
                <div class="filter-wrap">
                    <input type="text" id="productSearch" class="form-control form-control-sm" placeholder="🔍 Search product...">
                    <select id="categoryFilter" class="form-select form-select-sm">
                        <option value="all" selected>All Categories</option>
                        @foreach (var category in Model.Products.Keys)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>
            </div>

            @foreach (var category in Model.Products)
            {
                <div class="product-category-title">
                    <span class="category-badge"><i class="bi bi-grid-fill me-2"></i>@category.Key</span>
                </div>
                <div class="row g-3">
                    @foreach (var product in category.Value)
                    {
                        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 col-6 product-card"
                             data-product-name="@product.ProductName.ToLower()">
                            <div class="product-item" onclick="openProductModal('@product.ProductCode')">
                                <div class="product-img">
                                    @if (product.DiscountAmount > 0)
                                    {
                                        <span class="discount-badge">-@product.DiscountAmount</span>
                                    }
                                    <img src="@("/images/ProductRegistration/" + product.ProductImage)"
                                         alt="@product.ProductName" id="img-@product.ProductCode" />
                                    <div class="zoom-hint"><i class="bi bi-zoom-in"></i></div>
                                </div>
                                <div class="product-info">
                                    <h6 class="product-name">@product.ProductName</h6>
                                    <span class="product-description">@product.ProductDescription</span>
                                    <div class="product-price">
                                        <span class="current-price">@(product.Prices - product.DiscountAmount)</span>
                                        @if (product.DiscountAmount > 0)
                                        {
                                            <span class="old-price">@(product.Prices)</span>
                                        }
                                    </div>
                                    <div class="qty-box" onclick="event.stopPropagation()">
                                        <button class="qty-btn" onclick="changeQuantity('@product.ProductCode','@product.ProductName',-1)">−</button>
                                        <span class="qty-value" id="qty-@product.ProductCode">0</span>
                                        <button class="qty-btn" onclick="changeQuantity('@product.ProductCode','@product.ProductName',1)">+</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- CART DRAWER -->
    <div id="cartDrawer" class="cart-drawer">
        <div class="cart-header">
            <h4>
                <i class="bi bi-bag-heart-fill"></i> Your Cart
                <span id="cartHeaderCount" style="background:rgba(255,255,255,.25);color:#ffffff;font-size:.65rem;font-weight:800;padding:2px 8px;border-radius:20px;margin-left:4px;display:none;"></span>
            </h4>
            <button class="cart-close-btn" onclick="toggleCart()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div id="cartItemsContainer" class="cart-items-scroll">
            <div class="cart-empty-state">
                <div class="cart-empty-icon"><i class="bi bi-cart-x"></i></div>
                <div class="cart-empty-text">Your cart is empty</div>
                <div style="font-size:.76rem;color:var(--muted);margin-top:4px;">Add items to get started</div>
            </div>
        </div>
        <div id="cartTotal" class="cart-total" style="display:none;"></div>
        <div class="checkout-wrapper">
            <button class="btn w-100" onclick="openCheckoutModal()">
                <i class="bi bi-lightning-charge-fill"></i> Checkout
            </button>
        </div>
    </div>
    <div id="cartBackdrop" class="cart-backdrop" onclick="toggleCart()"></div>

    <footer class="main-footer">
        <div class="footer-body">
            <div>
                <a href="/" style="display:inline-flex;align-items:center;text-decoration:none;">
                    <img src="/images/logo.png" alt="Logo" style="height:44px;width:auto;object-fit:contain;" />
                </a>
                <p class="footer-brand-desc">Elegance in Every Stitch</p>
                <div class="footer-socials">
                    <a href="https://www.facebook.com/share/1Buimi6joN/" target="_blank"><i class="bi bi-facebook"></i></a>
                    <a href="#"><i class="bi bi-instagram"></i></a>
                    <a href="https://api.whatsapp.com/send?phone=923002222662" target="_blank"><i class="bi bi-whatsapp"></i></a>
                </div>
            </div>
            <div class="footer-col">
                <h6>Contact</h6>
                <a href="tel:+923002222662"><i class="bi bi-telephone-fill" style="color:var(--pink);"></i> +92-300-2222662</a>
            </div>
        </div>
        <div class="footer-bottom">
            <p>Software Developed By: <span style="font-weight:700;color:rgba(214,19,109,.6);">UT Designer</span></p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // SUB HEADER
        document.addEventListener("DOMContentLoaded", function () {
            const sub = document.getElementById("miniSubHeader");
            const hdr = document.querySelector(".main-header");
            if (sub && hdr) hdr.style.top = sub.offsetHeight + "px";
        });

        // SLIDER ANIMATION
        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById('detailSlider').addEventListener('slide.bs.carousel', function (e) {
                const inc = e.relatedTarget; if (!inc) return;
                inc.querySelectorAll('.caption-badge,.caption-heading').forEach(el => {
                    el.style.animation = 'none'; el.style.opacity = '0';
                    void el.offsetWidth; el.style.animation = '';
                });
            });
        });

        // FILTER
        document.addEventListener("DOMContentLoaded", function () {
            const si = document.getElementById("productSearch");
            const cf = document.getElementById("categoryFilter");
            function filterProducts() {
                const q = si.value.toLowerCase(), c = cf.value.toLowerCase();
                document.querySelectorAll(".product-section .row").forEach(row => {
                    const prev = row.previousElementSibling; if (!prev) return;
                    const badge = prev.querySelector(".category-badge"); if (!badge) return;
                    const cat = badge.innerText.toLowerCase().replace(/^\W+/, '').trim();
                    const catOk = c === "all" || cat.includes(c);
                    let vis = false;
                    row.querySelectorAll(".product-card").forEach(card => {
                        const ok = card.dataset.productName.includes(q) && catOk;
                        card.style.display = ok ? "block" : "none"; if (ok) vis = true;
                    });
                    row.style.display = vis ? "flex" : "none";
                    prev.style.display = vis ? "flex" : "none";
                });
            }
            si.addEventListener("keyup", filterProducts);
            cf.addEventListener("change", filterProducts);
        });

        // PRODUCT DATA
        const productMaster = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Products.SelectMany(x => x.Value)));
        function getProductByCode(code) { return productMaster.find(p => p.ProductCode === code); }
        let cart = {};

        // ===== PRODUCT LIGHTBOX =====
        let pmodalCode = null;

        function openProductModal(productCode) {
            const p = getProductByCode(productCode);
            if (!p) return;
            pmodalCode = productCode;

            document.getElementById('pmodal-img').src = '/images/ProductRegistration/' + p.ProductImage;
            document.getElementById('pmodal-img').alt = p.ProductName;

            const discEl = document.getElementById('pmodal-discount');
            if (p.DiscountAmount > 0) { discEl.textContent = '− Rs.' + fmt(p.DiscountAmount) + ' OFF'; discEl.style.display = 'inline-block'; }
            else { discEl.style.display = 'none'; }

            document.getElementById('pmodal-category').textContent = p.Category || '';
            document.getElementById('pmodal-name').textContent = p.ProductName;
            document.getElementById('pmodal-desc').textContent = p.ProductDescription || 'No description available.';

            const net = (p.Prices || 0) - (p.DiscountAmount || 0);
            document.getElementById('pmodal-price').textContent = 'Rs. ' + fmt(net);

            const oldEl = document.getElementById('pmodal-old-price');
            if (p.DiscountAmount > 0) { oldEl.textContent = 'Rs. ' + fmt(p.Prices); oldEl.style.display = 'inline'; }
            else { oldEl.style.display = 'none'; }

            const cardQty = parseInt(document.getElementById('qty-' + productCode)?.textContent) || 0;
            document.getElementById('pmodal-qty').textContent = Math.max(cardQty, 1);

            new bootstrap.Modal(document.getElementById('productModal')).show();
        }

        function pmodalQty(delta) {
            const el = document.getElementById('pmodal-qty');
            el.textContent = Math.max(1, parseInt(el.textContent) + delta);
        }

        function pmodalAddToCart() {
            if (!pmodalCode) return;
            const qty = parseInt(document.getElementById('pmodal-qty').textContent) || 1;
            const p = getProductByCode(pmodalCode);
            if (!p) return;

            const cardQtyEl = document.getElementById('qty-' + pmodalCode);
            if (cardQtyEl) cardQtyEl.textContent = qty;

            cart[pmodalCode] = {
                ProductCode: pmodalCode, ProductName: p.ProductName,
                Quantity: qty, Rate: p.Prices,
                DiscountAmount: p.DiscountAmount,
                DeliveryCharges: p.DeliveryCharges,
                image: p.ProductImage
            };
            renderCart();
            bootstrap.Modal.getInstance(document.getElementById('productModal')).hide();

            const icon = document.getElementById('cartIcon');
            icon.style.background = '#D6136D'; icon.style.color = '#ffffff';
            setTimeout(() => { icon.style.background = ''; icon.style.color = ''; }, 700);
        }

        // CART
        function changeQuantity(productCode, productName, delta) {
            const qtySpan = document.getElementById('qty-' + productCode);
            let newQty = Math.max(0, (parseInt(qtySpan.textContent) || 0) + delta);
            qtySpan.textContent = newQty;
            const product = getProductByCode(productCode);
            if (!product) return;
            if (delta > 0) flyToCart(productCode);
            if (newQty === 0) { delete cart[productCode]; }
            else { cart[productCode] = { ProductCode: productCode, ProductName: product.ProductName, Quantity: newQty, Rate: product.Prices, DiscountAmount: product.DiscountAmount, DeliveryCharges: product.DeliveryCharges, image: product.ProductImage }; }
            renderCart();
        }

        function flyToCart(productCode) {
            const img = document.getElementById('img-' + productCode);
            const cartIcon = document.getElementById('cartIcon');
            if (!img || !cartIcon) return;
            const ir = img.getBoundingClientRect(), cr = cartIcon.getBoundingClientRect();
            const fi = img.cloneNode(true);
            fi.style.cssText = `position:fixed;z-index:9999;pointer-events:none;border-radius:10px;transition:all .75s cubic-bezier(.4,0,.2,1);left:${ir.left}px;top:${ir.top}px;width:${ir.width}px;height:${ir.height}px;`;
            document.body.appendChild(fi);
            requestAnimationFrame(() => { Object.assign(fi.style, { left: cr.left + "px", top: cr.top + "px", width: "24px", height: "24px", opacity: "0" }); });
            fi.addEventListener("transitionend", () => fi.remove());
        }

        function renderCart() {
            const container = document.getElementById("cartItemsContainer");
            const totalDiv  = document.getElementById("cartTotal");
            container.innerHTML = "";
            const items = Object.values(cart);
            if (items.length === 0) {
                container.innerHTML = `<div class="cart-empty-state"><div class="cart-empty-icon"><i class="bi bi-cart-x"></i></div><div class="cart-empty-text">Your cart is empty</div><div style="font-size:.76rem;color:var(--muted);margin-top:4px;">Add items to get started</div></div>`;
                totalDiv.style.display = "none"; updateCartCount(); return;
            }
            let tg = 0, td = 0, tq = 0, dc = 0;
            items.forEach(item => {
                if (dc === 0 && item.DeliveryCharges !== undefined) dc = Number(item.DeliveryCharges);
                const r = item.Quantity * item.Rate, d = item.Quantity * item.DiscountAmount, net = r - d;
                tg += r; td += d; tq += item.Quantity;
                const unitDisplay = item.DiscountAmount > 0
                    ? `<span style="color:var(--pink);font-weight:700;">${fmt(item.Rate - item.DiscountAmount)}</span> <span style="text-decoration:line-through;color:var(--danger);opacity:.7;">${fmt(item.Rate)}</span>`
                    : `<span style="color:var(--muted);">${fmt(item.Rate)}</span>`;
                container.innerHTML += `
                    <div class="cart-item">
                        <img src="/images/ProductRegistration/${item.image}" class="cart-item-img" />
                        <div class="cart-item-info"><strong>${item.ProductName}</strong><div class="cart-item-price-unit">Unit: ${unitDisplay}</div></div>
                        <div class="cart-item-right">
                            <div class="cart-item-total">${fmt(net)}</div>
                            <div class="cart-qty-box">
                                <button class="cart-qty-btn minus" onclick="changeQuantity('${item.ProductCode}','${item.ProductName}',-1)">−</button>
                                <span class="cart-qty-num">${item.Quantity}</span>
                                <button class="cart-qty-btn" onclick="changeQuantity('${item.ProductCode}','${item.ProductName}',1)">+</button>
                            </div>
                        </div>
                    </div>`;
            });
            const np = (tg - td) + dc;
            totalDiv.style.display = "block";
            totalDiv.innerHTML = `
                <div class="cart-total-inner">
                    <div class="total-row"><span class="lbl"><i class="bi bi-bag"></i> Total Items</span><span class="val">${tq}</span></div>
                    <div class="total-row"><span class="lbl"><i class="bi bi-receipt"></i> Gross</span><span class="val">${fmt(tg)}</span></div>
                    ${td > 0 ? `<div class="total-row discount"><span class="lbl"><i class="bi bi-tag"></i> Discount</span><span class="val">− ${fmt(td)}</span></div>` : ''}
                    <div class="total-row"><span class="lbl"><i class="bi bi-truck"></i> Delivery</span><span class="val">${dc === 0 ? `<span class="free-delivery">Free</span>` : `<span class="delivery-fee">${fmt(dc)}</span>`}</span></div>
                    <div class="total-row net"><span class="lbl">Payable</span><span class="val">${fmt(np)}</span></div>
                </div>`;
            updateCartCount();
        }

        function fmt(v) { return Number(v).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 }); }

        function updateCartCount() {
            let c = 0; Object.values(cart).forEach(x => c += x.Quantity);
            document.getElementById('cartCount').textContent = c;
            const hBadge = document.getElementById('cartHeaderCount');
            if (c > 0) { hBadge.textContent = c + ' items'; hBadge.style.display = 'inline'; }
            else { hBadge.style.display = 'none'; }
        }

        function toggleCart() {
            document.getElementById('cartDrawer').classList.toggle('open');
            document.getElementById('cartBackdrop').classList.toggle('show');
        }

        function openCheckoutModal() {
            if (Object.values(cart).length === 0) { Swal.fire({ icon: 'warning', title: 'Cart Empty', text: 'Please add items to cart first.' }); return; }
            document.getElementById('cartDrawer').classList.remove('open');
            document.getElementById('cartBackdrop').classList.remove('show');
            fetch('/StoreDetail/CheckRestaurantValidation', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ RestaurantId: @Model.RestaurantId }) })
                .then(r => r.json())
                .then(data => {
                    if (data.statusId === 0) { document.querySelector('#closedModal .modal-title').innerText = 'Order Not Allowed'; document.querySelector('#closedModal .modal-body').innerHTML = data.message; new bootstrap.Modal(document.getElementById('closedModal')).show(); return; }
                    new bootstrap.Modal(document.getElementById('checkoutModal')).show();
                })
                .catch(() => Swal.fire('Error', 'Server validation failed.', 'error'));
        }

        function placeOrder() {
            const contactNo = document.getElementById("ContactNo").value.trim();
            const customerName = document.getElementById("CustomerName").value.trim();
            const customerAddress = document.getElementById("CustomerAddress").value.trim();
            const street = document.getElementById("Street").value.trim();
            const floor = document.getElementById("Floor").value.trim();
            const description = document.getElementById("Description").value.trim();
            if (!contactNo || contactNo.length < 9) { Swal.fire("Validation", "Contact No must be at least 9 digits.", "error"); return; }
            if (!customerName || !customerAddress || !street || !floor) { Swal.fire("Validation", "All fields are mandatory except Description.", "error"); return; }
            Swal.fire({ title: "Confirm Order", text: "Are you sure you want to place this order?", icon: "question", showCancelButton: true, confirmButtonText: "Yes, Place Order", cancelButtonText: "No", confirmButtonColor: "#D6136D", cancelButtonColor: "#6c757d", reverseButtons: true, focusCancel: true })
                .then(result => {
                    if (!result.isConfirmed) return;
                    bootstrap.Modal.getInstance(document.getElementById('checkoutModal')).hide();
                    setTimeout(() => {
                        Swal.fire({ title: "Please wait...", html: `<div style="text-align:center"><img src="/Images/GIF/OrderPlaced.gif" class="success-gif mb-3" /><div style="font-weight:700;color:#000;">Placing your order...</div></div>`, allowOutsideClick: false, allowEscapeKey: false, showConfirmButton: false, backdrop: 'rgba(0,0,0,0.7)', customClass: { popup: 'loading-swal-popup', container: 'loading-swal-container' }, didOpen: () => { const c = document.querySelector('.swal2-container'); c.setAttribute('tabindex', '-1'); c.focus(); document.querySelectorAll('#checkoutModal input,#checkoutModal textarea').forEach(i => i.disabled = true); }, willClose: () => { document.querySelectorAll('#checkoutModal input,#checkoutModal textarea').forEach(i => i.disabled = false); } });
                        $.ajax({
                            url: "/StoreDetail/PlaceOrder", type: "POST", contentType: "application/json",
                            data: JSON.stringify({ ContactNo: contactNo, CustomerName: customerName, CustomerAddress: customerAddress, Street: street, Floor: floor, Description: description, Items: Object.values(cart), RestaurantId: @Model.RestaurantId }),
                            success: function (res) {
                                Swal.close();
                                document.getElementById("orderSuccessMessage").innerHTML = res.message;
                                if (res.statusId === 0) { document.getElementById("orderStatusGif").src = "/Images/GIF/OrderFailed.gif"; }
                                else { document.getElementById("orderStatusGif").src = "/Images/GIF/OrderSuccess.gif"; cart = {}; renderCart(); document.querySelectorAll('[id^="qty-"]').forEach(s => s.textContent = 0); clearCheckoutModalFields(); }
                                new bootstrap.Modal(document.getElementById('orderSuccessModal')).show();
                            },
                            error: function () { Swal.close(); Swal.fire("Error", "Something went wrong.", "error"); }
                        });
                    }, 300);
                });
        }

        function clearCheckoutModalFields(cc = true) {
            if (cc) document.getElementById("ContactNo").value = "";
            ["CustomerName", "CustomerAddress", "Street", "Floor", "Description"].forEach(id => document.getElementById(id).value = "");
        }

        document.getElementById("ContactNo").addEventListener("input", function () { this.value = this.value.replace(/\D/g, ''); });
        document.getElementById("ContactNo").addEventListener("blur", function () {
            if (!this.value.trim()) return;
            fetch('/StoreDetail/CustomerExsistOrNo', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ ContactNo: this.value.trim() }) })
                .then(r => r.json())
                .then(data => {
                    if (data.statusId === 1) {
                        document.getElementById("CustomerName").value    = data.customerName    || "";
                        document.getElementById("CustomerAddress").value = data.customerAddress || "";
                        document.getElementById("Street").value          = data.street          || "";
                        document.getElementById("Floor").value           = data.floor           || "";
                        document.getElementById("Description").value     = data.description     || "";
                    } else { clearCheckoutModalFields(false); }
                }).catch(err => console.error(err));
        });

        document.addEventListener("DOMContentLoaded", function () {
            const inputs = document.querySelectorAll(".next-input");
            inputs.forEach((input, index) => {
                input.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") { e.preventDefault(); const next = inputs[index + 1]; next ? next.focus() : placeOrder(); }
                });
            });
        });
    </script>
</body>
</html>
