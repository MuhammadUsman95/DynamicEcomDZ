@model DynamicEcomDZ.Models.RestaurantDetailViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@Model.RestaurantName</title>
    <link rel="icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

    <style>
        :root {
            --pink:          #D6136D;
            --pink-dark:     #A30F52;
            --pink-soft:     #FDE8F2;
            --bg:            #F9F9F9;
            --dark:          #333333;
            --danger:        #dc3545;
            --success:       #28a745;

            /* legacy alias kept for compatibility */
            --lavender-purple: #D6136D;
            --dark-charcoal:   #333333;
            --warm-yellow:     #F5A623;
            --vibrant-pink:    #D6136D;
            --light-grey:      #F9F9F9;
            --medium-gray:     #757575;
            --border-gray:     #E0E0E0;
            --bright-orange:   #FF4C00;
            --footer-dark:     #222222;
            --white:           #ffffff;
            --muted:           #64748b;
            --radius:          14px;
            --tr:              all .35s cubic-bezier(.4, 0, .2, 1);
            --shadow-sm:       0 2px 12px rgba(214,19,109,.08);
            --shadow-lg:       0 20px 60px rgba(214,19,109,.18);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg);
            font-family: 'Poppins', sans-serif;
            color: var(--dark);
        }

        /* ===== SUB HEADER ===== */
        .mini-sub-header {
            background: var(--pink);
            color: #ffffff;
            font-size: .82rem;
            font-weight: 500;
            position: sticky;
            top: 0;
            z-index: 1060;
            border-bottom: 1px solid var(--pink-dark);
        }

        .sub-header-inner {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 7px 0;
        }

        .sub-header-inner i { color: #ffffff; }

        /* ===== MAIN HEADER ===== */
        .main-header {
            background: #ffffff;
            box-shadow: 0 2px 20px rgba(214,19,109,.12);
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 2px solid var(--pink);
        }

        .main-header .header-inner {
            width: 92%;
            max-width: 1200px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 68px;
        }

        .header-logo img {
            height: 46px;
            width: auto;
            object-fit: contain;
            transition: var(--tr);
        }

        .header-logo img:hover { transform: scale(1.04); }

        .cart-icon {
            position: relative;
            font-size: 24px;
            cursor: pointer;
            color: var(--pink);
            width: 46px;
            height: 46px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: var(--pink-soft);
            border: 1.5px solid rgba(214,19,109,.3);
            transition: var(--tr);
        }

        .cart-icon:hover {
            background: var(--pink);
            color: #ffffff;
            transform: scale(1.08);
            border-color: var(--pink);
        }

        .cart-count {
            position: absolute;
            top: 2px;
            right: 2px;
            background: var(--pink);
            color: #ffffff;
            font-size: 9px;
            font-weight: 800;
            padding: 2px 6px;
            border-radius: 20px;
            min-width: 18px;
            text-align: center;
            line-height: 14px;
            border: 2px solid #ffffff;
            transition: transform .2s ease;
        }

        .cart-icon:hover .cart-count { transform: scale(1.15); }

        /* ===== SLIDER ===== */
        #detailSlider { width: 100%; overflow: hidden; position: relative; }

        #detailSlider .carousel-inner img {
            width: 100%;
            height: 500px;
            object-fit: cover;
            filter: brightness(50%);
            transition: filter .5s ease, transform 6s ease;
        }

        #detailSlider .carousel-item.active img { transform: scale(1.05); }

        #detailSlider:hover .carousel-inner img { filter: brightness(60%); }

        #detailSlider .carousel-item::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, rgba(26,26,46,.9) 0%, rgba(214,19,109,.25) 60%, rgba(0,0,0,.1) 100%);
            z-index: 1;
        }

        #detailSlider .carousel-caption {
            position: absolute;
            top: 73%;
            left: 7%;
            right: auto;
            transform: translateY(-50%);
            z-index: 10;
            text-align: left;
            max-width: 520px;
            padding: 0;
        }

        .caption-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--pink);
            color: #ffffff;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 5px 16px;
            border-radius: 30px;
            margin-bottom: 18px;
            opacity: 0;
        }

        .caption-heading {
            font-size: 3rem;
            font-weight: 900;
            color: #ffffff;
            line-height: 1.1;
            margin-bottom: 16px;
            text-shadow: 0 4px 24px rgba(0,0,0,.5);
            opacity: 0;
        }

        @@keyframes capBadgeIn {
            from { opacity: 0; transform: scale(.75) }
            to   { opacity: 1; transform: scale(1)   }
        }

        @@keyframes capHeadIn {
            from { opacity: 0; transform: translateX(-60px) }
            to   { opacity: 1; transform: translateX(0)     }
        }

        #detailSlider .carousel-item.active .caption-badge  { animation: capBadgeIn .6s ease .10s forwards; }
        #detailSlider .carousel-item.active .caption-heading { animation: capHeadIn  .7s ease .35s forwards; }

        #detailSlider .carousel-control-prev,
        #detailSlider .carousel-control-next {
            width: 50px;
            height: 50px;
            background: rgba(214,19,109,.2);
            backdrop-filter: blur(8px);
            border-radius: 50%;
            top: 50%;
            bottom: auto;
            transform: translateY(-50%);
            margin: 0 22px;
            opacity: 0;
            border: 1.5px solid rgba(214,19,109,.4);
            transition: var(--tr);
        }

        #detailSlider:hover .carousel-control-prev,
        #detailSlider:hover .carousel-control-next { opacity: 1; }

        #detailSlider .carousel-control-prev:hover,
        #detailSlider .carousel-control-next:hover {
            background: var(--pink);
            border-color: var(--pink);
        }

        #detailSlider .carousel-indicators { margin-bottom: 24px; gap: 6px; }

        #detailSlider .carousel-indicators button {
            width: 28px;
            height: 4px;
            border-radius: 4px;
            background: rgba(255,255,255,.4);
            border: none;
            padding: 0;
            transition: var(--tr);
        }

        #detailSlider .carousel-indicators .active { width: 48px; background: var(--pink); }

        @@media (max-width:768px) {
            #detailSlider .carousel-inner img { height: 280px; }
            .caption-heading { font-size: 1.8rem; }
        }

        @@media (max-width:576px) {
            #detailSlider .carousel-inner img { height: 220px; }
            .caption-heading { font-size: 1.4rem; }
            .caption-badge   { font-size: .62rem; }
        }

        /* ===== PRODUCTS SECTION ===== */
        .products-section-wrap { background: var(--bg); padding: 32px 0 48px; }

        .restaurant-bar {
            background: #ffffff;
            border-radius: var(--radius);
            padding: 16px 20px;
            margin-bottom: 28px;
            box-shadow: 0 4px 24px rgba(214,19,109,.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            border: 1.5px solid rgba(214,19,109,.2);
        }

        .restaurant-identity { display: flex; align-items: center; gap: 14px; }

        .restaurant-logo {
            width: 52px;
            height: 52px;
            object-fit: cover;
            border-radius: 12px;
            box-shadow: var(--shadow-sm);
            border: 2px solid var(--pink);
        }

        .restaurant-name-text {
            font-weight: 800;
            color: var(--pink);
            font-size: 1.05rem;
            line-height: 1.2;
            margin: 0;
        }

        .restaurant-address-text {
            font-size: .74rem;
            color: var(--muted);
            margin: 3px 0 0;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .restaurant-address-text i { color: var(--pink); font-size: .78rem; }

        .filter-wrap { display: flex; gap: 8px; }

        .filter-wrap .form-control,
        .filter-wrap .form-select {
            border: 1.5px solid rgba(214,19,109,.25);
            border-radius: 10px;
            font-size: .85rem;
            font-family: 'Poppins', sans-serif;
            background: #ffffff;
            color: var(--dark);
            transition: var(--tr);
        }

        .filter-wrap .form-control::placeholder { color: rgba(26,26,46,.4); }

        .filter-wrap .form-select option { background: #ffffff; color: var(--dark); }

        .filter-wrap .form-control:focus,
        .filter-wrap .form-select:focus {
            border-color: var(--pink);
            box-shadow: 0 0 0 3px rgba(214,19,109,.15);
            background: #ffffff;
            color: var(--dark);
        }

        @@media (max-width:767px) {
            .restaurant-bar { flex-direction: column; align-items: flex-start; }
            .filter-wrap { width: 100%; }
            .filter-wrap .form-control, .filter-wrap .form-select { flex: 1; }
        }

        /* ===== CATEGORY TITLE ===== */
        .product-category-title {
            margin: 36px 0 20px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .product-category-title::before,
        .product-category-title::after {
            content: '';
            flex: 1;
            height: 1.5px;
            background: linear-gradient(90deg, transparent, rgba(214,19,109,.3), transparent);
        }

        button {
            background: var(--pink);
            color: #ffffff;
            border-radius: var(--radius);
            font-weight: 700;
            font-size: 1rem;
            padding: 10px 20px;
            cursor: pointer;
            transition: var(--tr);
        }

        button:hover { background: var(--pink-dark); }

        .category-badge {
            background: linear-gradient(135deg, var(--pink), var(--pink-dark));
            color: #ffffff;
            padding: 7px 20px;
            border-radius: 50px;
            font-size: .88rem;
            font-weight: 700;
            letter-spacing: .5px;
            white-space: nowrap;
            box-shadow: 0 4px 16px rgba(214,19,109,.3);
        }

        /* ===== PRODUCT CARD ===== */
        .product-item {
            background: #ffffff;
            border-radius: var(--radius);
            overflow: hidden;
            height: 100%;
            box-shadow: 0 2px 12px rgba(214,19,109,.07);
            transition: transform .35s cubic-bezier(.34,1.56,.64,1), box-shadow .35s ease;
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(214,19,109,.1);
            cursor: pointer;
        }

        .product-item:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 48px rgba(214,19,109,.18);
            border-color: rgba(214,19,109,.35);
        }

        .product-img {
            height: 150px;
            overflow: hidden;
            background: var(--pink-soft);
            position: relative;
        }

        .product-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .5s ease;
        }

        .product-item:hover .product-img img { transform: scale(1.1); }

        .zoom-hint {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 3;
            transition: background .3s ease;
            pointer-events: none;
        }

        .zoom-hint i { font-size: 2rem; color: rgba(255,255,255,0); transition: color .3s ease; }

        .product-item:hover .zoom-hint       { background: rgba(214,19,109,.35); }
        .product-item:hover .zoom-hint i     { color: rgba(255,255,255,.9); }

        .discount-badge {
            position: absolute;
            top: 8px;
            right: 8px;
            background: linear-gradient(135deg, var(--pink), var(--pink-dark));
            color: #ffffff;
            font-size: 11px;
            font-weight: 800;
            padding: 3px 9px;
            border-radius: 20px;
            z-index: 4;
            box-shadow: 0 4px 12px rgba(214,19,109,.4);
        }

        .product-info {
            padding: 14px 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 5px;
            flex-grow: 1;
        }

        .product-name  { font-size: .92rem; font-weight: 700; margin: 0; color: var(--dark); line-height: 1.3; }
        .product-description { font-size: .76rem; color: var(--muted); line-height: 1.4; }

        .product-price {
            margin-top: auto;
            display: flex;
            align-items: baseline;
            gap: 6px;
            padding-top: 6px;
        }

        .current-price { font-weight: 800; font-size: 1rem; color: var(--pink); }
        .old-price     { font-size: .82rem; color: var(--danger); text-decoration: line-through; opacity: .8; }

        .qty-box {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 12px;
            gap: 14px;
            background: var(--pink-soft);
            border-radius: 30px;
            padding: 6px 10px;
        }

        .qty-btn {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            border: none;
            background: var(--pink);
            color: #ffffff;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: transform .2s, background .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(214,19,109,.3);
            line-height: 1;
        }

        .qty-btn:hover  { transform: scale(1.12); background: var(--pink-dark); }
        .qty-btn:active { transform: scale(.93); }

        .qty-value {
            font-size: 1rem;
            font-weight: 800;
            min-width: 24px;
            text-align: center;
            color: var(--dark);
        }

        @@media (max-width:576px) {
            .product-img  { height: 120px; }
            .product-name { font-size: .85rem; }
            .qty-btn      { width: 28px; height: 28px; font-size: 1rem; }
        }

        .flying-img {
            position: fixed;
            z-index: 9999;
            pointer-events: none;
            transition: all .75s cubic-bezier(.4,0,.2,1);
            border-radius: 10px;
            box-shadow: 0 8px 24px rgba(214,19,109,.3);
        }

        /* ===== PRODUCT LIGHTBOX MODAL ===== */
        #productModal .modal-dialog  { max-width: 700px; }

        #productModal .modal-content {
            border-radius: 20px;
            border: none;
            overflow: hidden;
            background: transparent;
            box-shadow: 0 30px 80px rgba(214,19,109,.25);
        }

        #productModal .modal-body { padding: 0; position: relative; }

        .pmodal-layout { display: grid; grid-template-columns: 1fr 1fr; min-height: 380px; }

        @@media (max-width:576px) { .pmodal-layout { grid-template-columns: 1fr; } }

        .pmodal-img-wrap { position: relative; overflow: hidden; background: var(--pink-soft); min-height: 320px; }

        .pmodal-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform .6s cubic-bezier(.4,0,.2,1);
        }

        .pmodal-img-wrap:hover img { transform: scale(1.08); }

        .pmodal-discount-tag {
            position: absolute;
            top: 14px;
            left: 14px;
            background: linear-gradient(135deg, var(--pink), var(--pink-dark));
            color: #ffffff;
            font-size: 11px;
            font-weight: 800;
            padding: 4px 12px;
            border-radius: 20px;
            z-index: 2;
        }

        .pmodal-close-btn {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: rgba(0,0,0,.55);
            border: 1px solid rgba(255,255,255,.2);
            color: #ffffff;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--tr);
            z-index: 10;
        }

        .pmodal-close-btn:hover { background: var(--pink); border-color: var(--pink); }

        .pmodal-info {
            background: #ffffff;
            padding: 28px 22px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .pmodal-cat-tag {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--pink-soft);
            color: var(--pink);
            border: 1px solid rgba(214,19,109,.25);
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 4px 12px;
            border-radius: 20px;
            width: fit-content;
        }

        .pmodal-name { font-size: 1.15rem; font-weight: 800; color: var(--dark); line-height: 1.3; margin: 0; }
        .pmodal-desc { font-size: .81rem; color: var(--muted); line-height: 1.75; flex-grow: 1; }

        .pmodal-price-row { display: flex; align-items: baseline; gap: 10px; }

        .pmodal-price     { font-size: 1.45rem; font-weight: 900; color: var(--pink); }
        .pmodal-old-price { font-size: .88rem; color: var(--danger); text-decoration: line-through; opacity: .75; }

        .pmodal-qty-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--pink-soft);
            border-radius: 30px;
            padding: 8px 16px;
            border: 1px solid rgba(214,19,109,.2);
        }

        .pmodal-qty-label { font-size: .78rem; color: var(--muted); font-weight: 600; }
        .pmodal-qty-controls { display: flex; align-items: center; gap: 14px; }

        .pmodal-qty-btn {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: none;
            background: var(--pink);
            color: #ffffff;
            font-size: 1.1rem;
            font-weight: 800;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .2s, transform .15s;
        }

        .pmodal-qty-btn:hover  { background: var(--pink-dark); transform: scale(1.1); }
        .pmodal-qty-btn:active { transform: scale(.9); }

        .pmodal-qty-btn.minus { background: #f0f0f5; color: var(--dark); }
        .pmodal-qty-btn.minus:hover { background: var(--danger); color: #ffffff; }

        .pmodal-qty-num { font-size: 1.1rem; font-weight: 900; min-width: 22px; text-align: center; color: var(--dark); }

        .pmodal-add-btn {
            width: 100%;
            padding: 13px;
            border-radius: 12px;
            border: none;
            background: linear-gradient(135deg, var(--pink), var(--pink-dark));
            color: #ffffff;
            font-weight: 800;
            font-size: .95rem;
            cursor: pointer;
            transition: var(--tr);
        }

        .pmodal-add-btn:hover {
            background: var(--dark);
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(214,19,109,.25);
        }

        /* ===== CART DRAWER ===== */
        .cart-drawer {
            position: fixed;
            top: 0;
            right: -420px;
            width: 380px;
            height: 100vh;
            background: #ffffff;
            z-index: 1300;
            display: flex;
            flex-direction: column;
            transition: right .38s cubic-bezier(.4,0,.2,1);
            box-shadow: -12px 0 48px rgba(214,19,109,.15);
            border-left: 2px solid rgba(214,19,109,.2);
        }

        .cart-drawer.open { right: 0; }

        .cart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 20px 14px;
            border-bottom: 2px solid rgba(214,19,109,.15);
            flex-shrink: 0;
            background: linear-gradient(135deg, var(--pink), var(--pink-dark));
        }

        .cart-header h4 {
            font-weight: 800;
            color: #ffffff;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 0;
        }

        .cart-close-btn {
            border: none;
            background: rgba(255,255,255,.2);
            width: 34px;
            height: 34px;
            border-radius: 50%;
            font-size: 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--tr);
            color: #ffffff;
        }

        .cart-close-btn:hover { background: rgba(255,255,255,.35); }

        .cart-items-scroll {
            flex-grow: 1;
            overflow-y: auto;
            padding: 12px 14px 6px;
            background: var(--bg);
        }

        .cart-items-scroll::-webkit-scrollbar       { width: 4px; }
        .cart-items-scroll::-webkit-scrollbar-thumb { background: rgba(214,19,109,.3); border-radius: 10px; }

        .cart-empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            text-align: center;
        }

        .cart-empty-icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: var(--pink-soft);
            border: 1px solid rgba(214,19,109,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: rgba(214,19,109,.4);
            margin-bottom: 14px;
        }

        .cart-empty-text { font-size: .85rem; font-weight: 600; color: var(--muted); }

        .cart-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            background: #ffffff;
            border: 1px solid rgba(214,19,109,.1);
            margin-bottom: 8px;
            transition: box-shadow .25s ease;
        }

        .cart-item:hover { box-shadow: 0 4px 16px rgba(214,19,109,.12); border-color: rgba(214,19,109,.25); }

        .cart-item-img {
            width: 52px;
            height: 52px;
            object-fit: cover;
            border-radius: 10px;
            flex-shrink: 0;
            border: 1.5px solid rgba(214,19,109,.2);
        }

        .cart-item-info { flex: 1; min-width: 0; }

        .cart-item-info strong {
            font-size: .82rem;
            display: block;
            color: var(--dark);
            font-weight: 700;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .cart-item-price-unit { font-size: .72rem; color: var(--muted); margin-top: 2px; }

        .cart-qty-box {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--pink-soft);
            border-radius: 20px;
            padding: 3px 6px;
            flex-shrink: 0;
        }

        .cart-qty-btn {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: none;
            background: var(--pink);
            color: #ffffff;
            font-size: .95rem;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .2s, transform .15s;
            line-height: 1;
            flex-shrink: 0;
        }

        .cart-qty-btn:hover        { background: var(--pink-dark); transform: scale(1.1); }
        .cart-qty-btn.minus        { background: #e9e9f0; color: var(--dark); }
        .cart-qty-btn.minus:hover  { background: var(--danger); color: #ffffff; }

        .cart-qty-num { font-size: .85rem; font-weight: 800; min-width: 18px; text-align: center; color: var(--dark); }

        .cart-item-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; flex-shrink: 0; }
        .cart-item-total { font-weight: 800; font-size: .88rem; color: var(--pink); white-space: nowrap; }

        .cart-total { padding: 14px 16px; border-top: 1.5px solid rgba(214,19,109,.15); flex-shrink: 0; background: #ffffff; }

        .cart-total-inner {
            background: var(--bg);
            border-radius: 12px;
            padding: 12px 14px;
            border: 1px solid rgba(214,19,109,.15);
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 7px;
            font-size: .82rem;
            color: var(--muted);
        }

        .total-row:last-child { margin-bottom: 0; }

        .total-row .lbl { font-weight: 500; display: flex; align-items: center; gap: 5px; }
        .total-row .lbl i { font-size: .8rem; opacity: .6; }
        .total-row .val { font-weight: 700; color: var(--dark); }

        .total-row.discount .lbl,
        .total-row.discount .val { color: var(--danger); }

        .total-row.net {
            margin-top: 10px;
            padding-top: 10px;
            border-top: 1.5px dashed rgba(214,19,109,.25);
        }

        .total-row.net .lbl { font-size: 1rem; font-weight: 800; color: var(--dark); }
        .total-row.net .val { font-size: 1.15rem; font-weight: 900; color: var(--pink); }

        .free-delivery  { background: var(--success); color: #ffffff; padding: 1px 9px; border-radius: 30px; font-size: .72rem; font-weight: 700; }
        .delivery-fee   { color: var(--pink); font-weight: 700; }

        .checkout-wrapper { padding: 12px 16px 16px; flex-shrink: 0; background: #ffffff; }

        .checkout-wrapper .btn {
            border-radius: 12px;
            font-weight: 700;
            font-size: .95rem;
            padding: 13px;
            background: linear-gradient(135deg, var(--pink), var(--pink-dark));
            border: none;
            color: #ffffff;
            box-shadow: 0 6px 20px rgba(214,19,109,.35);
            transition: var(--tr);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .checkout-wrapper .btn:hover { background: var(--dark); color: #ffffff; transform: translateY(-2px); }

        @@media (max-width:576px) { .cart-drawer { width: 100%; right: -100%; } }

        .cart-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(26,26,46,.55);
            backdrop-filter: blur(3px);
            z-index: 900;
            opacity: 0;
            visibility: hidden;
            transition: .3s ease;
        }

        .cart-backdrop.show { opacity: 1; visibility: visible; }

        /* ===== MODALS ===== */
        .modal-content { border-radius: 16px; border: none; box-shadow: var(--shadow-lg); }

        .modal-header {
            background: linear-gradient(135deg, var(--pink), var(--pink-dark));
            border-bottom: none;
            border-radius: 16px 16px 0 0;
        }

        .modal-header .modal-title    { color: #ffffff; font-weight: 700; }
        .modal-header .btn-close      { filter: brightness(0) invert(1); }

        .input-group-text { background: var(--pink-soft); border-color: rgba(214,19,109,.2); color: var(--pink); }

        .form-control,
        .form-select {
            border-color: rgba(214,19,109,.2);
            border-radius: 10px;
            font-family: 'Poppins', sans-serif;
            font-size: .88rem;
            transition: var(--tr);
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--pink);
            box-shadow: 0 0 0 3px rgba(214,19,109,.15);
        }

        #orderSuccessModal .modal-dialog { transform: scale(.7); transition: transform .35s cubic-bezier(.34,1.56,.64,1); }
        #orderSuccessModal.show .modal-dialog { transform: scale(1); }

        .success-gif { width: 130px; height: 130px; border-radius: 50%; object-fit: cover; }

        /* ===== FOOTER ===== */
        .main-footer {
            background: var(--footer-dark);
            color: rgba(255,255,255,.5);
            border-top: 3px solid var(--pink);
        }

        .footer-body {
            display: grid;
            grid-template-columns: 1.6fr 1fr;
            gap: 40px;
            padding: 44px 40px 32px;
            border-bottom: 1px solid rgba(214,19,109,.12);
            max-width: 1200px;
            margin: auto;
        }

        @@media (max-width:768px) { .footer-body { grid-template-columns: 1fr; gap: 24px; padding: 32px 24px; } }

        .footer-brand-desc { font-size: .84rem; line-height: 1.75; margin-top: 10px; color: rgba(255,255,255,.4); }

        .footer-socials { display: flex; gap: 9px; margin-top: 16px; }

        .footer-socials a {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            background: rgba(214,19,109,.1);
            color: var(--pink);
            border: 1px solid rgba(214,19,109,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-size: 1rem;
            transition: var(--tr);
        }

        .footer-socials a:hover { background: var(--pink); color: #ffffff; transform: translateY(-2px); }

        .footer-col h6 {
            font-size: .78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .12em;
            color: var(--pink);
            margin-bottom: 12px;
        }

        .footer-col a { color: rgba(255,255,255,.45); text-decoration: none; font-size: .84rem; display: flex; align-items: center; gap: 8px; transition: color .2s; }
        .footer-col a:hover { color: var(--pink); }

        .footer-bottom {
            text-align: center;
            padding: 14px 24px;
            font-size: .78rem;
            color: rgba(255,255,255,.25);
            background: rgba(0,0,0,.4);
            border-top: 1px solid rgba(214,19,109,.1);
        }

        .loading-swal-container { z-index: 99999 !important; }
        .loading-swal-popup     { z-index: 99999 !important; }
        .modal-backdrop         { z-index: 1040 !important; }
        .modal                  { z-index: 1050 !important; }
    </style>
</head>

