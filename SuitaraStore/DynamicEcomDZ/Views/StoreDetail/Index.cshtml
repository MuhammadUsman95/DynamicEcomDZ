    <!-- Back to Top -->
    <button class="back-top" id="backTop" onclick="window.scrollTo({top:0,behavior:'smooth'})"><i class="bi bi-chevron-up"></i></button>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ── PROMO + NAV OFFSET ──
        document.addEventListener("DOMContentLoaded", function(){
          const promo = document.getElementById("promoBar");
          const nav   = document.getElementById("mainNav");
          if(promo && nav) nav.style.top = promo.offsetHeight + "px";
        });

        // ── BACK TO TOP ──
        window.addEventListener("scroll",function(){
          const bt = document.getElementById("backTop");
          bt.classList.toggle("show", window.scrollY > 400);
        });

        // ── MOBILE MENU ──
        function openMenu(){ document.getElementById("mobileMenu").classList.add("open"); document.body.style.overflow="hidden"; }
        function closeMenu(){ document.getElementById("mobileMenu").classList.remove("open"); document.body.style.overflow=""; }

        // ── SMOOTH SCROLL ──
        document.querySelectorAll('a[href^="#"]').forEach(a=>{
          a.addEventListener("click",function(e){
            const t = document.querySelector(this.getAttribute("href"));
            if(t){ e.preventDefault(); t.scrollIntoView({behavior:"smooth"}); }
          });
        });

        // ── NAV ACTIVE ON SCROLL ──
        window.addEventListener("scroll",function(){
          const sections=["hero","about","shop"];
          sections.forEach(id=>{
            const sec=document.getElementById(id);
            if(!sec) return;
            const r=sec.getBoundingClientRect();
            if(r.top<=100&&r.bottom>100){
              document.querySelectorAll(".nav-link-item").forEach(l=>l.classList.remove("active"));
              const al=document.querySelector(`.nav-link-item[href="#${id}"]`);
              if(al) al.classList.add("active");
            }
          });
        });

        // ── SLIDER ANIMATION ──
        document.getElementById('heroCarousel').addEventListener('slide.bs.carousel',function(e){
          const inc=e.relatedTarget; if(!inc) return;
          inc.querySelectorAll('.hero-tag,.hero-title,.hero-sub,.hero-btns').forEach(el=>{
            el.style.animation='none'; el.style.opacity='0'; void el.offsetWidth; el.style.animation='';
          });
        });

        // ── FILTER ──
        document.addEventListener("DOMContentLoaded",function(){
          const si=document.getElementById("productSearch");
          const cf=document.getElementById("categoryFilter");
          function filter(){
            const q=si.value.toLowerCase(), c=cf.value.toLowerCase();
            document.querySelectorAll("#shop .row").forEach(row=>{
              const prev=row.previousElementSibling; if(!prev) return;
              const badge=prev.querySelector(".cat-title-badge"); if(!badge) return;
              const cat=badge.innerText.toLowerCase().replace(/^\W+/,'').trim();
              const catOk=c==="all"||cat.includes(c);
              let vis=false;
              row.querySelectorAll(".product-card-item").forEach(card=>{
                const ok=card.dataset.productName.includes(q)&&catOk;
                card.style.display=ok?"block":"none"; if(ok) vis=true;
              });
              row.style.display=vis?"flex":"none";
              prev.style.display=vis?"flex":"none";
            });
          }
          si.addEventListener("keyup",filter);
          cf.addEventListener("change",filter);
        });

        // ── FASHION PILLS ──
        document.querySelectorAll(".fpill").forEach(p=>{
          p.addEventListener("click",function(){
            document.querySelectorAll(".fpill").forEach(x=>x.classList.remove("active"));
            this.classList.add("active");
          });
        });

        // ── PRODUCT DATA ──
        const productMaster = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Products.SelectMany(x => x.Value)));
        function getProductByCode(code){ return productMaster.find(p=>p.ProductCode===code); }
        let cart={};

        // ── PRODUCT MODAL ──
        let pmodalCode=null;
        function openProductModal(productCode){
          const p=getProductByCode(productCode); if(!p) return;
          pmodalCode=productCode;
          document.getElementById('pmodal-img').src='/images/ProductRegistration/'+p.ProductImage;
          document.getElementById('pmodal-img').alt=p.ProductName;
          const discEl=document.getElementById('pmodal-discount');
          if(p.DiscountAmount>0){discEl.textContent='−Rs.'+fmt(p.DiscountAmount)+' OFF';discEl.style.display='inline-block';}
          else{discEl.style.display='none';}
          document.getElementById('pmodal-category').textContent=p.Category||'';
          document.getElementById('pmodal-name').textContent=p.ProductName;
          document.getElementById('pmodal-desc').textContent=p.ProductDescription||'Premium quality fashion product.';
          const net=(p.Prices||0)-(p.DiscountAmount||0);
          document.getElementById('pmodal-price').textContent='Rs. '+fmt(net);
          const oldEl=document.getElementById('pmodal-old-price');
          if(p.DiscountAmount>0){oldEl.textContent='Rs. '+fmt(p.Prices);oldEl.style.display='inline';}
          else{oldEl.style.display='none';}
          const cardQty=parseInt(document.getElementById('qty-'+productCode)?.textContent)||0;
          document.getElementById('pmodal-qty').textContent=Math.max(cardQty,1);
          new bootstrap.Modal(document.getElementById('productModal')).show();
        }
        function pmodalQty(d){
          const el=document.getElementById('pmodal-qty');
          el.textContent=Math.max(1,parseInt(el.textContent)+d);
        }
        function pmodalAddToCart(){
          if(!pmodalCode) return;
          const qty=parseInt(document.getElementById('pmodal-qty').textContent)||1;
          const p=getProductByCode(pmodalCode); if(!p) return;
          const cardQtyEl=document.getElementById('qty-'+pmodalCode);
          if(cardQtyEl) cardQtyEl.textContent=qty;
          cart[pmodalCode]={ProductCode:pmodalCode,ProductName:p.ProductName,Quantity:qty,Rate:p.Prices,DiscountAmount:p.DiscountAmount,DeliveryCharges:p.DeliveryCharges,image:p.ProductImage};
          renderCart();
          bootstrap.Modal.getInstance(document.getElementById('productModal')).hide();
          const icon=document.getElementById('cartIcon');
          icon.style.background='var(--pk)';
          setTimeout(()=>{icon.style.background='';},700);
          Swal.fire({toast:true,position:'top-end',icon:'success',title:'Added to cart!',showConfirmButton:false,timer:1800,timerProgressBar:true,customClass:{popup:'swal2-toast'}});
        }

        // ── CART ──
        function changeQuantity(productCode,productName,delta){
          const qtySpan=document.getElementById('qty-'+productCode);
          let newQty=Math.max(0,(parseInt(qtySpan.textContent)||0)+delta);
          qtySpan.textContent=newQty;
          const product=getProductByCode(productCode); if(!product) return;
          if(delta>0) flyToCart(productCode);
          if(newQty===0){delete cart[productCode];}
          else{cart[productCode]={ProductCode:productCode,ProductName:product.ProductName,Quantity:newQty,Rate:product.Prices,DiscountAmount:product.DiscountAmount,DeliveryCharges:product.DeliveryCharges,image:product.ProductImage};}
          renderCart();
        }
        function flyToCart(productCode){
          const img=document.getElementById('img-'+productCode);
          const cartIcon=document.getElementById('cartIcon');
          if(!img||!cartIcon) return;
          const ir=img.getBoundingClientRect(),cr=cartIcon.getBoundingClientRect();
          const fi=img.cloneNode(true);
          fi.style.cssText=`position:fixed;z-index:9999;pointer-events:none;border-radius:10px;transition:all .7s cubic-bezier(.4,0,.2,1);left:${ir.left}px;top:${ir.top}px;width:${ir.width}px;height:${ir.height}px;`;
          document.body.appendChild(fi);
          requestAnimationFrame(()=>{Object.assign(fi.style,{left:cr.left+"px",top:cr.top+"px",width:"30px",height:"30px",opacity:"0"});});
          fi.addEventListener("transitionend",()=>fi.remove());
        }
        function renderCart(){
          const container=document.getElementById("cartItemsContainer");
          const totalDiv=document.getElementById("cartTotal");
          container.innerHTML="";
          const items=Object.values(cart);
          if(items.length===0){
            container.innerHTML=`<div class="cart-empty-state"><div class="cart-empty-icon"><i class="bi bi-cart-x"></i></div><div class="cart-empty-text">Your cart is empty</div><div style="font-size:.74rem;color:var(--muted);margin-top:4px;">Add beautiful items to get started</div></div>`;
            totalDiv.style.display="none"; updateCartCount(); return;
          }
          let tg=0,td=0,tq=0,dc=0;
          items.forEach(item=>{
            if(dc===0&&item.DeliveryCharges!==undefined) dc=Number(item.DeliveryCharges);
            const r=item.Quantity*item.Rate,d=item.Quantity*item.DiscountAmount,net=r-d;
            tg+=r;td+=d;tq+=item.Quantity;
            const unitDisplay=item.DiscountAmount>0
              ?`<span style="color:var(--pk);font-weight:700;">${fmt(item.Rate-item.DiscountAmount)}</span> <span style="text-decoration:line-through;color:#dc3545;opacity:.7;">${fmt(item.Rate)}</span>`
              :`<span style="color:var(--muted);">${fmt(item.Rate)}</span>`;
            container.innerHTML+=`
              <div class="cart-item">
                <img src="/images/ProductRegistration/${item.image}" class="cart-item-img"/>
                <div class="cart-item-info"><strong>${item.ProductName}</strong><div class="cart-item-price-unit">Unit: ${unitDisplay}</div></div>
                <div class="cart-item-right">
                  <div class="cart-item-total">Rs.${fmt(net)}</div>
                  <div class="cart-qty-box">
                    <button class="cart-qty-btn minus" onclick="changeQuantity('${item.ProductCode}','${item.ProductName}',-1)">−</button>
                    <span class="cart-qty-num">${item.Quantity}</span>
                    <button class="cart-qty-btn" onclick="changeQuantity('${item.ProductCode}','${item.ProductName}',1)">+</button>
                  </div>
                </div>
              </div>`;
          });
          const np=(tg-td)+dc;
          totalDiv.style.display="block";
          totalDiv.innerHTML=`<div class="cart-total-inner">
            <div class="total-row"><span class="lbl"><i class="bi bi-bag"></i>Items</span><span class="val">${tq}</span></div>
            <div class="total-row"><span class="lbl"><i class="bi bi-receipt"></i>Subtotal</span><span class="val">Rs.${fmt(tg)}</span></div>
            ${td>0?`<div class="total-row discount"><span class="lbl"><i class="bi bi-tag"></i>Discount</span><span class="val">−Rs.${fmt(td)}</span></div>`:''}
            <div class="total-row"><span class="lbl"><i class="bi bi-truck"></i>Delivery</span><span class="val">${dc===0?`<span class="free-delivery">Free</span>`:`<span class="delivery-fee">Rs.${fmt(dc)}</span>`}</span></div>
            <div class="total-row net"><span class="lbl">Total Payable</span><span class="val">Rs.${fmt(np)}</span></div>
          </div>`;
          updateCartCount();
        }
        function fmt(v){return Number(v).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0});}
        function updateCartCount(){
          let c=0; Object.values(cart).forEach(x=>c+=x.Quantity);
          document.getElementById('cartCount').textContent=c;
          const mb=document.getElementById('cartCountMobile');
          if(mb) mb.textContent=c;
          const hBadge=document.getElementById('cartHeaderCount');
          if(c>0){hBadge.textContent=c+' items';hBadge.style.display='inline';}
          else{hBadge.style.display='none';}
        }
        function toggleCart(){
          document.getElementById('cartDrawer').classList.toggle('open');
          document.getElementById('cartBackdrop').classList.toggle('show');
        }

        // ── CHECKOUT ──
        function openCheckoutModal(){
          if(Object.values(cart).length===0){Swal.fire({icon:'warning',title:'Cart Empty',text:'Please add items first.',confirmButtonColor:'#D6136D'});return;}
          document.getElementById('cartDrawer').classList.remove('open');
          document.getElementById('cartBackdrop').classList.remove('show');
          fetch('/StoreDetail/CheckRestaurantValidation',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({RestaurantId:@Model.RestaurantId})})
            .then(r=>r.json())
            .then(data=>{
              if(data.statusId===0){document.querySelector('#closedModal .modal-title').innerText='Order Not Allowed';document.querySelector('#closedModal .modal-body').innerHTML=data.message;new bootstrap.Modal(document.getElementById('closedModal')).show();return;}
              new bootstrap.Modal(document.getElementById('checkoutModal')).show();
            })
            .catch(()=>Swal.fire('Error','Server validation failed.','error'));
        }
        function placeOrder(){
          const contactNo=document.getElementById("ContactNo").value.trim();
          const customerName=document.getElementById("CustomerName").value.trim();
          const customerAddress=document.getElementById("CustomerAddress").value.trim();
          const street=document.getElementById("Street").value.trim();
          const floor=document.getElementById("Floor").value.trim();
          const description=document.getElementById("Description").value.trim();
          if(!contactNo||contactNo.length<9){Swal.fire("Validation","Contact No must be at least 9 digits.","error");return;}
          if(!customerName||!customerAddress||!street||!floor){Swal.fire("Validation","All fields are mandatory except Description.","error");return;}
          Swal.fire({title:"Confirm Order",text:"Are you sure you want to place this order?",icon:"question",showCancelButton:true,confirmButtonText:"Yes, Place Order",cancelButtonText:"Cancel",confirmButtonColor:"#D6136D",cancelButtonColor:"#6c757d",reverseButtons:true,focusCancel:true})
            .then(result=>{
              if(!result.isConfirmed) return;
              bootstrap.Modal.getInstance(document.getElementById('checkoutModal')).hide();
              setTimeout(()=>{
                Swal.fire({title:"Processing...",html:`<div style="text-align:center"><img src="/Images/GIF/OrderPlaced.gif" style="width:120px;height:120px;border-radius:50%;margin-bottom:12px;"/><div style="font-weight:700;color:#333;">Placing your order...</div></div>`,allowOutsideClick:false,allowEscapeKey:false,showConfirmButton:false,backdrop:'rgba(0,0,0,0.7)',customClass:{popup:'loading-swal-popup',container:'loading-swal-container'},didOpen:()=>{const c=document.querySelector('.swal2-container');c.setAttribute('tabindex','-1');c.focus();document.querySelectorAll('#checkoutModal input,#checkoutModal textarea').forEach(i=>i.disabled=true);},willClose:()=>{document.querySelectorAll('#checkoutModal input,#checkoutModal textarea').forEach(i=>i.disabled=false);}});
                $.ajax({
                  url:"/StoreDetail/PlaceOrder",type:"POST",contentType:"application/json",
                  data:JSON.stringify({ContactNo:contactNo,CustomerName:customerName,CustomerAddress:customerAddress,Street:street,Floor:floor,Description:description,Items:Object.values(cart),RestaurantId:@Model.RestaurantId}),
                  success:function(res){
                    Swal.close();
                    document.getElementById("orderSuccessMessage").innerHTML=res.message;
                    if(res.statusId===0){document.getElementById("orderStatusGif").src="/Images/GIF/OrderFailed.gif";}
                    else{document.getElementById("orderStatusGif").src="/Images/GIF/OrderSuccess.gif";cart={};renderCart();document.querySelectorAll('[id^="qty-"]').forEach(s=>s.textContent=0);clearCheckoutModalFields();}
                    new bootstrap.Modal(document.getElementById('orderSuccessModal')).show();
                  },
                  error:function(){Swal.close();Swal.fire("Error","Something went wrong.","error");}
                });
              },300);
            });
        }
        function clearCheckoutModalFields(cc=true){
          if(cc) document.getElementById("ContactNo").value="";
          ["CustomerName","CustomerAddress","Street","Floor","Description"].forEach(id=>document.getElementById(id).value="");
        }
        document.getElementById("ContactNo").addEventListener("input",function(){this.value=this.value.replace(/\D/g,'');});
        document.getElementById("ContactNo").addEventListener("blur",function(){
          if(!this.value.trim()) return;
          fetch('/StoreDetail/CustomerExsistOrNo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ContactNo:this.value.trim()})})
            .then(r=>r.json())
            .then(data=>{
              if(data.statusId===1){
                document.getElementById("CustomerName").value=data.customerName||"";
                document.getElementById("CustomerAddress").value=data.customerAddress||"";
                document.getElementById("Street").value=data.street||"";
                document.getElementById("Floor").value=data.floor||"";
                document.getElementById("Description").value=data.description||"";
              }else{clearCheckoutModalFields(false);}
            }).catch(err=>console.error(err));
        });
        document.addEventListener("DOMContentLoaded",function(){
          const inputs=document.querySelectorAll(".next-input");
          inputs.forEach((input,index)=>{
            input.addEventListener("keydown",function(e){
              if(e.key==="Enter"){e.preventDefault();const next=inputs[index+1];next?next.focus():placeOrder();}
            });
          });
        });
    </script>
</body>
</html>
