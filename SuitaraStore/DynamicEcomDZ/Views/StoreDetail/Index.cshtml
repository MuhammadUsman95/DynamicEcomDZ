            <a class="wa-start-btn"
               target="_blank"
               href="https://wa.me/923001234567?text=Assalam%20o%20Alaikum%2C%20I%20want%20to%20place%20an%20order">
                <span class="wa-mini-icon">
                    <svg xmlns="http://www.w3.org/2000/svg"
