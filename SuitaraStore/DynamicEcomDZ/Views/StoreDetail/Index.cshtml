@model DynamicEcomDZ.Models.RestaurantDetailViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@Model.RestaurantName</title>
    <link rel="icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

    {{!-- ✅ Separate CSS file --}}
    <link rel="stylesheet" href="~/css/restaurantdetail.css" />
</head>

<!-- ══════════════ PRODUCT MODAL ══════════════ -->
<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body p-0" style="position:relative;">
                <button class="pmodal-close-btn" onclick="bootstrap.Modal.getInstance(document.getElementById('productModal')).hide()"><i class="bi bi-x-lg"></i></button>
                <div class="pmodal-layout">
                    <div class="pmodal-img-wrap">
                        <span class="pmodal-discount-tag" id="pmodal-discount" style="display:none;"></span>
                        <img id="pmodal-img" src="" alt="" />
                    </div>
                    <div class="pmodal-info">
                        <span class="pmodal-cat-tag"><i class="bi bi-tag-fill"></i><span id="pmodal-category"></span></span>
                        <h4 class="pmodal-name" id="pmodal-name"></h4>
                        <p class="pmodal-desc" id="pmodal-desc"></p>
                        <div class="pmodal-price-row">
                            <span class="pmodal-price" id="pmodal-price"></span>
                            <span class="pmodal-old-price" id="pmodal-old-price" style="display:none;"></span>
                        </div>
                        <div class="pmodal-qty-row">
                            <span class="pmodal-qty-label"><i class="bi bi-basket2"></i> Quantity</span>
                            <div class="pmodal-qty-controls">
                                <button class="pmodal-qty-btn minus" onclick="pmodalQty(-1)">−</button>
                                <span class="pmodal-qty-num" id="pmodal-qty">1</span>
                                <button class="pmodal-qty-btn" onclick="pmodalQty(1)">+</button>
                            </div>
                        </div>
                        <button class="pmodal-add-btn" onclick="pmodalAddToCart()"><i class="bi bi-bag-plus-fill me-2"></i>Add to Cart</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ CLOSED MODAL ══════════════ -->
<div class="modal fade" id="closedModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center">
            <div class="modal-header justify-content-center"><h5 class="modal-title">Store Notice</h5></div>
            <div class="modal-body py-4"></div>
            <div class="modal-footer justify-content-center border-0">
                <button class="btn px-4" style="background:var(--pk);color:#fff;font-weight:700;border-radius:30px;" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ CHECKOUT MODAL ══════════════ -->
<div class="modal fade" id="checkoutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-bag-heart-fill me-2"></i>Complete Your Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-6"><label class="form-label fw-600 small">Contact # *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-telephone"></i></span><input type="text" id="ContactNo" class="form-control next-input" maxlength="15" placeholder="03XXXXXXXXX"></div></div>
                    <div class="col-6"><label class="form-label fw-600 small">Name *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-person"></i></span><input type="text" id="CustomerName" class="form-control next-input" placeholder="Your full name"></div></div>
                    <div class="col-6"><label class="form-label fw-600 small">Street *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-signpost"></i></span><input type="text" id="Street" class="form-control next-input" placeholder="Street no."></div></div>
                    <div class="col-6"><label class="form-label fw-600 small">Block / Floor *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-layers"></i></span><input type="text" id="Floor" class="form-control next-input" placeholder="Block / Floor / House"></div></div>
                    <div class="col-12"><label class="form-label fw-600 small">Full Address *</label><div class="input-group"><span class="input-group-text"><i class="bi bi-house"></i></span><input type="text" id="CustomerAddress" class="form-control next-input" placeholder="Complete delivery address"></div></div>
                    <div class="col-12"><label class="form-label fw-600 small">Special Instructions</label><textarea id="Description" class="form-control next-input" rows="2" placeholder="Any special requests or notes..."></textarea></div>
                </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4">
                <button class="btn btn-secondary px-4" style="border-radius:30px;" data-bs-dismiss="modal"><i class="bi bi-x-circle me-1"></i>Cancel</button>
                <button class="btn px-5" style="background:linear-gradient(135deg,var(--pk),var(--pk-dark));color:#fff;font-weight:700;border-radius:30px;border:none;" onclick="placeOrder()"><i class="bi bi-check2-circle me-1"></i>Place Order</button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ SUCCESS MODAL ══════════════ -->
<div class="modal fade" id="orderSuccessModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">
            <div class="modal-body">
                <img id="orderStatusGif" src="/Images/GIF/OrderSuccess.gif" class="success-gif mb-3" alt="Order Status" />
                <div id="orderSuccessMessage" class="mt-2 fw-600"></div>
            </div>
            <div class="modal-footer justify-content-center border-0 pt-0">
                <button type="button" class="btn px-5" style="background:linear-gradient(135deg,var(--pk),var(--pk-dark));color:#fff;font-weight:700;border-radius:30px;border:none;" data-bs-dismiss="modal">OK, Thank You!</button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ ABOUT MODAL ══════════════ -->
<div class="modal fade" id="aboutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-info-circle-fill me-2"></i>About @Model.RestaurantName</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <p style="font-size:.9rem;color:var(--muted);line-height:1.85;">We are a premier fashion destination offering exquisite <strong>Pakistani Outfits</strong> and <strong>Luxury Bags</strong> collections. With a passion for elegance and craftsmanship, every piece in our collection is curated to bring you the finest in contemporary and traditional fashion.</p>
                <div class="row g-3 mt-2">
                    <div class="col-md-6"><div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:var(--pk-soft);border:1px solid rgba(214,19,109,.15)"><i class="bi bi-patch-check-fill fs-4" style="color:var(--pk)"></i><div><strong class="d-block" style="font-size:.85rem">Premium Quality</strong><span style="font-size:.75rem;color:var(--muted)">Finest fabrics & craftsmanship</span></div></div></div>
                    <div class="col-md-6"><div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:var(--pk-soft);border:1px solid rgba(214,19,109,.15)"><i class="bi bi-truck fs-4" style="color:var(--pk)"></i><div><strong class="d-block" style="font-size:.85rem">Fast Delivery</strong><span style="font-size:.75rem;color:var(--muted)">Swift & safe to your door</span></div></div></div>
                    <div class="col-md-6"><div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:var(--pk-soft);border:1px solid rgba(214,19,109,.15)"><i class="bi bi-arrow-repeat fs-4" style="color:var(--pk)"></i><div><strong class="d-block" style="font-size:.85rem">Easy Returns</strong><span style="font-size:.75rem;color:var(--muted)">Hassle-free return policy</span></div></div></div>
                    <div class="col-md-6"><div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:var(--pk-soft);border:1px solid rgba(214,19,109,.15)"><i class="bi bi-headset fs-4" style="color:var(--pk)"></i><div><strong class="d-block" style="font-size:.85rem">24/7 Support</strong><span style="font-size:.75rem;color:var(--muted)">Always here to help you</span></div></div></div>
                </div>
                <div class="mt-4 p-3 rounded-3 text-center" style="background:linear-gradient(135deg,var(--pk),var(--pk-dark))">
                    <p class="mb-0" style="color:#fff;font-size:.88rem;font-weight:600;">📍 @Model.RestaurantAddress</p>
                </div>
            </div>
        </div>
    </div>
</div>

<body>
    <!-- ══════════════ PROMO BAR ══════════════ -->
    @if (!string.IsNullOrEmpty(Model.SubHeaderTitle))
    {
        <div class="promo-bar" id="promoBar">
            <span><i class="bi bi-truck"></i>@Html.Raw(Model.SubHeaderTitle)</span>
            <span><i class="bi bi-patch-check"></i>Authentic Products</span>
            <span><i class="bi bi-stars"></i>Premium Collections</span>
        </div>
    }

    <!-- ══════════════ NAVBAR ══════════════ -->
    <nav class="main-nav" id="mainNav">
        <div class="nav-inner">
            <a href="/" class="nav-logo"><img src="/images/logo.png" alt="@Model.RestaurantName" /></a>
            <div class="nav-links">
                <a href="#hero" class="nav-link-item active">Home</a>
                <a href="#shop" class="nav-link-item" onclick="scrollTo('shop')">Shop</a>
                <a href="#about" class="nav-link-item" onclick="scrollTo('about')">About</a>
                <a href="#" class="nav-link-item" data-bs-toggle="modal" data-bs-target="#aboutModal">Contact</a>
            </div>
            <div class="nav-right">
                <a href="#shop" class="nav-shop-btn"><i class="bi bi-bag-heart me-1"></i>Shop Now</a>
                <div class="cart-pill" id="cartIcon" onclick="toggleCart()">
                    <i class="bi bi-cart3 cp-icon"></i>
                    <span class="cp-txt">Cart</span>
                    <span class="cp-badge" id="cartCount">0</span>
                </div>
                <div class="nav-hamburger" id="hamburger" onclick="openMenu()">
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
    </nav>

    <!-- Mobile menu -->
    <div class="mobile-menu" id="mobileMenu">
        <button class="mobile-menu-close" onclick="closeMenu()"><i class="bi bi-x-lg"></i></button>
        <a href="#hero" class="m-link" onclick="closeMenu()">Home</a>
        <a href="#shop" class="m-link" onclick="closeMenu()">Shop</a>
        <a href="#about" class="m-link" onclick="closeMenu()">About</a>
        <a href="#" class="m-link" data-bs-toggle="modal" data-bs-target="#aboutModal" onclick="closeMenu()">Contact</a>
        <div class="cart-pill" onclick="toggleCart();closeMenu()" style="margin-top:8px">
            <i class="bi bi-cart3 cp-icon"></i>
            <span class="cp-txt">Cart</span>
            <span class="cp-badge" id="cartCountMobile">0</span>
        </div>
    </div>

    <!-- ══════════════ HERO SLIDER ══════════════ -->
    <section id="hero">
        <div id="heroCarousel" class="hero-slider carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                @for (int i = 0; i < Model.Sliders.Count; i++)
                {
                    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-label="Slide @(i + 1)"></button>
                }
            </div>
            <div class="carousel-inner">
                @for (int i = 0; i < Model.Sliders.Count; i++)
                {
                    var s = Model.Sliders[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")" data-bs-interval="@(s.SliderMovingTimer * 1000)">
                        <div class="hero-slide">
                            <img src="@("/images/SliderRegistration/" + s.SliderName)" class="hero-slide-img" alt="@s.HeadingSlider" />
                            <div class="hero-overlay"></div>
                            <div class="hero-content">
                                <div class="hero-tag"><i class="bi bi-stars"></i>@s.HeadingSlider</div>
                                <h1 class="hero-title">@s.DescriptionSlider</h1>
                                <p class="hero-sub">Discover premium Pakistani fashion — timeless elegance crafted for the modern woman.</p>
                                <div class="hero-btns">
                                    <a href="#shop" class="hero-btn-primary"><i class="bi bi-bag-heart"></i>Shop Collection</a>
                                    <a href="#about" class="hero-btn-outline"><i class="bi bi-play-circle"></i>Our Story</a>
                                </div>
                            </div>
                            <div class="hero-stats">
                                <div class="hstat"><div class="hstat-num">500+</div><div class="hstat-lbl">Products</div></div>
                                <div class="hstat"><div class="hstat-num">10K+</div><div class="hstat-lbl">Happy Clients</div></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
        </div>
    </section>

    <!-- ══════════════ FEATURES STRIP ══════════════ -->
    <div class="features-strip">
        <div class="features-inner">
            <div class="feat-item"><div class="feat-icon"><i class="bi bi-truck"></i></div><div><div class="feat-title">Free Delivery</div><div class="feat-sub">On orders above Rs.3,000</div></div></div>
            <div class="feat-item"><div class="feat-icon"><i class="bi bi-patch-check"></i></div><div><div class="feat-title">100% Authentic</div><div class="feat-sub">Verified quality products</div></div></div>
            <div class="feat-item"><div class="feat-icon"><i class="bi bi-arrow-counterclockwise"></i></div><div><div class="feat-title">Easy Returns</div><div class="feat-sub">7-day hassle-free returns</div></div></div>
            <div class="feat-item"><div class="feat-icon"><i class="bi bi-shield-check"></i></div><div><div class="feat-title">Secure Payment</div><div class="feat-sub">100% safe transactions</div></div></div>
            <div class="feat-item"><div class="feat-icon"><i class="bi bi-headset"></i></div><div><div class="feat-title">24/7 Support</div><div class="feat-sub">Always here for you</div></div></div>
        </div>
    </div>

    <!-- ══════════════ ABOUT SECTION ══════════════ -->
    <section id="about" class="about-section">
        <div class="about-wrap">
            <div class="about-img-col">
                <img src="/images/SliderRegistration/@(Model.Sliders.Count > 0 ? Model.Sliders[0].SliderName : "placeholder.jpg")" class="about-img-main" alt="About Us" />
                <div class="about-badge-float">
                    <div class="about-badge-num">10+</div>
                    <div class="about-badge-txt">Years of<br>Elegance</div>
                </div>
            </div>
            <div class="about-text-col">
                <div class="about-tagline">Our Story</div>
                <h2 class="about-heading">Crafting <em>Elegance</em><br>in Every Stitch</h2>
                <p class="about-body">We are passionate about bringing you the finest in Pakistani fashion — from luxurious Lawn suits to stunning Party wear and exquisite Luxury Bags. Each piece in our collection represents the perfect blend of traditional artistry and contemporary style.</p>
                <div class="about-points">
                    <div class="apoint"><div class="apoint-icon"><i class="bi bi-gem"></i></div><div class="apoint-txt"><strong>Premium Fabric Selection</strong><span>Handpicked finest quality materials from top mills</span></div></div>
                    <div class="apoint"><div class="apoint-icon"><i class="bi bi-palette"></i></div><div class="apoint-txt"><strong>Designer Collections</strong><span>Exclusive designs inspired by heritage & modernity</span></div></div>
                    <div class="apoint"><div class="apoint-icon"><i class="bi bi-star"></i></div><div class="apoint-txt"><strong>Customer Satisfaction</strong><span>Over 10,000 happy customers across Pakistan</span></div></div>
                </div>
                <div class="about-btns">
                    <a href="#shop" class="btn-primary-fill"><i class="bi bi-bag-heart"></i>Shop Now</a>
                    <button class="btn-outline-dark" data-bs-toggle="modal" data-bs-target="#aboutModal"><i class="bi bi-info-circle"></i>Learn More</button>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════ FASHION CONTENT ══════════════ -->
    <section class="fashion-strip">
        <div class="fashion-strip-inner">
            <div class="fashion-grid">
                <div class="fashion-text">
                    <div class="ft-tag">Our Collections</div>
                    <h2 class="fashion-heading">Where <em>Tradition</em><br>Meets Luxury</h2>
                    <p class="fashion-body">Explore our curated collections of Pakistani fashion — each ensemble tells a story of heritage, craftsmanship, and modern elegance. From intricate embroideries to luxurious fabrics, our pieces are designed for women who appreciate true quality.</p>
                    <div class="fashion-pills">
                        <span class="fpill active">Lawn Suits</span>
                        <span class="fpill">Party Wear</span>
                        <span class="fpill">Bridal Collection</span>
                        <span class="fpill">Luxury Bags</span>
                        <span class="fpill">Winter Shawls</span>
                        <span class="fpill">Formal Wear</span>
                    </div>
                    <button class="fashion-cta-btn" onclick="document.getElementById('shop').scrollIntoView({behavior:'smooth'})">
                        <i class="bi bi-arrow-right-circle-fill"></i>Explore All Collections
                    </button>
                </div>
                <div class="fashion-cards">
                    <div class="fcard"><div class="fcard-icon"><i class="bi bi-gem"></i></div><div><div class="fcard-title">Luxury Fabrics</div><div class="fcard-sub">Premium Swiss lawn, chiffon, silk & velvet collections</div></div></div>
                    <div class="fcard"><div class="fcard-icon"><i class="bi bi-award"></i></div><div><div class="fcard-title">Award-Winning Designs</div><div class="fcard-sub">Recognized for excellence in Pakistani fashion</div></div></div>
                    <div class="fcard"><div class="fcard-icon"><i class="bi bi-box-seam"></i></div><div><div class="fcard-title">Elegant Packaging</div><div class="fcard-sub">Premium gift-ready packaging for every order</div></div></div>
                    <div class="fcard"><div class="fcard-icon"><i class="bi bi-lightning-charge"></i></div><div><div class="fcard-title">New Arrivals Weekly</div><div class="fcard-sub">Fresh collections added every week</div></div></div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════ SHOP SECTION ══════════════ -->
    <section id="shop" class="shop-section">
        <div class="shop-wrap">
            <div class="sec-hd">
                <div class="sec-hd-tag">Our Products</div>
                <h2 class="sec-title">Shop the Collection</h2>
                <p class="sec-sub">Discover our full range of premium Pakistani fashion and luxury accessories</p>
            </div>

            <div class="shop-bar">
                <div class="shop-bar-left">
                    <div>
                        <div class="shop-bar-name">@Model.RestaurantName</div>
                        <div class="shop-bar-addr"><i class="bi bi-geo-alt-fill"></i>@Model.RestaurantAddress</div>
                    </div>
                </div>
                <div class="filter-row">
                    <input type="text" id="productSearch" class="form-control form-control-sm" placeholder="🔍 Search products..." style="min-width:180px">
                    <select id="categoryFilter" class="form-select form-select-sm">
                        <option value="all">All Categories</option>
                        @foreach (var category in Model.Products.Keys)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>
            </div>

            @* ✅ Product cards now rendered via partial *@
            @foreach (var category in Model.Products)
            {
                <div class="cat-title-row">
                    <span class="cat-title-badge"><i class="bi bi-grid-fill"></i>@category.Key</span>
                </div>
                <div class="row g-3">
                    @foreach (var product in category.Value)
                    {
                        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 col-6 product-card-item"
                             data-product-name="@product.ProductName.ToLower()">
                            @await Html.PartialAsync("_ProductCard", product)
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <!-- ══════════════ TESTIMONIALS ══════════════ -->
    <section class="testimonial-section">
        <div class="test-wrap">
            <div class="sec-hd">
                <div class="sec-hd-tag">Happy Customers</div>
                <h2 class="sec-title">What Our Clients Say</h2>
                <p class="sec-sub">Real reviews from our valued customers across Pakistan</p>
            </div>
            <div class="test-grid">
                <div class="tcard"><div class="tcard-stars"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i></div><p class="tcard-text">"Absolutely stunning quality! The lawn suit I ordered was exactly as shown — beautiful embroidery and excellent fabric. Will definitely order again."</p><div class="tcard-author"><div class="tcard-avatar">AK</div><div><div class="tcard-name">Ayesha Khan</div><div class="tcard-loc">Karachi, Pakistan</div></div></div></div>
                <div class="tcard"><div class="tcard-stars"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i></div><p class="tcard-text">"The luxury bag collection is exceptional! Authentic quality, beautiful packaging, and fast delivery. Highly recommend to every fashion lover."</p><div class="tcard-author"><div class="tcard-avatar">SR</div><div><div class="tcard-name">Sara Raza</div><div class="tcard-loc">Lahore, Pakistan</div></div></div></div>
                <div class="tcard"><div class="tcard-stars"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i></div><p class="tcard-text">"Best bridal wear I found! The party wear collection is just breathtaking. Customer service was excellent and delivery was prompt."</p><div class="tcard-author"><div class="tcard-avatar">MF</div><div><div class="tcard-name">Mahnoor Fatima</div><div class="tcard-loc">Islamabad, Pakistan</div></div></div></div>
            </div>
        </div>
    </section>

    <!-- ══════════════ NEWSLETTER ══════════════ -->
    <section class="newsletter-section">
        <div class="nl-inner">
            <div class="nl-icon"><i class="bi bi-envelope-heart"></i></div>
            <h2 class="nl-title">Stay in Style</h2>
            <p class="nl-sub">Subscribe for exclusive access to new arrivals, special offers, and fashion inspiration delivered to your inbox.</p>
            <div class="nl-form">
                <input type="email" placeholder="Enter your email address..." />
                <button type="button" onclick="Swal.fire({icon:'success',title:'Subscribed!',text:'Thank you! You\'ll receive our latest updates.',confirmButtonColor:'#D6136D'})"><i class="bi bi-send me-1"></i>Subscribe</button>
            </div>
        </div>
    </section>

    <!-- ══════════════ CART DRAWER ══════════════ -->
    <div id="cartDrawer" class="cart-drawer">
        <div class="cart-header">
            <h4><i class="bi bi-bag-heart-fill"></i>Your Cart <span id="cartHeaderCount" style="background:rgba(255,255,255,.2);color:#fff;font-size:.62rem;font-weight:800;padding:2px 8px;border-radius:20px;margin-left:4px;display:none;"></span></h4>
            <button class="cart-close-btn" onclick="toggleCart()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div id="cartItemsContainer" class="cart-items-scroll">
            <div class="cart-empty-state">
                <div class="cart-empty-icon"><i class="bi bi-cart-x"></i></div>
                <div class="cart-empty-text">Your cart is empty</div>
                <div style="font-size:.74rem;color:var(--muted);margin-top:4px;">Add beautiful items to get started</div>
            </div>
        </div>
        <div id="cartTotal" class="cart-total" style="display:none;"></div>
        <div class="checkout-wrapper">
            <button class="btn w-100" onclick="openCheckoutModal()"><i class="bi bi-lightning-charge-fill"></i>Proceed to Checkout</button>
        </div>
    </div>
    <div id="cartBackdrop" class="cart-backdrop" onclick="toggleCart()"></div>

    <!-- ══════════════ FOOTER ══════════════ -->
    <footer class="site-footer">
        <div class="footer-top">
            <div class="footer-brand">
                <a href="/"><img src="/images/logo.png" alt="Logo" style="height:50px;width:auto;object-fit:contain;filter:brightness(0) invert(1);" /></a>
                <p>Premium Pakistani fashion destination — where elegance meets tradition. Curating the finest outfits and luxury bags for the modern woman.</p>
                <div class="footer-socials">
                    <a href="https://www.facebook.com/share/1Buimi6joN/" target="_blank" class="fsoc"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="fsoc"><i class="bi bi-instagram"></i></a>
                    <a href="https://api.whatsapp.com/send?phone=923002222662" target="_blank" class="fsoc"><i class="bi bi-whatsapp"></i></a>
                    <a href="#" class="fsoc"><i class="bi bi-tiktok"></i></a>
                </div>
            </div>
            <div class="footer-col">
                <h5>Collections</h5>
                <ul>
                    @foreach (var category in Model.Products.Keys)
                    {
                        <li><a href="#shop" onclick="document.getElementById('categoryFilter').value='@category';document.getElementById('categoryFilter').dispatchEvent(new Event('change'))"><i class="bi bi-chevron-right"></i>@category</a></li>
                    }
                </ul>
            </div>
            <div class="footer-col">
                <h5>Quick Links</h5>
                <ul>
                    <li><a href="#hero"><i class="bi bi-chevron-right"></i>Home</a></li>
                    <li><a href="#shop"><i class="bi bi-chevron-right"></i>Shop</a></li>
                    <li><a href="#about"><i class="bi bi-chevron-right"></i>About Us</a></li>
                    <li><a href="#" data-bs-toggle="modal" data-bs-target="#aboutModal"><i class="bi bi-chevron-right"></i>Contact</a></li>
                    <li><a href="#" onclick="toggleCart()"><i class="bi bi-chevron-right"></i>View Cart</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h5>Get in Touch</h5>
                <div class="footer-contact-item"><div class="fc-icon"><i class="bi bi-telephone-fill"></i></div><div><div class="fc-label">Phone</div><a href="tel:+923002222662" class="fc-val">+92-300-2222662</a></div></div>
                <div class="footer-contact-item"><div class="fc-icon"><i class="bi bi-whatsapp"></i></div><div><div class="fc-label">WhatsApp</div><a href="https://api.whatsapp.com/send?phone=923002222662" target="_blank" class="fc-val">Chat with Us</a></div></div>
                <div class="footer-contact-item"><div class="fc-icon"><i class="bi bi-geo-alt-fill"></i></div><div><div class="fc-label">Address</div><span class="fc-val">@Model.RestaurantAddress</span></div></div>
                <div class="footer-contact-item"><div class="fc-icon"><i class="bi bi-clock-fill"></i></div><div><div class="fc-label">Hours</div><span class="fc-val">Mon–Sat: 10am–8pm</span></div></div>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year @Model.RestaurantName. All rights reserved.</span>
            <span style="color:rgba(214,19,109,.5)">|</span>
            <span>Developed by <strong style="color:rgba(214,19,109,.7)">UT Designer</strong></span>
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Service</a>
        </div>
    </footer>

    <!-- Back to Top -->
    <button class="back-top" id="backTop" onclick="window.scrollTo({top:0,behavior:'smooth'})"><i class="bi bi-chevron-up"></i></button>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ── PROMO + NAV OFFSET ──
        document.addEventListener("DOMContentLoaded", function(){
          const promo = document.getElementById("promoBar");
          const nav   = document.getElementById("mainNav");
          if(promo && nav) nav.style.top = promo.offsetHeight + "px";
        });

        // ── BACK TO TOP ──
        window.addEventListener("scroll",function(){
          const bt = document.getElementById("backTop");
          bt.classList.toggle("show", window.scrollY > 400);
        });

        // ── MOBILE MENU ──
        function openMenu(){ document.getElementById("mobileMenu").classList.add("open"); document.body.style.overflow="hidden"; }
        function closeMenu(){ document.getElementById("mobileMenu").classList.remove("open"); document.body.style.overflow=""; }

        // ── SMOOTH SCROLL ──
        document.querySelectorAll('a[href^="#"]').forEach(a=>{
          a.addEventListener("click",function(e){
            const t = document.querySelector(this.getAttribute("href"));
            if(t){ e.preventDefault(); t.scrollIntoView({behavior:"smooth"}); }
          });
        });

        // ── NAV ACTIVE ON SCROLL ──
        window.addEventListener("scroll",function(){
          const sections=["hero","about","shop"];
          sections.forEach(id=>{
            const sec=document.getElementById(id);
            if(!sec) return;
            const r=sec.getBoundingClientRect();
            if(r.top<=100&&r.bottom>100){
              document.querySelectorAll(".nav-link-item").forEach(l=>l.classList.remove("active"));
              const al=document.querySelector(`.nav-link-item[href="#${id}"]`);
              if(al) al.classList.add("active");
            }
          });
        });

        // ── SLIDER ANIMATION ──
        document.getElementById('heroCarousel').addEventListener('slide.bs.carousel',function(e){
          const inc=e.relatedTarget; if(!inc) return;
          inc.querySelectorAll('.hero-tag,.hero-title,.hero-sub,.hero-btns').forEach(el=>{
            el.style.animation='none'; el.style.opacity='0'; void el.offsetWidth; el.style.animation='';
          });
        });

        // ── FILTER ──
        document.addEventListener("DOMContentLoaded",function(){
          const si=document.getElementById("productSearch");
          const cf=document.getElementById("categoryFilter");
          function filter(){
            const q=si.value.toLowerCase(), c=cf.value.toLowerCase();
            document.querySelectorAll("#shop .row").forEach(row=>{
              const prev=row.previousElementSibling; if(!prev) return;
              const badge=prev.querySelector(".cat-title-badge"); if(!badge) return;
              const cat=badge.innerText.toLowerCase().replace(/^\W+/,'').trim();
              const catOk=c==="all"||cat.includes(c);
              let vis=false;
              row.querySelectorAll(".product-card-item").forEach(card=>{
                const ok=card.dataset.productName.includes(q)&&catOk;
                card.style.display=ok?"block":"none"; if(ok) vis=true;
              });
              row.style.display=vis?"flex":"none";
              prev.style.display=vis?"flex":"none";
            });
          }
          si.addEventListener("keyup",filter);
          cf.addEventListener("change",filter);
        });

        // ── FASHION PILLS ──
        document.querySelectorAll(".fpill").forEach(p=>{
          p.addEventListener("click",function(){
            document.querySelectorAll(".fpill").forEach(x=>x.classList.remove("active"));
            this.classList.add("active");
          });
        });

        // ── PRODUCT DATA ──
        const productMaster = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Products.SelectMany(x => x.Value)));
        function getProductByCode(code){ return productMaster.find(p=>p.ProductCode===code); }
        let cart={};

        // ── PRODUCT MODAL ──
        let pmodalCode=null;
        function openProductModal(productCode){
          const p=getProductByCode(productCode); if(!p) return;
          pmodalCode=productCode;
          document.getElementById('pmodal-img').src='/images/ProductRegistration/'+p.ProductImage;
          document.getElementById('pmodal-img').alt=p.ProductName;
          const discEl=document.getElementById('pmodal-discount');
          if(p.DiscountAmount>0){discEl.textContent='−Rs.'+fmt(p.DiscountAmount)+' OFF';discEl.style.display='inline-block';}
          else{discEl.style.display='none';}
          document.getElementById('pmodal-category').textContent=p.Category||'';
          document.getElementById('pmodal-name').textContent=p.ProductName;
          document.getElementById('pmodal-desc').textContent=p.ProductDescription||'Premium quality fashion product.';
          const net=(p.Prices||0)-(p.DiscountAmount||0);
          document.getElementById('pmodal-price').textContent='Rs. '+fmt(net);
          const oldEl=document.getElementById('pmodal-old-price');
          if(p.DiscountAmount>0){oldEl.textContent='Rs. '+fmt(p.Prices);oldEl.style.display='inline';}
          else{oldEl.style.display='none';}
          const cardQty=parseInt(document.getElementById('qty-'+productCode)?.textContent)||0;
          document.getElementById('pmodal-qty').textContent=Math.max(cardQty,1);
          new bootstrap.Modal(document.getElementById('productModal')).show();
        }
        function pmodalQty(d){
          const el=document.getElementById('pmodal-qty');
          el.textContent=Math.max(1,parseInt(el.textContent)+d);
        }
        function pmodalAddToCart(){
          if(!pmodalCode) return;
          const qty=parseInt(document.getElementById('pmodal-qty').textContent)||1;
          const p=getProductByCode(pmodalCode); if(!p) return;
          const cardQtyEl=document.getElementById('qty-'+pmodalCode);
          if(cardQtyEl) cardQtyEl.textContent=qty;
          cart[pmodalCode]={ProductCode:pmodalCode,ProductName:p.ProductName,Quantity:qty,Rate:p.Prices,DiscountAmount:p.DiscountAmount,DeliveryCharges:p.DeliveryCharges,image:p.ProductImage};
          renderCart();
          bootstrap.Modal.getInstance(document.getElementById('productModal')).hide();
          const icon=document.getElementById('cartIcon');
          icon.style.background='var(--pk)';
          setTimeout(()=>{icon.style.background='';},700);
          Swal.fire({toast:true,position:'top-end',icon:'success',title:'Added to cart!',showConfirmButton:false,timer:1800,timerProgressBar:true,customClass:{popup:'swal2-toast'}});
        }

        // ── CART ──
        function changeQuantity(productCode,productName,delta){
          const qtySpan=document.getElementById('qty-'+productCode);
          let newQty=Math.max(0,(parseInt(qtySpan.textContent)||0)+delta);
          qtySpan.textContent=newQty;
          const product=getProductByCode(productCode); if(!product) return;
          if(delta>0) flyToCart(productCode);
          if(newQty===0){delete cart[productCode];}
          else{cart[productCode]={ProductCode:productCode,ProductName:product.ProductName,Quantity:newQty,Rate:product.Prices,DiscountAmount:product.DiscountAmount,DeliveryCharges:product.DeliveryCharges,image:product.ProductImage};}
          renderCart();
        }
        function flyToCart(productCode){
          const img=document.getElementById('img-'+productCode);
          const cartIcon=document.getElementById('cartIcon');
          if(!img||!cartIcon) return;
          const ir=img.getBoundingClientRect(),cr=cartIcon.getBoundingClientRect();
          const fi=img.cloneNode(true);
          fi.style.cssText=`position:fixed;z-index:9999;pointer-events:none;border-radius:10px;transition:all .7s cubic-bezier(.4,0,.2,1);left:${ir.left}px;top:${ir.top}px;width:${ir.width}px;height:${ir.height}px;`;
          document.body.appendChild(fi);
          requestAnimationFrame(()=>{Object.assign(fi.style,{left:cr.left+"px",top:cr.top+"px",width:"30px",height:"30px",opacity:"0"});});
          fi.addEventListener("transitionend",()=>fi.remove());
        }
        function renderCart(){
          const container=document.getElementById("cartItemsContainer");
          const totalDiv=document.getElementById("cartTotal");
          container.innerHTML="";
          const items=Object.values(cart);
          if(items.length===0){
            container.innerHTML=`<div class="cart-empty-state"><div class="cart-empty-icon"><i class="bi bi-cart-x"></i></div><div class="cart-empty-text">Your cart is empty</div><div style="font-size:.74rem;color:var(--muted);margin-top:4px;">Add beautiful items to get started</div></div>`;
            totalDiv.style.display="none"; updateCartCount(); return;
          }
          let tg=0,td=0,tq=0,dc=0;
          items.forEach(item=>{
            if(dc===0&&item.DeliveryCharges!==undefined) dc=Number(item.DeliveryCharges);
            const r=item.Quantity*item.Rate,d=item.Quantity*item.DiscountAmount,net=r-d;
            tg+=r;td+=d;tq+=item.Quantity;
            const unitDisplay=item.DiscountAmount>0
              ?`<span style="color:var(--pk);font-weight:700;">${fmt(item.Rate-item.DiscountAmount)}</span> <span style="text-decoration:line-through;color:#dc3545;opacity:.7;">${fmt(item.Rate)}</span>`
              :`<span style="color:var(--muted);">${fmt(item.Rate)}</span>`;
            container.innerHTML+=`
              <div class="cart-item">
                <img src="/images/ProductRegistration/${item.image}" class="cart-item-img"/>
                <div class="cart-item-info"><strong>${item.ProductName}</strong><div class="cart-item-price-unit">Unit: ${unitDisplay}</div></div>
                <div class="cart-item-right">
                  <div class="cart-item-total">Rs.${fmt(net)}</div>
                  <div class="cart-qty-box">
                    <button class="cart-qty-btn minus" onclick="changeQuantity('${item.ProductCode}','${item.ProductName}',-1)">−</button>
                    <span class="cart-qty-num">${item.Quantity}</span>
                    <button class="cart-qty-btn" onclick="changeQuantity('${item.ProductCode}','${item.ProductName}',1)">+</button>
                  </div>
                </div>
              </div>`;
          });
          const np=(tg-td)+dc;
          totalDiv.style.display="block";
          totalDiv.innerHTML=`<div class="cart-total-inner">
            <div class="total-row"><span class="lbl"><i class="bi bi-bag"></i>Items</span><span class="val">${tq}</span></div>
            <div class="total-row"><span class="lbl"><i class="bi bi-receipt"></i>Subtotal</span><span class="val">Rs.${fmt(tg)}</span></div>
            ${td>0?`<div class="total-row discount"><span class="lbl"><i class="bi bi-tag"></i>Discount</span><span class="val">−Rs.${fmt(td)}</span></div>`:''}
            <div class="total-row"><span class="lbl"><i class="bi bi-truck"></i>Delivery</span><span class="val">${dc===0?`<span class="free-delivery">Free</span>`:`<span class="delivery-fee">Rs.${fmt(dc)}</span>`}</span></div>
            <div class="total-row net"><span class="lbl">Total Payable</span><span class="val">Rs.${fmt(np)}</span></div>
          </div>`;
          updateCartCount();
        }
        function fmt(v){return Number(v).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0});}
        function updateCartCount(){
          let c=0; Object.values(cart).forEach(x=>c+=x.Quantity);
          document.getElementById('cartCount').textContent=c;
          const mb=document.getElementById('cartCountMobile');
          if(mb) mb.textContent=c;
          const hBadge=document.getElementById('cartHeaderCount');
          if(c>0){hBadge.textContent=c+' items';hBadge.style.display='inline';}
          else{hBadge.style.display='none';}
        }
        function toggleCart(){
          document.getElementById('cartDrawer').classList.toggle('open');
          document.getElementById('cartBackdrop').classList.toggle('show');
        }

        // ── CHECKOUT ──
        function openCheckoutModal(){
          if(Object.values(cart).length===0){Swal.fire({icon:'warning',title:'Cart Empty',text:'Please add items first.',confirmButtonColor:'#D6136D'});return;}
          document.getElementById('cartDrawer').classList.remove('open');
          document.getElementById('cartBackdrop').classList.remove('show');
          fetch('/StoreDetail/CheckRestaurantValidation',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({RestaurantId:@Model.RestaurantId})})
            .then(r=>r.json())
            .then(data=>{
              if(data.statusId===0){document.querySelector('#closedModal .modal-title').innerText='Order Not Allowed';document.querySelector('#closedModal .modal-body').innerHTML=data.message;new bootstrap.Modal(document.getElementById('closedModal')).show();return;}
              new bootstrap.Modal(document.getElementById('checkoutModal')).show();
            })
            .catch(()=>Swal.fire('Error','Server validation failed.','error'));
        }
        function placeOrder(){
          const contactNo=document.getElementById("ContactNo").value.trim();
          const customerName=document.getElementById("CustomerName").value.trim();
          const customerAddress=document.getElementById("CustomerAddress").value.trim();
          const street=document.getElementById("Street").value.trim();
          const floor=document.getElementById("Floor").value.trim();
          const description=document.getElementById("Description").value.trim();
          if(!contactNo||contactNo.length<9){Swal.fire("Validation","Contact No must be at least 9 digits.","error");return;}
          if(!customerName||!customerAddress||!street||!floor){Swal.fire("Validation","All fields are mandatory except Description.","error");return;}
          Swal.fire({title:"Confirm Order",text:"Are you sure you want to place this order?",icon:"question",showCancelButton:true,confirmButtonText:"Yes, Place Order",cancelButtonText:"Cancel",confirmButtonColor:"#D6136D",cancelButtonColor:"#6c757d",reverseButtons:true,focusCancel:true})
            .then(result=>{
              if(!result.isConfirmed) return;
              bootstrap.Modal.getInstance(document.getElementById('checkoutModal')).hide();
              setTimeout(()=>{
                Swal.fire({title:"Processing...",html:`<div style="text-align:center"><img src="/Images/GIF/OrderPlaced.gif" style="width:120px;height:120px;border-radius:50%;margin-bottom:12px;"/><div style="font-weight:700;color:#333;">Placing your order...</div></div>`,allowOutsideClick:false,allowEscapeKey:false,showConfirmButton:false,backdrop:'rgba(0,0,0,0.7)',customClass:{popup:'loading-swal-popup',container:'loading-swal-container'},didOpen:()=>{const c=document.querySelector('.swal2-container');c.setAttribute('tabindex','-1');c.focus();document.querySelectorAll('#checkoutModal input,#checkoutModal textarea').forEach(i=>i.disabled=true);},willClose:()=>{document.querySelectorAll('#checkoutModal input,#checkoutModal textarea').forEach(i=>i.disabled=false);}});
                $.ajax({
                  url:"/StoreDetail/PlaceOrder",type:"POST",contentType:"application/json",
                  data:JSON.stringify({ContactNo:contactNo,CustomerName:customerName,CustomerAddress:customerAddress,Street:street,Floor:floor,Description:description,Items:Object.values(cart),RestaurantId:@Model.RestaurantId}),
                  success:function(res){
                    Swal.close();
                    document.getElementById("orderSuccessMessage").innerHTML=res.message;
                    if(res.statusId===0){document.getElementById("orderStatusGif").src="/Images/GIF/OrderFailed.gif";}
                    else{document.getElementById("orderStatusGif").src="/Images/GIF/OrderSuccess.gif";cart={};renderCart();document.querySelectorAll('[id^="qty-"]').forEach(s=>s.textContent=0);clearCheckoutModalFields();}
                    new bootstrap.Modal(document.getElementById('orderSuccessModal')).show();
                  },
                  error:function(){Swal.close();Swal.fire("Error","Something went wrong.","error");}
                });
              },300);
            });
        }
        function clearCheckoutModalFields(cc=true){
          if(cc) document.getElementById("ContactNo").value="";
          ["CustomerName","CustomerAddress","Street","Floor","Description"].forEach(id=>document.getElementById(id).value="");
        }
        document.getElementById("ContactNo").addEventListener("input",function(){this.value=this.value.replace(/\D/g,'');});
        document.getElementById("ContactNo").addEventListener("blur",function(){
          if(!this.value.trim()) return;
          fetch('/StoreDetail/CustomerExsistOrNo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ContactNo:this.value.trim()})})
            .then(r=>r.json())
            .then(data=>{
              if(data.statusId===1){
                document.getElementById("CustomerName").value=data.customerName||"";
                document.getElementById("CustomerAddress").value=data.customerAddress||"";
                document.getElementById("Street").value=data.street||"";
                document.getElementById("Floor").value=data.floor||"";
                document.getElementById("Description").value=data.description||"";
              }else{clearCheckoutModalFields(false);}
            }).catch(err=>console.error(err));
        });
        document.addEventListener("DOMContentLoaded",function(){
          const inputs=document.querySelectorAll(".next-input");
          inputs.forEach((input,index)=>{
            input.addEventListener("keydown",function(e){
              if(e.key==="Enter"){e.preventDefault();const next=inputs[index+1];next?next.focus():placeOrder();}
            });
          });
        });
    </script>
</body>
</html>
