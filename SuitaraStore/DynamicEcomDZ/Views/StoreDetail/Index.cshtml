@model DynamicEcomDZ.Models.RestaurantDetailViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@Model.RestaurantName</title>
    <link rel="icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <style>
        :root {
            --pk: #D6136D;
            --pk-dark: #A30F52;
            --pk-soft: #fce8f2;
            --pk-mid: rgba(214,19,109,.12);
            --gold: #c9a84c;
            --bg: #fafafa;
            --dark: #1a1a2e;
            --muted: #7a7a8c;
            --white: #ffffff;
            --footer: #0f0f1a;
            --radius: 14px;
            --tr: all .35s cubic-bezier(.4,0,.2,1);
            --shadow: 0 8px 32px rgba(214,19,109,.15);
            --display: 'Cormorant Garamond', Georgia, serif;
            --body: 'Jost', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        /* ── SCROLLBAR ── */
        ::-webkit-scrollbar {
            width: 5px
        }

        ::-webkit-scrollbar-track {
            background: #f0f0f0
        }

        ::-webkit-scrollbar-thumb {
            background: var(--pk);
            border-radius: 10px
        }

        body {
            background: var(--bg);
            font-family: var(--body);
            color: var(--dark);
            overflow-x: hidden
        }

        /* ─────────────── PROMO BAR ─────────────── */
        .promo-bar {
            background: var(--pk);
            color: #fff;
            font-size: .75rem;
            font-weight: 500;
            letter-spacing: .08em;
            text-align: center;
            padding: 8px 12px;
            position: sticky;
            top: 0;
            z-index: 1070;
        }

            .promo-bar span {
                margin: 0 18px
            }

            .promo-bar i {
                color: rgba(255,255,255,.7);
                margin-right: 5px
            }

        /* ─────────────── NAVBAR ─────────────── */
        .main-nav {
            background: #fff;
            border-bottom: 1.5px solid rgba(214,19,109,.12);
            position: sticky;
            top: 36px;
            z-index: 1060;
            box-shadow: 0 2px 24px rgba(214,19,109,.08);
        }

        .nav-inner {
            max-width: 1280px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            height: 70px;
        }

        .nav-logo img {
            height: 48px;
            width: auto;
            object-fit: contain;
            transition: var(--tr)
        }

            .nav-logo img:hover {
                transform: scale(1.04)
            }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 6px
        }

        .nav-link-item {
            font-size: .82rem;
            font-weight: 600;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: var(--dark);
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 8px;
            transition: var(--tr);
            position: relative;
        }

            .nav-link-item::after {
                content: '';
                position: absolute;
                bottom: 4px;
                left: 50%;
                right: 50%;
                height: 2px;
                background: var(--pk);
                border-radius: 2px;
                transition: var(--tr);
            }

            .nav-link-item:hover {
                color: var(--pk)
            }

                .nav-link-item:hover::after {
                    left: 16px;
                    right: 16px
                }

            .nav-link-item.active {
                color: var(--pk)
            }

                .nav-link-item.active::after {
                    left: 16px;
                    right: 16px
                }

        .nav-shop-btn {
            background: var(--pk);
            color: #fff;
            font-size: .8rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            padding: 10px 22px;
            border-radius: 30px;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: var(--tr);
            box-shadow: 0 4px 16px rgba(214,19,109,.3);
        }

            .nav-shop-btn:hover {
                background: var(--pk-dark);
                color: #fff;
                transform: translateY(-2px)
            }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 14px
        }

        .cart-pill {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--pk-soft);
            border: 1.5px solid rgba(214,19,109,.2);
            border-radius: 30px;
            padding: 7px 16px;
            cursor: pointer;
            transition: var(--tr);
        }

            .cart-pill:hover {
                background: var(--pk);
                border-color: var(--pk)
            }

                .cart-pill:hover .cp-icon, .cart-pill:hover .cp-txt {
                    color: #fff
                }

        .cp-icon {
            font-size: 1.1rem;
            color: var(--pk);
            transition: var(--tr)
        }

        .cp-txt {
            font-size: .8rem;
            font-weight: 700;
            color: var(--pk);
            transition: var(--tr)
        }

        .cp-badge {
            background: var(--pk);
            color: #fff;
            font-size: .65rem;
            font-weight: 800;
            padding: 2px 7px;
            border-radius: 20px;
            border: 2px solid #fff;
            transition: var(--tr);
        }

        .cart-pill:hover .cp-badge {
            background: #fff;
            color: var(--pk);
            border-color: var(--pk)
        }

        .nav-hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 6px
        }

            .nav-hamburger span {
                display: block;
                width: 22px;
                height: 2px;
                background: var(--dark);
                border-radius: 2px;
                transition: var(--tr)
            }

        .mobile-menu {
            display: none;
            position: fixed;
            inset: 0;
            background: #fff;
            z-index: 9000;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 28px;
        }

            .mobile-menu.open {
                display: flex
            }

            .mobile-menu .m-link {
                font-family: var(--display);
                font-size: 2rem;
                font-weight: 600;
                color: var(--dark);
                text-decoration: none;
                letter-spacing: .04em;
                transition: var(--tr);
            }

                .mobile-menu .m-link:hover {
                    color: var(--pk)
                }

        .mobile-menu-close {
            position: absolute;
            top: 24px;
            right: 24px;
            font-size: 1.6rem;
            cursor: pointer;
            color: var(--dark);
            background: var(--pk-soft);
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--tr);
            border: none;
        }

            .mobile-menu-close:hover {
                background: var(--pk);
                color: #fff
            }

        @@media(max-width:900px) {
            .nav-links, .nav-shop-btn {
                display: none
            }

            .nav-hamburger {
                display: flex
            }
        }

        @@media(max-width:576px) {
            .nav-inner {
                padding: 0 16px
            }
        }

        /* ─────────────── HERO SLIDER ─────────────── */
        .hero-slider {
            position: relative;
            overflow: hidden
        }

            .hero-slider .carousel-inner {
            }

        .hero-slide {
            position: relative;
            height: 620px;
            overflow: hidden;
            display: flex;
            align-items: flex-end;
        }

        .hero-slide-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 8s ease;
        }

        .carousel-item.active .hero-slide-img {
            transform: scale(1.06)
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(105deg,rgba(15,15,26,.85) 0%,rgba(214,19,109,.18) 55%,rgba(0,0,0,.1) 100%);
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            padding: 0 60px 70px;
            max-width: 640px;
        }

        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--pk);
            color: #fff;
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .18em;
            text-transform: uppercase;
            padding: 5px 18px;
            border-radius: 30px;
            margin-bottom: 20px;
            opacity: 0;
        }

        .carousel-item.active .hero-tag {
            animation: fadeUp .5s ease .2s forwards
        }

        .hero-title {
            font-family: var(--display);
            font-size: 4rem;
            font-weight: 700;
            line-height: 1.05;
            color: #fff;
            margin-bottom: 18px;
            text-shadow: 0 4px 32px rgba(0,0,0,.4);
            opacity: 0;
        }

        .carousel-item.active .hero-title {
            animation: fadeUp .6s ease .4s forwards
        }

        .hero-sub {
            font-size: .9rem;
            color: rgba(255,255,255,.75);
            line-height: 1.7;
            margin-bottom: 32px;
            opacity: 0;
        }

        .carousel-item.active .hero-sub {
            animation: fadeUp .6s ease .55s forwards
        }

        .hero-btns {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            opacity: 0
        }

        .carousel-item.active .hero-btns {
            animation: fadeUp .6s ease .7s forwards
        }

        .hero-btn-primary {
            background: var(--pk);
            color: #fff;
            border: none;
            font-size: .85rem;
            font-weight: 700;
            letter-spacing: .07em;
            text-transform: uppercase;
            padding: 14px 32px;
            border-radius: 30px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: var(--tr);
            box-shadow: 0 6px 24px rgba(214,19,109,.4);
        }

            .hero-btn-primary:hover {
                background: var(--pk-dark);
                color: #fff;
                transform: translateY(-3px)
            }

        .hero-btn-outline {
            background: transparent;
            color: #fff;
            border: 1.5px solid rgba(255,255,255,.5);
            font-size: .85rem;
            font-weight: 600;
            letter-spacing: .07em;
            text-transform: uppercase;
            padding: 14px 32px;
            border-radius: 30px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: var(--tr);
        }

            .hero-btn-outline:hover {
                background: rgba(255,255,255,.12);
                border-color: #fff;
                color: #fff
            }

        /* Slider side stats */
        .hero-stats {
            position: absolute;
            right: 48px;
            bottom: 70px;
            z-index: 3;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .hstat {
            background: rgba(255,255,255,.1);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,.15);
            border-radius: 12px;
            padding: 12px 18px;
            text-align: center;
        }

        .hstat-num {
            font-family: var(--display);
            font-size: 1.6rem;
            font-weight: 700;
            color: #fff;
            line-height: 1
        }

        .hstat-lbl {
            font-size: .65rem;
            color: rgba(255,255,255,.6);
            letter-spacing: .1em;
            text-transform: uppercase;
            margin-top: 2px
        }

        /* Controls */
        .hero-slider .carousel-control-prev,
        .hero-slider .carousel-control-next {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,.12);
            backdrop-filter: blur(10px);
            border-radius: 50%;
            top: 50%;
            bottom: auto;
            transform: translateY(-50%);
            margin: 0 20px;
            opacity: 0;
            border: 1px solid rgba(255,255,255,.2);
            transition: var(--tr);
        }

        .hero-slider:hover .carousel-control-prev,
        .hero-slider:hover .carousel-control-next {
            opacity: 1
        }

        .hero-slider .carousel-control-prev:hover,
        .hero-slider .carousel-control-next:hover {
            background: var(--pk);
            border-color: var(--pk)
        }

        .hero-slider .carousel-indicators {
            margin-bottom: 28px;
            gap: 8px
        }

            .hero-slider .carousel-indicators button {
                width: 32px;
                height: 3px;
                border-radius: 3px;
                background: rgba(255,255,255,.3);
                border: none;
                padding: 0;
                transition: var(--tr);
            }

            .hero-slider .carousel-indicators .active {
                width: 52px;
                background: var(--pk)
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(28px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        @@media(max-width:900px) {
            .hero-slide {
                height: 480px
            }

            .hero-content {
                padding: 0 32px 56px;
                max-width: 100%
            }

            .hero-title {
                font-size: 2.8rem
            }

            .hero-stats {
                display: none
            }
        }

        @@media(max-width:576px) {
            .hero-slide {
                height: 360px
            }

            .hero-content {
                padding: 0 20px 48px
            }

            .hero-title {
                font-size: 2rem
            }

            .hero-sub {
                display: none
            }
        }

        /* ─────────────── FEATURES STRIP ─────────────── */
        .features-strip {
            background: #fff;
            border-bottom: 1px solid rgba(214,19,109,.1);
            padding: 22px 0;
            box-shadow: 0 4px 24px rgba(214,19,109,.06);
        }

        .features-inner {
            max-width: 1280px;
            margin: auto;
            padding: 0 28px;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 16px;
        }

        .feat-item {
            display: flex;
            align-items: center;
            gap: 12px
        }

        .feat-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            background: var(--pk-soft);
            border: 1px solid rgba(214,19,109,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: var(--pk);
            flex-shrink: 0;
        }

        .feat-title {
            font-size: .82rem;
            font-weight: 700;
            color: var(--dark)
        }

        .feat-sub {
            font-size: .72rem;
            color: var(--muted)
        }

        /* ─────────────── SECTION HEADER ─────────────── */
        .sec-hd {
            text-align: center;
            margin-bottom: 48px
        }

        .sec-hd-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--pk);
            margin-bottom: 12px;
        }

            .sec-hd-tag::before, .sec-hd-tag::after {
                content: '';
                display: inline-block;
                width: 28px;
                height: 1.5px;
                background: var(--pk);
            }

        .sec-title {
            font-family: var(--display);
            font-size: 2.8rem;
            font-weight: 600;
            color: var(--dark);
            line-height: 1.2;
            margin-bottom: 10px;
        }

        .sec-sub {
            font-size: .9rem;
            color: var(--muted);
            max-width: 500px;
            margin: 0 auto;
            line-height: 1.7
        }

        /* ─────────────── ABOUT SECTION ─────────────── */
        .about-section {
            padding: 90px 0;
            background: #fff;
            background-image: radial-gradient(ellipse 60% 50% at 80% 50%,rgba(214,19,109,.04) 0%,transparent 70%);
        }

        .about-wrap {
            max-width: 1280px;
            margin: auto;
            padding: 0 40px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 72px;
            align-items: center
        }

        @@media(max-width:900px) {
            .about-wrap {
                grid-template-columns: 1fr;
                gap: 40px;
                padding: 0 24px
            }
        }

        .about-img-col {
            position: relative
        }

        .about-img-main {
            width: 100%;
            height: 500px;
            object-fit: cover;
            border-radius: 20px;
            box-shadow: 0 24px 72px rgba(214,19,109,.18);
        }

        .about-img-accent {
            position: absolute;
            bottom: -24px;
            right: -24px;
            width: 180px;
            height: 180px;
            object-fit: cover;
            border-radius: 16px;
            border: 4px solid #fff;
            box-shadow: 0 12px 36px rgba(0,0,0,.15);
        }

        .about-badge-float {
            position: absolute;
            top: 28px;
            left: -20px;
            background: var(--pk);
            color: #fff;
            border-radius: 16px;
            padding: 16px 20px;
            box-shadow: 0 8px 28px rgba(214,19,109,.35);
            text-align: center;
        }

        .about-badge-num {
            font-family: var(--display);
            font-size: 2.2rem;
            font-weight: 700;
            line-height: 1
        }

        .about-badge-txt {
            font-size: .65rem;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            opacity: .85
        }

        .about-text-col {
        }

        .about-tagline {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--pk);
            margin-bottom: 14px
        }

        .about-heading {
            font-family: var(--display);
            font-size: 2.8rem;
            font-weight: 600;
            color: var(--dark);
            line-height: 1.15;
            margin-bottom: 20px
        }

            .about-heading em {
                color: var(--pk);
                font-style: italic
            }

        .about-body {
            font-size: .9rem;
            color: var(--muted);
            line-height: 1.85;
            margin-bottom: 24px
        }

        .about-points {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 32px
        }

        .apoint {
            display: flex;
            align-items: flex-start;
            gap: 12px
        }

        .apoint-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: var(--pk-soft);
            border: 1px solid rgba(214,19,109,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .9rem;
            color: var(--pk);
            flex-shrink: 0;
            margin-top: 1px;
        }

        .apoint-txt strong {
            display: block;
            font-size: .85rem;
            font-weight: 700;
            color: var(--dark)
        }

        .apoint-txt span {
            font-size: .78rem;
            color: var(--muted)
        }

        .about-btns {
            display: flex;
            gap: 14px;
            flex-wrap: wrap
        }

        .btn-primary-fill {
            background: var(--pk);
            color: #fff;
            border: none;
            padding: 13px 30px;
            border-radius: 30px;
            font-size: .85rem;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            cursor: pointer;
            transition: var(--tr);
            box-shadow: 0 6px 20px rgba(214,19,109,.3);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

            .btn-primary-fill:hover {
                background: var(--pk-dark);
                color: #fff;
                transform: translateY(-2px)
            }

        .btn-outline-dark {
            background: transparent;
            color: var(--dark);
            border: 1.5px solid rgba(26,26,46,.2);
            padding: 13px 30px;
            border-radius: 30px;
            font-size: .85rem;
            font-weight: 600;
            letter-spacing: .06em;
            text-transform: uppercase;
            cursor: pointer;
            transition: var(--tr);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

            .btn-outline-dark:hover {
                border-color: var(--pk);
                color: var(--pk)
            }

        /* ─────────────── CATEGORIES GRID ─────────────── */
        .categories-section {
            padding: 90px 0;
            background: var(--bg)
        }

        .cats-wrap {
            max-width: 1280px;
            margin: auto;
            padding: 0 28px
        }

        .cats-grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 20px
        }

        @@media(max-width:900px) {
            .cats-grid {
                grid-template-columns: repeat(2,1fr)
            }
        }

        @@media(max-width:576px) {
            .cats-grid {
                grid-template-columns: 1fr
            }
        }

        .cat-card {
            position: relative;
            overflow: hidden;
            border-radius: 20px;
            height: 320px;
            cursor: pointer;
            box-shadow: 0 8px 32px rgba(0,0,0,.1);
        }

            .cat-card img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform .6s cubic-bezier(.4,0,.2,1);
            }

            .cat-card:hover img {
                transform: scale(1.08)
            }

        .cat-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(0deg,rgba(15,15,26,.8) 0%,rgba(15,15,26,.2) 60%,transparent 100%);
            transition: var(--tr);
        }

        .cat-card:hover .cat-overlay {
            background: linear-gradient(0deg,rgba(214,19,109,.75) 0%,rgba(15,15,26,.4) 60%,transparent 100%)
        }

        .cat-content {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 28px 24px;
        }

        .cat-tag {
            display: inline-block;
            background: var(--pk);
            color: #fff;
            font-size: .62rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            padding: 3px 12px;
            border-radius: 20px;
            margin-bottom: 10px;
        }

        .cat-name {
            font-family: var(--display);
            font-size: 1.6rem;
            font-weight: 600;
            color: #fff;
            line-height: 1.2;
            margin-bottom: 6px
        }

        .cat-count {
            font-size: .75rem;
            color: rgba(255,255,255,.65)
        }

        .cat-arrow {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: rgba(255,255,255,.15);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,.25);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: .9rem;
            opacity: 0;
            transform: translateX(10px);
            transition: var(--tr);
        }

        .cat-card:hover .cat-arrow {
            opacity: 1;
            transform: translateX(0)
        }

        /* ─────────────── PRODUCTS SECTION ─────────────── */
        .shop-section {
            padding: 90px 0;
            background: #fff
        }

        .shop-wrap {
            max-width: 1280px;
            margin: auto;
            padding: 0 28px
        }

        .shop-bar {
            background: #fff;
            border-radius: 16px;
            padding: 18px 22px;
            margin-bottom: 36px;
            box-shadow: 0 4px 28px rgba(214,19,109,.08);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            border: 1.5px solid rgba(214,19,109,.15);
        }

        .shop-bar-left {
            display: flex;
            align-items: center;
            gap: 12px
        }

        .shop-bar-logo {
            width: 48px;
            height: 48px;
            object-fit: cover;
            border-radius: 12px;
            border: 2px solid var(--pk);
        }

        .shop-bar-name {
            font-weight: 800;
            color: var(--pk);
            font-size: 1rem;
            font-family: var(--display)
        }

        .shop-bar-addr {
            font-size: .74rem;
            color: var(--muted);
            display: flex;
            align-items: center;
            gap: 4px
        }

            .shop-bar-addr i {
                color: var(--pk);
                font-size: .75rem
            }

        .filter-row {
            display: flex;
            gap: 10px
        }

            .filter-row .form-control,
            .filter-row .form-select {
                border: 1.5px solid rgba(214,19,109,.2);
                border-radius: 10px;
                font-size: .84rem;
                font-family: var(--body);
                background: #fff;
                color: var(--dark);
                transition: var(--tr);
            }

                .filter-row .form-control:focus,
                .filter-row .form-select:focus {
                    border-color: var(--pk);
                    box-shadow: 0 0 0 3px rgba(214,19,109,.12)
                }

        @@media(max-width:700px) {
            .shop-bar {
                flex-direction: column;
                align-items: flex-start
            }

            .filter-row {
                width: 100%
            }

                .filter-row .form-control, .filter-row .form-select {
                    flex: 1
                }
        }

        /* Category title */
        .cat-title-row {
            margin: 44px 0 22px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .cat-title-row::before, .cat-title-row::after {
                content: '';
                flex: 1;
                height: 1px;
                background: linear-gradient(90deg,transparent,rgba(214,19,109,.25),transparent);
            }

        .cat-title-badge {
            background: linear-gradient(135deg,var(--pk),var(--pk-dark));
            color: #fff;
            padding: 8px 22px;
            border-radius: 50px;
            font-size: .82rem;
            font-weight: 700;
            letter-spacing: .04em;
            white-space: nowrap;
            box-shadow: 0 4px 16px rgba(214,19,109,.28);
            display: flex;
            align-items: center;
            gap: 7px;
        }

        /* Product Card */
        .product-card-wrap {
            height: 100%
        }

        .pcard {
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(214,19,109,.08);
            box-shadow: 0 2px 16px rgba(214,19,109,.06);
            transition: transform .4s cubic-bezier(.34,1.56,.64,1),box-shadow .35s ease;
            cursor: pointer;
        }

            .pcard:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 52px rgba(214,19,109,.18);
                border-color: rgba(214,19,109,.3)
            }

        .pcard-img {
            height: 200px;
            overflow: hidden;
            position: relative;
            background: var(--pk-soft)
        }

            .pcard-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform .55s ease
            }

        .pcard:hover .pcard-img img {
            transform: scale(1.1)
        }

        .pcard-discount {
            position: absolute;
            top: 10px;
            left: 10px;
            background: linear-gradient(135deg,var(--pk),var(--pk-dark));
            color: #fff;
            font-size: .62rem;
            font-weight: 800;
            padding: 3px 10px;
            border-radius: 20px;
            z-index: 2;
            box-shadow: 0 4px 12px rgba(214,19,109,.4);
        }

        .pcard-zoom {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 3;
            pointer-events: none;
            transition: background .3s;
        }

            .pcard-zoom i {
                font-size: 1.8rem;
                color: rgba(255,255,255,0);
                transition: color .3s
            }

        .pcard:hover .pcard-zoom {
            background: rgba(214,19,109,.32)
        }

            .pcard:hover .pcard-zoom i {
                color: rgba(255,255,255,.9)
            }

        .pcard-wishlist {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: rgba(255,255,255,.85);
            backdrop-filter: blur(6px);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .9rem;
            color: rgba(214,19,109,.5);
            z-index: 4;
            transition: var(--tr);
            cursor: pointer;
            pointer-events: auto;
            border: none;
        }

            .pcard-wishlist:hover {
                background: var(--pk);
                color: #fff
            }

        .pcard-body {
            padding: 14px 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            flex-grow: 1
        }

        .pcard-name {
            font-size: .9rem;
            font-weight: 700;
            color: var(--dark);
            line-height: 1.3;
            margin: 0
        }

        .pcard-desc {
            font-size: .73rem;
            color: var(--muted);
            line-height: 1.4
        }

        .pcard-price {
            margin-top: auto;
            padding-top: 8px;
            display: flex;
            align-items: baseline;
            gap: 7px;
        }

        .pcard-cur {
            font-weight: 800;
            font-size: .95rem;
            color: var(--pk)
        }

        .pcard-old {
            font-size: .78rem;
            color: #dc3545;
            text-decoration: line-through;
            opacity: .8
        }

        .qty-strip {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-top: 10px;
            background: var(--pk-soft);
            border-radius: 30px;
            padding: 6px 10px;
        }

        .qty-b {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            border: none;
            background: var(--pk);
            color: #fff;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: transform .2s,background .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(214,19,109,.28);
            line-height: 1;
        }

            .qty-b:hover {
                transform: scale(1.12);
                background: var(--pk-dark)
            }

            .qty-b:active {
                transform: scale(.92)
            }

        .qty-n {
            font-size: .95rem;
            font-weight: 800;
            min-width: 22px;
            text-align: center;
            color: var(--dark)
        }

        @@media(max-width:576px) {
            .pcard-img {
                height: 160px
            }
        }

        /* Flying item */
        .flying-img {
            position: fixed;
            z-index: 9999;
            pointer-events: none;
            transition: all .75s cubic-bezier(.4,0,.2,1);
            border-radius: 10px;
            box-shadow: 0 8px 24px rgba(214,19,109,.3)
        }

        /* ─────────────── FASHION CONTENT STRIP ─────────────── */
        .fashion-strip {
            background: var(--dark);
            padding: 72px 0;
            background-image: radial-gradient(ellipse 80% 60% at 50% 50%,rgba(214,19,109,.12) 0%,transparent 70%);
        }

        .fashion-strip-inner {
            max-width: 1280px;
            margin: auto;
            padding: 0 40px
        }

        .fashion-grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 60px;
            align-items: center
        }

        @@media(max-width:900px) {
            .fashion-grid {
                grid-template-columns: 1fr;
                gap: 36px
            }
        }

        .fashion-text .ft-tag {
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--pk);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .fashion-text .ft-tag::before {
                content: '';
                width: 28px;
                height: 1.5px;
                background: var(--pk)
            }

        .fashion-heading {
            font-family: var(--display);
            font-size: 3rem;
            font-weight: 600;
            color: #fff;
            line-height: 1.1;
            margin-bottom: 18px;
        }

            .fashion-heading em {
                color: var(--pk);
                font-style: italic
            }

        .fashion-body {
            font-size: .88rem;
            color: rgba(255,255,255,.55);
            line-height: 1.85;
            margin-bottom: 32px
        }

        .fashion-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 32px
        }

        .fpill {
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.1);
            color: rgba(255,255,255,.7);
            font-size: .76rem;
            font-weight: 600;
            padding: 7px 16px;
            border-radius: 20px;
            cursor: pointer;
            transition: var(--tr);
        }

            .fpill:hover, .fpill.active {
                background: var(--pk);
                border-color: var(--pk);
                color: #fff
            }

        .fashion-cta-btn {
            background: linear-gradient(135deg,var(--pk),var(--pk-dark));
            color: #fff;
            border: none;
            padding: 14px 32px;
            border-radius: 30px;
            font-size: .85rem;
            font-weight: 700;
            letter-spacing: .07em;
            text-transform: uppercase;
            cursor: pointer;
            transition: var(--tr);
            box-shadow: 0 6px 24px rgba(214,19,109,.4);
            display: inline-flex;
            align-items: center;
            gap: 9px;
        }

            .fashion-cta-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 32px rgba(214,19,109,.5)
            }

        .fashion-cards {
            display: flex;
            flex-direction: column;
            gap: 16px
        }

        .fcard {
            background: rgba(255,255,255,.05);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 16px;
            padding: 20px 22px;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: var(--tr);
            cursor: default;
        }

            .fcard:hover {
                background: rgba(214,19,109,.1);
                border-color: rgba(214,19,109,.3)
            }

        .fcard-icon {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            background: rgba(214,19,109,.15);
            border: 1px solid rgba(214,19,109,.25);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: var(--pk);
            flex-shrink: 0;
        }

        .fcard-title {
            font-size: .9rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 3px
        }

        .fcard-sub {
            font-size: .76rem;
            color: rgba(255,255,255,.45)
        }

        /* ─────────────── TESTIMONIALS ─────────────── */
        .testimonial-section {
            padding: 90px 0;
            background: var(--bg)
        }

        .test-wrap {
            max-width: 1100px;
            margin: auto;
            padding: 0 28px
        }

        .test-grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 24px
        }

        @@media(max-width:900px) {
            .test-grid {
                grid-template-columns: 1fr 1fr
            }
        }

        @@media(max-width:576px) {
            .test-grid {
                grid-template-columns: 1fr
            }
        }

        .tcard {
            background: #fff;
            border-radius: 18px;
            padding: 28px 24px;
            border: 1px solid rgba(214,19,109,.1);
            box-shadow: 0 4px 24px rgba(214,19,109,.06);
            transition: var(--tr);
        }

            .tcard:hover {
                transform: translateY(-4px);
                box-shadow: 0 12px 40px rgba(214,19,109,.12);
                border-color: rgba(214,19,109,.25)
            }

        .tcard-stars {
            display: flex;
            gap: 3px;
            margin-bottom: 14px
        }

            .tcard-stars i {
                font-size: .8rem;
                color: var(--gold)
            }

        .tcard-text {
            font-size: .85rem;
            color: var(--muted);
            line-height: 1.75;
            font-style: italic;
            margin-bottom: 20px
        }

        .tcard-author {
            display: flex;
            align-items: center;
            gap: 10px
        }

        .tcard-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: linear-gradient(135deg,var(--pk),var(--pk-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .85rem;
            font-weight: 800;
            color: #fff;
            flex-shrink: 0;
        }

        .tcard-name {
            font-size: .82rem;
            font-weight: 700;
            color: var(--dark)
        }

        .tcard-loc {
            font-size: .72rem;
            color: var(--muted)
        }

        /* ─────────────── NEWSLETTER ─────────────── */
        .newsletter-section {
            background: linear-gradient(135deg,var(--pk),var(--pk-dark));
            padding: 72px 0;
        }

        .nl-inner {
            max-width: 680px;
            margin: auto;
            text-align: center;
            padding: 0 28px
        }

        .nl-icon {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: rgba(255,255,255,.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: #fff;
            margin: 0 auto 20px;
            border: 1px solid rgba(255,255,255,.25);
        }

        .nl-title {
            font-family: var(--display);
            font-size: 2.4rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 10px
        }

        .nl-sub {
            font-size: .88rem;
            color: rgba(255,255,255,.75);
            margin-bottom: 28px
        }

        .nl-form {
            display: flex;
            gap: 10px;
            max-width: 440px;
            margin: 0 auto
        }

            .nl-form input {
                flex: 1;
                border: none;
                border-radius: 30px;
                padding: 13px 22px;
                font-family: var(--body);
                font-size: .88rem;
                outline: none;
                background: rgba(255,255,255,.95);
                color: var(--dark);
            }

            .nl-form button {
                background: #fff;
                color: var(--pk);
                border: none;
                border-radius: 30px;
                padding: 13px 24px;
                font-weight: 700;
                font-size: .82rem;
                cursor: pointer;
                white-space: nowrap;
                transition: var(--tr);
                letter-spacing: .04em;
            }

                .nl-form button:hover {
                    background: var(--dark);
                    color: #fff
                }

        @@media(max-width:480px) {
            .nl-form {
                flex-direction: column
            }
        }

        /* ─────────────── FOOTER ─────────────── */
        .site-footer {
            background: var(--footer)
        }

        .footer-top {
            max-width: 1280px;
            margin: auto;
            padding: 64px 40px 48px;
            display: grid;
            grid-template-columns: 1.8fr 1fr 1fr 1fr;
            gap: 48px;
            border-bottom: 1px solid rgba(255,255,255,.07);
        }

        @@media(max-width:1100px) {
            .footer-top {
                grid-template-columns: 1fr 1fr;
                gap: 36px;
                padding: 48px 28px
            }
        }

        @@media(max-width:600px) {
            .footer-top {
                grid-template-columns: 1fr;
                padding: 36px 20px
            }
        }

        .footer-brand p {
            font-size: .84rem;
            color: rgba(255,255,255,.4);
            line-height: 1.85;
            margin: 14px 0 22px;
            max-width: 280px
        }

        .footer-socials {
            display: flex;
            gap: 8px
        }

        .fsoc {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255,255,255,.5);
            font-size: .95rem;
            text-decoration: none;
            transition: var(--tr);
        }

            .fsoc:hover {
                background: var(--pk);
                border-color: var(--pk);
                color: #fff;
                transform: translateY(-2px)
            }

        .footer-col h5 {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .15em;
            text-transform: uppercase;
            color: var(--pk);
            margin-bottom: 18px;
        }

        .footer-col ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px
        }

            .footer-col ul li a {
                font-size: .82rem;
                color: rgba(255,255,255,.4);
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 7px;
                transition: color .2s;
            }

                .footer-col ul li a:hover {
                    color: var(--pk)
                }

                .footer-col ul li a i {
                    font-size: .75rem;
                    opacity: .6
                }

        .footer-contact-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 14px
        }

        .fc-icon {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            flex-shrink: 0;
            background: rgba(214,19,109,.12);
            border: 1px solid rgba(214,19,109,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .82rem;
            color: var(--pk);
            margin-top: 1px;
        }

        .fc-label {
            font-size: .7rem;
            color: rgba(255,255,255,.35);
            margin-bottom: 2px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .08em
        }

        .fc-val {
            font-size: .82rem;
            color: rgba(255,255,255,.6);
            text-decoration: none;
            transition: var(--tr)
        }

            .fc-val:hover {
                color: var(--pk)
            }

        .footer-bottom {
            text-align: center;
            padding: 18px 24px;
            font-size: .76rem;
            color: rgba(255,255,255,.2);
            background: rgba(0,0,0,.5);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 24px;
            flex-wrap: wrap;
        }

            .footer-bottom a {
                color: rgba(255,255,255,.3);
                text-decoration: none;
                transition: var(--tr)
            }

                .footer-bottom a:hover {
                    color: var(--pk)
                }

        /* ─────────────── PRODUCT MODAL ─────────────── */
        #productModal .modal-dialog {
            max-width: 720px
        }

        #productModal .modal-content {
            border-radius: 22px;
            border: none;
            overflow: hidden;
            background: transparent;
            box-shadow: 0 30px 80px rgba(214,19,109,.25)
