@model List<DynamicEcomDZ.Models.RedirectionTAB>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Hello B17</title>
    <link rel="icon" href="/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --c0: #06070d;
            --c1: #0d0f1a;
            --c2: #141726;
            --c3: #1e2235;
            --glass: rgba(14,16,26,0.88);
            --w10: rgba(255,255,255,0.10);
            --w06: rgba(255,255,255,0.06);
            --w03: rgba(255,255,255,0.03);
            --green: #28c76f;
            --green2: rgba(40,199,111,0.15);
            --green3: rgba(40,199,111,0.08);
            --text1: #f0eeea;
            --text2: #8b8fa8;
            --text3: #545871;
            --ease: cubic-bezier(0.22, 1, 0.36, 1);
            --spring: cubic-bezier(0.34, 1.56, 0.64, 1);
            --r-sm: 12px;
            --r-md: 18px;
            --r-lg: 28px;
        }

        html, body {
            width: 100%;
            min-height: 100%;
            font-family: 'Inter', sans-serif;
            background: var(--c0);
            color: var(--text1);
            overflow-x: hidden;
        }

        /* ═══════════════════════════════
                   BACKGROUND LAYER
                ═══════════════════════════════ */
        .bg-wrap {
            position: fixed;
            inset: 0;
            z-index: 0;
        }

        .bg-img {
            position: absolute;
            inset: -5%;
            background: url(/images/Background.jpg) center / cover no-repeat;
            filter: brightness(0.18) saturate(0.35);
            animation: slowDrift 20s ease-in-out infinite alternate;
        }

        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
            background-size: 48px 48px;
            mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 80%);
        }

        .bg-glow-1 {
            position: absolute;
            width: 640px;
            height: 640px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(40,199,111,0.12) 0%, transparent 65%);
            top: -200px;
            right: -100px;
            animation: floatA 12s ease-in-out infinite;
        }

        .bg-glow-2 {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(100,80,220,0.1) 0%, transparent 65%);
            bottom: -150px;
            left: -80px;
            animation: floatB 15s ease-in-out infinite;
        }

        .bg-noise {
            position: absolute;
            inset: 0;
            opacity: 0.022;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
            background-repeat: repeat;
            background-size: 128px 128px;
        }

        /* ═══════════════════════════════
                   PAGE LAYOUT
                ═══════════════════════════════ */
        .page {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: clamp(16px, 3vh, 32px) clamp(12px, 3vw, 24px);
        }

        /* ═══════════════════════════════
                   PORTAL CONTAINER
                ═══════════════════════════════ */
        .portal {
            width: min(1060px, 100%);
            display: flex;
            flex-direction: column;
            gap: 0;
            background: var(--glass);
            border: 1px solid var(--w10);
            border-radius: var(--r-lg);
            box-shadow: 0 0 0 1px var(--w03) inset, 0 50px 100px rgba(0,0,0,0.75), 0 12px 40px rgba(0,0,0,0.5);
            backdrop-filter: blur(32px) saturate(1.5);
            -webkit-backdrop-filter: blur(32px) saturate(1.5);
            overflow: hidden;
            animation: portalIn 0.7s var(--ease) both;
        }

            /* Top shimmer line */
            .portal::before {
                content: '';
                position: absolute;
                top: 0;
                left: 8%;
                right: 8%;
                height: 1px;
                background: linear-gradient(90deg, transparent 0%, rgba(40,199,111,0.6) 30%, rgba(40,199,111,0.9) 50%, rgba(40,199,111,0.6) 70%, transparent 100%);
            }

        /* ═══════════════════════════════
                   HEADER
                ═══════════════════════════════ */
        .header {
            padding: clamp(22px, 3.5vw, 36px) clamp(24px, 4vw, 48px) clamp(18px, 2.5vw, 28px);
            border-bottom: 1px solid var(--w06);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-shrink: 0;
            animation: slideDown 0.6s var(--ease) 0.1s both;
        }

        .header-brand {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .header-logo-wrap {
            position: relative;
            flex-shrink: 0;
        }

        .header-logo-bg {
            position: absolute;
            inset: -8px;
            border-radius: 50%;
            background: var(--green3);
            border: 1px solid rgba(40,199,111,0.2);
            animation: pulseBorder 3.5s ease-in-out infinite;
        }

        .header-logo {
            position: relative;
            height: clamp(42px, 5.5vw, 64px);
            width: auto;
            max-width: 200px;
            object-fit: contain;
            filter: drop-shadow(0 0 16px rgba(40,199,111,0.4));
            animation: logoIn 0.8s var(--ease) 0.25s both;
        }

        .header-text {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .header-title {
            font-family: 'Instrument Serif', serif;
            font-size: clamp(18px, 2.5vw, 28px);
            font-weight: 400;
            letter-spacing: -0.01em;
            color: var(--text1);
            line-height: 1.1;
        }

            .header-title em {
                font-style: italic;
                color: var(--green);
            }

        .header-sub {
            font-family: 'Syne', sans-serif;
            font-size: clamp(9px, 1vw, 11px);
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--text3);
        }

        /* Header right: item count pill */
        .header-badge {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 8px 16px;
            background: var(--w06);
            border: 1px solid var(--w10);
            border-radius: 99px;
        }

        .header-badge-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 8px var(--green);
            animation: dotPulse 2s ease-in-out infinite;
        }

        .header-badge-text {
            font-family: 'Syne', sans-serif;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.08em;
            color: var(--text2);
        }

        .header-badge-count {
            font-family: 'Syne', sans-serif;
            font-size: 12px;
            font-weight: 700;
            color: var(--green);
        }

        /* ═══════════════════════════════
                   BODY / GRID
                ═══════════════════════════════ */
        .body {
            padding: clamp(18px, 2.5vw, 28px) clamp(24px, 4vw, 48px) clamp(22px, 3vw, 36px);
            overflow-y: auto;
            overflow-x: hidden;
            max-height: calc(94vh - 120px);
        }

            .body::-webkit-scrollbar {
                width: 3px;
            }

            .body::-webkit-scrollbar-track {
                background: transparent;
            }

            .body::-webkit-scrollbar-thumb {
                background: rgba(40,199,111,0.25);
                border-radius: 3px;
            }

                .body::-webkit-scrollbar-thumb:hover {
                    background: rgba(40,199,111,0.5);
                }

        .grid {
            display: grid;
            gap: clamp(10px, 1.8vw, 16px);
            grid-template-columns: repeat(2, 1fr);
        }

        @@media (min-width: 560px) {
            .grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (min-width: 800px) {
            .grid {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        /* ═══════════════════════════════
                   CARD
                ═══════════════════════════════ */
        .card {
            position: relative;
            display: block;
            text-decoration: none;
            border-radius: var(--r-md);
            overflow: hidden;
            background: var(--c2);
            border: 1px solid var(--w06);
            aspect-ratio: 1 / 1.12;
            box-shadow: 0 0 0 1px var(--w03) inset, 0 8px 28px rgba(0,0,0,0.45);
            transition: transform 0.4s var(--spring), box-shadow 0.35s ease, border-color 0.3s ease;
            will-change: transform;
            animation: cardIn 0.5s var(--ease) both;
        }

            .card:hover {
                transform: translateY(-8px) scale(1.035);
                border-color: rgba(40,199,111,0.35);
                box-shadow: 0 0 0 1px rgba(40,199,111,0.1) inset, 0 24px 60px rgba(0,0,0,0.65), 0 0 0 1px rgba(40,199,111,0.3), 0 0 50px rgba(40,199,111,0.08);
                z-index: 5;
            }

        /* Image */
        .card-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            filter: brightness(0.7) saturate(0.8);
            transition: transform 0.6s ease, filter 0.4s ease;
        }

        .card:hover .card-img {
            transform: scale(1.08);
            filter: brightness(0.85) saturate(1.0);
        }

        /* Multi-stop gradient overlay */
        .card-grad {
            position: absolute;
            inset: 0;
            background: linear-gradient(0deg, rgba(6,7,13,0.97) 0%, rgba(6,7,13,0.65) 38%, rgba(6,7,13,0.15) 65%, rgba(6,7,13,0.04) 100%);
            z-index: 1;
        }

        /* Top-right number tag */
        .card-num {
            position: absolute;
            top: 12px;
            right: 12px;
            z-index: 3;
            font-family: 'Syne', sans-serif;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.1em;
            color: var(--text3);
            line-height: 1;
            transition: color 0.3s ease;
        }

        .card:hover .card-num {
            color: rgba(40,199,111,0.7);
        }

        /* Bottom content */
        .card-foot {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 2;
            padding: 12px 14px 14px;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        /* Category accent line */
        .card-line {
            width: 0;
            height: 1.5px;
            background: var(--green);
            border-radius: 2px;
            margin-bottom: 2px;
            transition: width 0.35s var(--ease);
        }

        .card:hover .card-line {
            width: 22px;
        }

        /* Name */
        .card-name {
            font-family: 'Syne', sans-serif;
            font-size: clamp(11px, 1.25vw, 13.5px);
            font-weight: 700;
            letter-spacing: 0.03em;
            color: var(--text1);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.2;
            transition: color 0.3s ease;
        }

        .card:hover .card-name {
            color: #fff;
        }

        /* Arrow cta */
        .card-cta {
            font-family: 'Inter', sans-serif;
            font-size: 10px;
            font-weight: 400;
            letter-spacing: 0.06em;
            color: var(--text3);
            display: flex;
            align-items: center;
            gap: 4px;
            overflow: hidden;
            max-height: 0;
            opacity: 0;
            transition: max-height 0.35s var(--ease), opacity 0.3s ease 0.05s;
        }

        .card-cta-arrow {
            display: inline-block;
            transition: transform 0.3s var(--ease);
        }

        .card:hover .card-cta {
            max-height: 20px;
            opacity: 1;
        }

        .card:hover .card-cta-arrow {
            transform: translateX(3px);
        }

        /* Corner bracket top-left */
        .card-bracket {
            position: absolute;
            top: 11px;
            left: 11px;
            width: 16px;
            height: 16px;
            z-index: 3;
            opacity: 0;
            transform: scale(0.7) translate(-2px,-2px);
            transition: opacity 0.3s ease, transform 0.4s var(--spring);
        }

            .card-bracket::before,
            .card-bracket::after {
                content: '';
                position: absolute;
                background: var(--green);
                border-radius: 1px;
            }

            .card-bracket::before {
                top: 0;
                left: 0;
                width: 100%;
                height: 1.5px;
            }

            .card-bracket::after {
                top: 0;
                left: 0;
                width: 1.5px;
                height: 100%;
            }

        .card:hover .card-bracket {
            opacity: 1;
            transform: scale(1) translate(0,0);
        }

        /* Hover top glow */
        .card-glow {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 70% 40% at 50% 0%, rgba(40,199,111,0.08), transparent 65%);
            opacity: 0;
            z-index: 1;
            transition: opacity 0.4s ease;
        }

        .card:hover .card-glow {
            opacity: 1;
        }

        /* ═══════════════════════════════
                   FOOTER BAR
                ═══════════════════════════════ */
        .footer {
            flex-shrink: 0;
            padding: 12px 48px;
            border-top: 1px solid var(--w06);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            animation: slideUp 0.6s var(--ease) 0.4s both;
        }

        .footer-left {
            font-size: 10px;
            font-weight: 400;
            letter-spacing: 0.08em;
            color: var(--text3);
            text-transform: uppercase;
        }

        .footer-dots {
            display: flex;
            gap: 5px;
            align-items: center;
        }

        .footer-dot {
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: var(--w10);
        }

            .footer-dot.active {
                background: var(--green);
                box-shadow: 0 0 6px var(--green);
            }

        @@media (max-width: 520px) {
            .header-text, .header-badge, .footer-left {
                display: none;
            }

            .footer {
                justify-content: center;
            }
        }

        /* ═══════════════════════════════
                   KEYFRAMES
                ═══════════════════════════════ */
        @@keyframes slowDrift {
            from {
                transform: scale(1.08) translateX(0);
            }

            to {
                transform: scale(1.12) translateX(-1%);
            }
        }

        @@keyframes floatA {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-40px);
            }
        }

        @@keyframes floatB {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(30px);
            }
        }

        @@keyframes pulseBorder {
            0%, 100% {
                transform: scale(1);
                opacity: 0.6;
            }

            50% {
                transform: scale(1.12);
                opacity: 0.25;
            }
        }

        @@keyframes dotPulse {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(0.8);
            }
        }

        @@keyframes portalIn {
            from {
                opacity: 0;
                transform: translateY(28px) scale(0.98);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes logoIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        @@keyframes cardIn {
            from {
                opacity: 0;
                transform: translateY(16px) scale(0.97);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @@media (orientation: landscape) and (max-height: 520px) {
            .portal {
                max-height: 98vh;
            }

            .header {
                padding: 10px 24px;
            }

            .header-logo {
                height: 36px;
            }

            .body {
                max-height: calc(98vh - 90px);
                padding: 12px 24px 16px;
            }

            .footer {
                display: none;
            }

            .grid {
                grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            }

            .card {
                aspect-ratio: 4/3;
            }
        }
    </style>
</head>

<body>

    <!-- Background -->
    <div class="bg-wrap">
        <div class="bg-img"></div>
        <div class="bg-grid"></div>
        <div class="bg-glow-1"></div>
        <div class="bg-glow-2"></div>
        <div class="bg-noise"></div>
    </div>

    <!-- Page wrapper -->
    <div class="page">
        <div class="portal" role="main">

            <!-- ── HEADER ── -->
            <div class="header">
                <div class="header-brand">
                    <div class="header-logo-wrap">
                        <div class="header-logo-bg"></div>
                        <img src="/images/png%20orignal.png"
                             class="header-logo"
                             alt="HelloB17"
                             onerror="this.src='/images/logo.png'" />
                    </div>
                    <div class="header-text">
                        <div class="header-title">Select your <em>section</em></div>
                        <div class="header-sub">HelloB17 Portal &nbsp;·&nbsp; All Categories</div>
                    </div>
                </div>

                <div class="header-badge">
                    <span class="header-badge-dot"></span>
                    <span class="header-badge-text">Active</span>
                    <span class="header-badge-count" id="sectionCount">@Model.Count</span>
                </div>
            </div>

            <!-- ── GRID ── -->
            <div class="body">
                <div class="grid">
                    @{
                        int i = 0;
                    }
                    @foreach (var item in Model)
                    {
                        <a href="@(item.FormUrl == "ComingSoon" ? Url.Action("ComingSoonPage", "Redirection") : "/" + item.FormUrl + "/Index/" + item.Id)"
                           onclick="localStorage.setItem('SelectionId', '@item.Id')"
                           class="card"
                           title="@item.Name"
                           aria-label="@item.Name"
                           style="animation-delay: @(i * 0.07)s">

                            @if (!string.IsNullOrEmpty(item.TabIcon))
                            {
                                <img class="card-img"
                                     src="@("/images/Department/" + item.TabIcon)"
                                     alt="@item.Name"
                                     loading="lazy" />
                            }
                            else
                            {
                                <img class="card-img"
                                     src="https://cdn-icons-png.flaticon.com/512/545/545682.png"
                                     alt="@item.Name"
                                     loading="lazy" />
                            }

                            <div class="card-grad"></div>
                            <div class="card-glow"></div>

                            <div class="card-bracket"></div>
                            <div class="card-num">@((i + 1).ToString("D2"))</div>

                            <div class="card-foot">
                                <div class="card-line"></div>
                                <div class="card-name">@item.Name</div>
                                <div class="card-cta">
                                    Open section
                                    <span class="card-cta-arrow">→</span>
                                </div>
                            </div>

                        </a>
                        i++;
                    }
                </div>
            </div>

            <!-- ── FOOTER ── -->
            <div class="footer">
                <span class="footer-left">HelloB17.pk &nbsp;·&nbsp; All rights reserved</span>
                <div class="footer-dots">
                    <div class="footer-dot active"></div>
                    <div class="footer-dot"></div>
                    <div class="footer-dot"></div>
                </div>
            </div>

        </div>
    </div>

</body>
</html>
